<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="paperformat_student_certificate_a4" model="report.paperformat">
            <field name="name">Student Certificate A4</field>
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">10</field>
            <field name="margin_bottom">10</field>
            <field name="margin_left">10</field>
            <field name="margin_right">10</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">0</field>
        </record>

        <record id="paperformat_student_certificate_a5" model="report.paperformat">
            <field name="name">Student Certificate A5</field>
            <field name="format">A5</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">8</field>
            <field name="margin_bottom">8</field>
            <field name="margin_left">8</field>
            <field name="margin_right">8</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">0</field>
        </record>

        <record id="action_report_student_certificate_a4" model="ir.actions.report">
            <field name="name">Student Certificate (A4)</field>
            <field name="model">aps.student.certificate</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">aps_sis.report_student_certificate_template</field>
            <field name="print_report_name">'Certificate - %s' % object.partner_id.name</field>
            <field name="paperformat_id" ref="aps_sis.paperformat_student_certificate_a4"/>
        </record>

        <record id="action_report_student_certificate_a5" model="ir.actions.report">
            <field name="name">Student Certificate (A5)</field>
            <field name="model">aps.student.certificate</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">aps_sis.report_student_certificate_template</field>
            <field name="print_report_name">'Certificate - %s' % object.partner_id.name</field>
            <field name="paperformat_id" ref="aps_sis.paperformat_student_certificate_a5"/>
        </record>

        <template id="report_student_certificate_template">
            <t t-call="web.basic_layout">
                <t t-foreach="docs" t-as="o">
                    <div class="page">
                        <div t-raw="o._render_certificate_body_html()"/>
                    </div>
                </t>
            </t>
        </template>
    </data>
</odoo>
