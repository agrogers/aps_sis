<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Custom paper format for submission report with no margins -->
        <record id="paperformat_submission_report" model="report.paperformat">
            <field name="name">Submission Report Format</field>
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">10</field>
            <field name="margin_bottom">15</field>
            <field name="margin_left">10</field>
            <field name="margin_right">10</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">0</field>
        </record>

        <!-- Report for Submissions - appears in Print menu -->
        <record id="submission_report_action" model="ir.actions.report">
            <field name="name">Submissions Report</field>
            <field name="model">aps.resource.submission</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">aps_sis.report_submission_template</field>
            <field name="print_report_name">'Submissions - %s' % object.create_date.strftime('%Y-%m-%d')</field>
            <field name="binding_model_id" ref="aps_sis.model_aps_resource_submission"/>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="aps_sis.paperformat_submission_report"/>
        </record>

        <!-- Report Template -->
        <template id="report_submission_template">
            <t t-call="web.basic_layout">
                <meta charset="utf-8"/>
                    <!-- Get options from data or use defaults -->
                    <t t-set="show_score" t-value="data.get('show_score', True) if data else True"/>
                    <t t-set="show_metadata" t-value="data.get('show_metadata', True) if data else True"/>
                    <t t-set="show_answer" t-value="data.get('show_answer', True) if data else True"/>
                    <t t-set="show_feedback" t-value="data.get('show_feedback', True) if data else True"/>
                    <t t-set="show_model_answer" t-value="data.get('show_model_answer', True) if data else True"/>
                    <t t-set="page_break_before_resource" t-value="data.get('page_break_before_resource', False) if data else False"/>
                    <t t-set="page_break_before_student" t-value="data.get('page_break_before_student', False) if data else False"/>
                    <t t-set="page_break_after_model_answer" t-value="data.get('page_break_after_model_answer', False) if data else False"/>
                    <t t-set="resource_counter" t-value="0"/>
                    
                    <style>
                        @page {
                            @bottom-center {
                                content: "Page " counter(page) " of " counter(pages);
                                font-size: 10px;
                                color: #666;
                            }
                        }
                        /* Reduce heading sizes in answer/feedback content so they dont overwhlem the main headings*/
                        .submission-content h1 { font-size: 1.6em; font-weight: bold; margin: 0.5em 0; }
                        .submission-content h2 { font-size: 1.5em; font-weight: bold; margin: 0.4em 0; }
                        .submission-content h3 { font-size: 1.4em; font-weight: bold; margin: 0.3em 0; }
                        .submission-content h4 { font-size: 1.3em; font-weight: bold; margin: 0.3em 0; }
                        .submission-content h5 { font-size: 1.2em; font-weight: bold; margin: 0.2em 0; }
                        .submission-content h6 { font-size: 1.1em; font-weight: normal; margin: 0.2em 0; }
                        
                    </style>
                    <div class="page">
                        <h1 class="text-center mb-4">Student Submissions Report</h1>
                        
                        <t t-foreach="grouped_submissions" t-as="resource_group">
                            <!-- Page break before resource if enabled (skip first resource) -->
                            <t t-if="page_break_before_resource and resource_counter > 0">
                                <div style="page-break-before: always;"></div>
                            </t>
                            <!-- Resource Header -->
                            <div class="resource-header mb-4" style="background-color: #e9ecef; padding: 15px; border-radius: 5px; border-left: 4px solid #007bff;">
                                <h2 class="mb-0" style="color: #007bff;">
                                    <t t-esc="resource_group[0]"/> 
                                    <small class="text-muted">(<t t-esc="len(resource_group[1])"/> submissions)</small>
                                </h2>
                            </div>    
                            <!-- Model Answer -->
                            <t t-if="show_model_answer">
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <h5 class="mb-2" style="color: #6c757d;">Model Answer</h5>
                                        <div class="submission-content" style="background-color: #f8f9fa; padding: 12px; border-left: 4px dotted #6c757d; min-height: 60px;">
                                            <t t-if="resource_group[1][0].model_answer">
                                                <div t-raw="resource_group[1][0].model_answer"/>
                                            </t>
                                            <t t-else="">
                                                <p class="text-muted"><em>No model answer provided</em></p>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                                <!-- Page break after model answer if enabled -->
                                <t t-if="page_break_after_model_answer">
                                    <div style="page-break-after: always;"></div>
                                </t>
                            </t>
                            
                            
                            <!-- Submissions for this resource -->
                            <t t-set="student_counter" t-value="0"/>
                            <t t-foreach="resource_group[1]" t-as="submission">
                                <!-- Page break before student if enabled (skip first student per resource) -->
                                <t t-if="page_break_before_student and student_counter > 0">
                                    <div style="page-break-before: always;"></div>
                                </t>
                                <div class="submission-item" style="page-break-inside: avoid; margin-bottom: 30px; padding: 1px; border: 0px solid #ccc;">
                                    <!-- Header Row -->
                                    <div class="row mb-3" style="background-color: #bbbbbb; padding: 5px; border-radius: 4px;">
                                        <div class="col-12">
                                            <h4 t-field="submission.student_id.name" class="mb-1"/>
                                            <t t-esc="resource_group[0]" style="font-size: 0.8em"/>
                                        </div>
                                    </div>

                                    <!-- Score and Percentage Row -->
                                    <t t-if="show_score">
                                        <div class="row mb-3" style="background-color: #f8f9fa; padding: 10px; border-radius: 4px;">
                                            <div class="col-4">
                                                <p class="mb-0">
                                                    <strong>Score:</strong> <span t-field="submission.score"/> / <span t-field="submission.out_of_marks"/>
                                                </p>
                                            </div>
                                            <div class="col-4">
                                                <p class="mb-0">
                                                    <strong>Percentage:</strong> <span t-field="submission.result_percent"/>%
                                                </p>
                                            </div>
                                            <div class="col-4">
                                                <p class="mb-0">
                                                    <strong>Status:</strong> <span t-field="submission.due_status"/>
                                                </p>
                                            </div>
                                        </div>
                                    </t>

                                    <!-- Metadata -->
                                    <t t-if="show_metadata">
                                        <div class="row" style="border-top: 1px solid #eee; padding-top: 10px; font-size: 11px;">
                                            <div class="col-6">
                                                <p class="mb-0 text-muted">
                                                    <strong>Submitted:</strong> <span t-field="submission.date_submitted" t-options="{'widget': 'datetime', 'format': 'dd/MM/yyyy HH:mm'}"/>
                                                </p>
                                            </div>
                                            <div class="col-6 text-right">
                                                <p class="mb-0 text-muted">
                                                    <strong>Finalized:</strong> <span t-field="submission.date_completed" t-options="{'widget': 'datetime', 'format': 'dd/MM/yyyy HH:mm'}"/>
                                                </p>
                                            </div>
                                        </div>
                                    </t>

                                    <!-- Student Answer -->
                                    <t t-if="show_answer">
                                        <div class="row mb-3">
                                            <div class="col-12">
                                                <h5 class="mb-2" style="color: #0066cc;">Student Answer</h5>
                                                <div class="submission-content" style="background-color: #f0f7ff; padding: 12px; border-left: 3px solid #0066cc; min-height: 60px;">
                                                    <t t-if="submission.answer">
                                                        <div t-raw="submission.answer"/>
                                                    </t>
                                                    <t t-else="">
                                                        <p class="text-muted"><em>No answer submitted</em></p>
                                                    </t>
                                                </div>
                                            </div>
                                        </div>
                                    </t>

                                    <!-- Feedback -->
                                    <t t-if="show_feedback">
                                        <div class="row mb-3">
                                            <div class="col-12">
                                                <h5 class="mb-2" style="color: #28a745;">Teacher Feedback</h5>
                                                <div class="submission-content" style="padding: 12px; border-left: 3px solid #28a745; min-height: 60px;">
                                                    <t t-if="submission.feedback">
                                                        <div t-raw="submission.feedback"/>
                                                    </t>
                                                    <t t-else="">
                                                        <p class="text-muted"><em>No feedback provided</em></p>
                                                    </t>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                                <t t-set="student_counter" t-value="student_counter + 1"/>
                            </t>
                            <t t-set="resource_counter" t-value="resource_counter + 1"/>
                        </t>
                    </div>
                </t>
        </template>
    </data>
</odoo>
