<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Inherit and modify the Program Level list view -->
    <record id="view_op_program_level_tree_inherit" model="ir.ui.view">
        <field name="name">op.program.level.list.inherit.aps</field>
        <field name="model">op.program.level</field>
        <field name="inherit_id" ref="openeducat_core.view_op_program_level_tree"/>
        <field name="arch" type="xml">
            <list position="attributes">
                <attribute name="string">Program Level</attribute>
                <attribute name="default_order">sequence, name</attribute>
            </list>
            <xpath expr="//field[@name='name']" position="before">
                <field name="sequence" widget="handle"/>
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                <field name="short_name" optional="show"/>
                <field name="code" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit and modify the Program Level form view -->
    <record id="view_op_program_level_form_inherit" model="ir.ui.view">
        <field name="name">op.program.level.form.inherit.aps</field>
        <field name="model">op.program.level</field>
        <field name="inherit_id" ref="openeducat_core.view_op_program_level_form"/>
        <field name="arch" type="xml">
            <form position="attributes">
                <attribute name="string">Program Level</attribute>
            </form>
            <xpath expr="//label[@for='name']" position="attributes">
                <attribute name="string">Program Level</attribute>
            </xpath>
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="placeholder">e.g. "Bachelor's Degree"</attribute>
            </xpath>
            <xpath expr="//div[hasclass('oe_title')]/parent::div" position="after">
                <group>
                    <group>
                        <field name="short_name" placeholder="e.g. BSc, MSc"/>
                    </group>
                    <group>
                        <field name="code" placeholder="e.g. UG, PG"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Override the action to change the menu name -->
    <record model="ir.actions.act_window" id="openeducat_core.act_open_op_program_level_view">
        <field name="name">Program Levels</field>
    </record>

    <!-- Override the menu item name -->
    <menuitem id="openeducat_core.menu_op_program_level_sub"
              name="Program Levels"/>
</odoo>
