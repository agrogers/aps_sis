<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ── Form view ──────────────────────────────────────────────────────── -->
    <record id="view_aps_time_tracking_form" model="ir.ui.view">
        <field name="name">aps.time.tracking.form</field>
        <field name="model">aps.time.tracking</field>
        <field name="arch" type="xml">
            <form string="Time Entry">
                <sheet>
                    <group>
                        <group>
                            <field name="is_current_user_teacher" invisible="1"/>
                            <field name="date"/>
                            <field name="subject_id" options="{'no_create': True}"/>
                            <field name="partner_id" options="{'no_create': True}" readonly="not is_current_user_teacher"/>
                            <field name="total_minutes"/>
                        </group>
                        <group>
                            <field name="start_time"/>
                            <field name="stop_time"/>
                            <field name="pause_minutes"/>
                            <field name="is_outside_school_hours"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── List view ─────────────────────────────────────────────────────── -->
    <record id="view_aps_time_tracking_list" model="ir.ui.view">
        <field name="name">aps.time.tracking.list</field>
        <field name="model">aps.time.tracking</field>
        <field name="arch" type="xml">
            <list string="Time Entries" decoration-muted="not stop_time">
                <field name="subject_icon" widget="image" string=" " optional="show" options="{'size': [24, 24]}"/>
                <field name="date" optional="show"/>
                <field name="subject_id" optional="show"/>
                <field name="partner_id" optional="show"/>
                <field name="start_time" optional="show"/>
                <field name="stop_time" optional="show"/>
                <field name="pause_minutes" optional="hide"/>
                <field name="total_minutes" string="Minutes" optional="show"/>
                <field name="is_outside_school_hours" string="Outside Hours" optional="show"/>
                <field name="notes" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ── Search view ───────────────────────────────────────────────────── -->
    <record id="view_aps_time_tracking_search" model="ir.ui.view">
        <field name="name">aps.time.tracking.search</field>
        <field name="model">aps.time.tracking</field>
        <field name="arch" type="xml">
            <search string="Search Time Entries">
                <field name="subject_id"/>
                <field name="partner_id"/>
                <field name="notes"/>
                <!-- Default filters -->
                <filter name="filter_today" string="Today"
                        domain="[('date','=', context_today())]"/>
                <filter name="filter_yesterday" string="Yesterday"
                        domain="[('date','=', context_today() + relativedelta(days=-1))]"/>
                <filter name="filter_this_week" string="This Week"
                        domain="[('date','&gt;=', context_today() + relativedelta(days=-context_today().weekday()))]"/>
                <separator/>
                <filter name="filter_outside_hours" string="Outside School Hours"
                        domain="[('is_outside_school_hours','=',True)]"/>
                <filter name="filter_in_hours" string="In School Hours"
                        domain="[('is_outside_school_hours','=',False)]"/>
                <!-- Search panel for subject (sidebar) -->
                <searchpanel>
                    <field name="subject_id" string="Subject" icon="fa-book" enable_counters="1"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <!-- ── Action ────────────────────────────────────────────────────────── -->
    <record id="action_aps_time_tracking" model="ir.actions.act_window">
        <field name="name">Time Tracking</field>
        <field name="res_model">aps.time.tracking</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_aps_time_tracking_search"/>
        <field name="context">{'search_default_filter_today': 1}</field>
    </record>

    <!-- Bind specific views to the action -->
    <record id="action_aps_time_tracking_view_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_aps_time_tracking_list"/>
        <field name="act_window_id" ref="action_aps_time_tracking"/>
    </record>

    <record id="action_aps_time_tracking_view_form" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_aps_time_tracking_form"/>
        <field name="act_window_id" ref="action_aps_time_tracking"/>
    </record>

</odoo>
