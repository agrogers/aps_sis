<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================================
         LIST VIEW
    ================================================================ -->
    <record id="view_aps_award_vote_list" model="ir.ui.view">
        <field name="name">aps.award.vote.list</field>
        <field name="model">aps.award.vote</field>
        <field name="arch" type="xml">
            <list string="Award Votes"
                  decoration-success="state == 'submitted'"
                  decoration-muted="state in ('closed', 'pending')"
                  decoration-warning="state == 'open'">
                <field name="image" widget="image" class="o_image_24_max" options="{'size': [24, 24]}" optional="show"/>
                <field name="vote_round_id" optional="show"/>
                <field name="award_category_id" optional="show"/>
                <field name="award_sub_category_id" optional="hide"/>
                <field name="recipient_partner_id"/>
                <field name="voter_partner_id" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'submitted'"
                       decoration-warning="state == 'open'"
                       decoration-muted="state in ('closed', 'pending')"/>
                <field name="submitted_date" optional="show"/>
                <field name="due_date" optional="hide"/>
                <field name="academic_week_id" optional="hide"/>
                <field name="comment" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ================================================================
         FORM VIEW
    ================================================================ -->
    <record id="view_aps_award_vote_form" model="ir.ui.view">
        <field name="name">aps.award.vote.form</field>
        <field name="model">aps.award.vote</field>
        <field name="arch" type="xml">
            <form string="Award Vote">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,open,submitted,closed"
                           clickable="1"/>
                </header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar" readonly="1"/>
                    <div class="oe_title">
                        <h1><field name="short_description" readonly="1" placeholder="(from round or category)"/></h1>
                    </div>
                    <group>
                        <group string="Round">
                            <field name="vote_round_id"/>
                            <field name="round_status" widget="badge"
                                   decoration-info="round_status == 'draft'"
                                   decoration-success="round_status == 'open'"
                                   decoration-warning="round_status == 'closed'"
                                   decoration-primary="round_status == 'finalised'"
                                   readonly="1"/>
                            <field name="round_datetime_start" readonly="1"/>
                            <field name="round_datetime_end" readonly="1"/>
                        </group>
                        <group string="Award">
                            <field name="award_category_id"/>
                            <field name="award_sub_category_id"
                                   invisible="not award_category_id"/>
                            <field name="academic_week_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="People">
                            <field name="recipient_partner_id"/>
                            <field name="voter_partner_id"/>
                        </group>
                        <group string="Dates">
                            <field name="open_date"/>
                            <field name="due_date"/>
                            <field name="submitted_date"/>
                        </group>
                    </group>
                    <group string="Comments">
                        <field name="comment" nolabel="1" placeholder="Voter comment…"/>
                        <field name="note" nolabel="1" placeholder="System note…"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================
         SEARCH VIEW
    ================================================================ -->
    <record id="view_aps_award_vote_search" model="ir.ui.view">
        <field name="name">aps.award.vote.search</field>
        <field name="model">aps.award.vote</field>
        <field name="arch" type="xml">
            <search string="Award Votes">
                <field name="recipient_partner_id" string="Recipient"/>
                <field name="voter_partner_id" string="Voter"/>
                <field name="vote_round_id" string="Round"/>
                <field name="award_category_id" string="Category"/>
                <field name="round_name" string="Round Name"/>

                <filter string="Submitted" name="submitted" domain="[('state','=','submitted')]"/>
                <filter string="Open" name="open" domain="[('state','=','open')]"/>
                <filter string="Closed" name="closed" domain="[('state','=','closed')]"/>
                <filter string="Pending" name="pending" domain="[('state','=','pending')]"/>
                <separator/>
                <filter string="Has Recipient" name="has_recipient"
                        domain="[('recipient_partner_id','!=',False)]"/>
                <filter string="No Recipient Yet" name="no_recipient"
                        domain="[('recipient_partner_id','=',False)]"/>

                <group expand="0" string="Group By">
                    <filter string="Round" name="group_round"
                            context="{'group_by': 'vote_round_id'}"/>
                    <filter string="Category" name="group_category"
                            context="{'group_by': 'award_category_id'}"/>
                    <filter string="Recipient" name="group_recipient"
                            context="{'group_by': 'recipient_partner_id'}"/>
                    <filter string="Voter" name="group_voter"
                            context="{'group_by': 'voter_partner_id'}"/>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Submitted Date" name="group_submitted_date"
                            context="{'group_by': 'submitted_date:month'}"/>
                    <filter string="Academic Week" name="group_week"
                            context="{'group_by': 'academic_week_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================
         PIVOT VIEW
    ================================================================ -->
    <record id="view_aps_award_vote_pivot" model="ir.ui.view">
        <field name="name">aps.award.vote.pivot</field>
        <field name="model">aps.award.vote</field>
        <field name="arch" type="xml">
            <pivot string="Award Votes" display_quantity="1">
                <!-- Rows: rounds / categories; Cols: recipients -->
                <field name="vote_round_id" type="row"/>
                <field name="award_category_id" type="row"/>
                <field name="recipient_partner_id" type="col"/>
                <field name="state" type="col"/>
            </pivot>
        </field>
    </record>

    <!-- ================================================================
         GRAPH VIEW
    ================================================================ -->
    <record id="view_aps_award_vote_graph" model="ir.ui.view">
        <field name="name">aps.award.vote.graph</field>
        <field name="model">aps.award.vote</field>
        <field name="arch" type="xml">
            <!-- Default: votes per recipient, coloured by round -->
            <graph string="Award Votes" type="bar" stacked="1">
                <field name="recipient_partner_id" type="row"/>
                <field name="vote_round_id" type="col"/>
            </graph>
        </field>
    </record>

    <!-- ================================================================
         ACTION
    ================================================================ -->
    <record id="action_aps_award_vote" model="ir.actions.act_window">
        <field name="name">Award Votes</field>
        <field name="res_model">aps.award.vote</field>
        <field name="view_mode">list,pivot,graph,form</field>
        <field name="search_view_id" ref="view_aps_award_vote_search"/>
        <field name="context">{'search_default_submitted': 1}</field>
    </record>

    <record id="action_aps_award_vote_list_view" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_aps_award_vote_list"/>
        <field name="act_window_id" ref="action_aps_award_vote"/>
    </record>

    <record id="action_aps_award_vote_pivot_view" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="view_aps_award_vote_pivot"/>
        <field name="act_window_id" ref="action_aps_award_vote"/>
    </record>

    <record id="action_aps_award_vote_graph_view" model="ir.actions.act_window.view">
        <field name="sequence">3</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_aps_award_vote_graph"/>
        <field name="act_window_id" ref="action_aps_award_vote"/>
    </record>

    <record id="action_aps_award_vote_form_view" model="ir.actions.act_window.view">
        <field name="sequence">4</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_aps_award_vote_form"/>
        <field name="act_window_id" ref="action_aps_award_vote"/>
    </record>

</odoo>
