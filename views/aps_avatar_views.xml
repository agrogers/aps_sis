<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ─── Avatar Category Views ─── -->

    <record id="view_aps_avatar_category_list" model="ir.ui.view">
        <field name="name">aps.avatar.category.list</field>
        <field name="model">aps.avatar.category</field>
        <field name="arch" type="xml">
            <list string="Avatar Categories">
                <field name="name"/>
                <field name="avatar_count" string="Avatars"/>
            </list>
        </field>
    </record>

    <record id="view_aps_avatar_category_form" model="ir.ui.view">
        <field name="name">aps.avatar.category.form</field>
        <field name="model">aps.avatar.category</field>
        <field name="arch" type="xml">
            <form string="Avatar Category">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Category Name"/>
                        </h1>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_aps_avatar_categories" model="ir.actions.act_window">
        <field name="name">Avatar Categories</field>
        <field name="res_model">aps.avatar.category</field>
        <field name="view_mode">list,form</field>
    </record>


    <!-- ─── Avatar Views ─── -->


    <record id="view_aps_avatar_list" model="ir.ui.view">
        <field name="name">aps.avatar.list</field>
        <field name="model">aps.avatar</field>
        <field name="arch" type="xml">
            <list string="Avatars">
                <field name="image" widget="image" options="{'size': [48, 48]}"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="student_count" string="Used By"/>
            </list>
        </field>
    </record>

    <record id="view_aps_avatar_form" model="ir.ui.view">
        <field name="name">aps.avatar.form</field>
        <field name="model">aps.avatar</field>
        <field name="arch" type="xml">
            <form string="Avatar">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Avatar Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="category_id"/>
                            <field name="student_count" string="Used By"/>
                        </group>
                        <group>
                            <field name="image" widget="image"
                                   options="{'size': [256, 256]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Used By" name="used_by">
                            <field name="student_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_aps_avatar_kanban" model="ir.ui.view">
        <field name="name">aps.avatar.kanban</field>
        <field name="model">aps.avatar</field>
        <field name="arch" type="xml">
            <kanban string="Avatars" class="avatar-kanban-card">
                <field name="id"/>
                <field name="name"/>
                <field name="image"/>
                <field name="category_id"/>
                <field name="student_count"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex align-items-center p-2">
                            <field name="image" widget="image"
                                   options="{'size': [64, 64]}"/>
                            <div class="ms-2">
                                <strong><field name="name"/></strong><br/>
                                <small class="text-muted"><field name="category_id"/></small><br/>
                                <small t-if="record.student_count.value > 0" class="text-success">
                                    In use
                                </small>
                                <small t-else="" class="text-muted">
                                    Available
                                </small>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_aps_avatars" model="ir.actions.act_window">
        <field name="name">Avatars</field>
        <field name="res_model">aps.avatar</field>
        <field name="view_mode">kanban,list,form</field>
    </record>


    <!-- Server action: assign random avatars to users without one -->
    <record id="action_assign_random_avatars" model="ir.actions.server">
        <field name="name">Assign Random Avatars</field>
        <field name="model_id" ref="model_aps_avatar"/>
        <field name="binding_model_id" ref="model_aps_avatar"/>
        <field name="binding_type">action</field>
        <field name="state">code</field>
        <field name="code">action = env['aps.avatar'].action_assign_random_avatars()</field>
    </record>


    <!-- ─── Student form view — add avatar below profile image ─── -->

    <record id="view_op_student_form_avatar" model="ir.ui.view">
        <field name="name">op.student.form.inherit.avatar</field>
        <field name="model">op.student</field>
        <field name="inherit_id" ref="openeducat_core.view_op_student_form"/>
        <field name="arch" type="xml">
            <!-- Add the avatar selector below the profile image in the header area -->
            <xpath expr="//field[@name='image_1920']" position="after">
                <field name="avatar_id" widget="many2one"
                       options="{'no_create': True}"
                       string="Avatar"/>
            </xpath>
        </field>
    </record>


    <!-- ─── User profile form (HR/employee) — show avatar over profile picture ─── -->

    <record id="view_res_users_profile_avatar" model="ir.ui.view">
        <field name="name">res.users.profile.inherit.avatar</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="hr.res_users_view_form_profile"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='image_1920']" position="replace">
                <div style="position:relative;float:right;margin-bottom:10px;">
                    <field name="image_1920" widget="image" class="oe_avatar"
                           options='{"zoom": true, "preview_image":"avatar_128"}'/>
                    <field name="avatar_id" widget="avatar_selector"/>
                </div>
            </xpath>
        </field>
    </record>

    <!-- ─── User preferences form (base/student) — show avatar over profile picture ─── -->

    <record id="view_res_users_simple_avatar" model="ir.ui.view">
        <field name="name">res.users.simple.inherit.avatar</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form_simple_modif"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='image_1920']" position="replace">
                <div name="base_avatar_wrapper" style="position:relative;float:right;margin-bottom:10px;">
                    <!-- Students: profile image is read-only -->
                    <field name="image_1920" readonly="1" widget="image" class="oe_avatar"
                           options='{"preview_image": "avatar_128"}'
                           groups="aps_sis.group_aps_student"/>
                    <!-- Teachers / Managers: profile image is editable -->
                    <field name="image_1920" readonly="0" widget="image" class="oe_avatar"
                           options='{"preview_image": "avatar_128"}'
                           groups="aps_sis.group_aps_teacher"/>
                    <field name="avatar_id" widget="avatar_selector"/>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
