<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- List View -->
    <record id="view_aps_award_vote_round_list" model="ir.ui.view">
        <field name="name">aps.award.vote.round.list</field>
        <field name="model">aps.award.vote.round</field>
        <field name="arch" type="xml">
            <list string="Vote Rounds" decoration-info="status == 'draft'" decoration-success="status == 'open'" decoration-muted="status in ('closed', 'finalised')">
                <field name="name"/>
                <field name="datetime_start"/>
                <field name="datetime_end"/>
                <field name="status" widget="badge" decoration-info="status == 'draft'" decoration-success="status == 'open'" decoration-warning="status == 'closed'" decoration-primary="status == 'finalised'"/>
                <field name="votes_cast"/>
                <field name="active_voter_count"/>
                <field name="total_voter_count"/>
                <field name="round_manager_ids" widget="many2many_tags" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_aps_award_vote_round_form" model="ir.ui.view">
        <field name="name">aps.award.vote.round.form</field>
        <field name="model">aps.award.vote.round</field>
        <field name="arch" type="xml">
            <form string="Award Vote Round">
                <header>
                    <button name="action_open" string="Open" type="object"
                            invisible="status != 'draft'"
                            class="btn-primary"/>
                    <button name="action_close" string="Close" type="object"
                            invisible="status != 'open'"/>
                    <button name="action_finalise" string="Finalise" type="object"
                            invisible="status != 'closed'"
                            class="btn-primary"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="status not in ('open', 'closed')"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,open,closed,finalised"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Round Name"/></h1>
                    </div>
                    <group>
                        <group string="Schedule">
                            <field name="datetime_start"/>
                            <field name="datetime_end"/>
                        </group>
                        <group string="Participation">
                            <field name="votes_cast"/>
                            <field name="active_voter_count"/>
                            <field name="total_voter_count"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                    <group string="Round Managers">
                        <field name="round_manager_ids" widget="many2many_tags" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Votes" name="votes">
                            <field name="vote_ids" readonly="1">
                                <list>
                                    <field name="submitted_date"/>
                                    <field name="voter_partner_id"/>
                                    <field name="recipient_partner_id"/>
                                    <field name="award_category_id"/>
                                    <field name="award_sub_category_id" optional="hide"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Eligible Voters" name="eligible_voters">
                            <field name="eligible_voters" widget="json" nolabel="1"/>
                        </page>
                        <page string="Eligible Candidates" name="eligible_candidates">
                            <field name="eligible_candidates" widget="json" nolabel="1"/>
                        </page>
                        <page string="Rules" name="rules">
                            <field name="rules" widget="json" nolabel="1"/>
                        </page>
                        <page string="Result Summary" name="result_summary">
                            <field name="result_summary" widget="json" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_aps_award_vote_round_search" model="ir.ui.view">
        <field name="name">aps.award.vote.round.search</field>
        <field name="model">aps.award.vote.round</field>
        <field name="arch" type="xml">
            <search string="Vote Rounds">
                <field name="name"/>
                <field name="round_manager_ids"/>
                <separator/>
                <filter name="filter_draft" string="Draft" domain="[('status', '=', 'draft')]"/>
                <filter name="filter_open" string="Open" domain="[('status', '=', 'open')]"/>
                <filter name="filter_closed" string="Closed" domain="[('status', '=', 'closed')]"/>
                <filter name="filter_finalised" string="Finalised" domain="[('status', '=', 'finalised')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_status" string="Status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_aps_award_vote_round" model="ir.actions.act_window">
        <field name="name">Vote Rounds</field>
        <field name="res_model">aps.award.vote.round</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_aps_award_vote_round_search"/>
    </record>

    <record id="action_aps_award_vote_round_list_view" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_aps_award_vote_round_list"/>
        <field name="act_window_id" ref="action_aps_award_vote_round"/>
    </record>

    <record id="action_aps_award_vote_round_form_view" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_aps_award_vote_round_form"/>
        <field name="act_window_id" ref="action_aps_award_vote_round"/>
    </record>
</odoo>
