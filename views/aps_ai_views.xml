<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- AI Dashboard client action (registered in aps_sis JS assets) -->
    <record id="action_aps_ai_dashboard" model="ir.actions.client">
        <field name="name">AI Dashboard</field>
        <field name="tag">aps_ai_dashboard</field>
    </record>

    <!-- AI Run views (aps.ai.run stays in aps_sis — APEX-specific) -->
    <record id="view_aps_ai_run_list" model="ir.ui.view">
        <field name="name">aps.ai.run.list</field>
        <field name="model">aps.ai.run</field>
        <field name="arch" type="xml">
            <list default_order="create_date desc, id desc" create="false" edit="false">
                <field name="create_date" string="Date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'completed'"
                       decoration-danger="state == 'failed'"
                       decoration-info="state in ('queued', 'running')"/>
                <field name="request_origin" optional="hide"/>
                <field name="requested_by_id" optional="hide"/>
                <field name="submission_id" optional="show"/>
                <field name="resource_id" optional="show"/>
                <field name="ai_model_id" optional="show"/>
                <field name="prompt_tokens" optional="hide"/>
                <field name="completion_tokens" optional="hide"/>
                <field name="estimated_cost" optional="show" digits="[16,6]"/>
                <field name="duration_ms" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_aps_ai_run_form" model="ir.ui.view">
        <field name="name">aps.ai.run.form</field>
        <field name="model">aps.ai.run</field>
        <field name="arch" type="xml">
            <form create="false" edit="false">
                <sheet>
                    <group>
                        <group string="Run">
                            <field name="create_date"/>
                            <field name="state"/>
                            <field name="request_origin"/>
                            <field name="requested_by_id"/>
                            <field name="attempt_number"/>
                        </group>
                        <group string="Subject">
                            <field name="submission_id"/>
                            <field name="resource_id"/>
                            <field name="ai_model_id"/>
                            <field name="override_model_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Timing">
                            <field name="started_at"/>
                            <field name="finished_at"/>
                            <field name="duration_ms"/>
                        </group>
                        <group string="Costing">
                            <field name="prompt_tokens"/>
                            <field name="completion_tokens"/>
                            <field name="estimated_cost" digits="[16,6]"/>
                        </group>
                    </group>
                    <group string="Status">
                        <field name="status_message" nolabel="1"/>
                    </group>
                    <group string="Result" invisible="not result_message">
                        <field name="result_message" nolabel="1"/>
                    </group>
                    <group string="Error" invisible="not error_message">
                        <field name="error_message" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_aps_ai_runs" model="ir.actions.act_window">
        <field name="name">AI Runs</field>
        <field name="res_model">aps.ai.run</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- APEX AI menus (under APEX Settings, visible to APEX Managers) -->
    <menuitem id="menu_apex_ai_heading" name="AI" parent="menu_apex_settings" sequence="350" groups="aps_sis.group_aps_manager"/>
    <menuitem id="menu_apex_ai_dashboard" name="Dashboard" parent="menu_apex_ai_heading" action="action_aps_ai_dashboard" sequence="5" groups="aps_sis.group_aps_manager"/>
    <menuitem id="menu_apex_ai_providers" name="Providers" parent="menu_apex_ai_heading" action="aps_ai.action_aps_ai_providers" sequence="10" groups="aps_sis.group_aps_manager"/>
    <menuitem id="menu_apex_ai_models" name="Models" parent="menu_apex_ai_heading" action="aps_ai.action_aps_ai_models" sequence="20" groups="aps_sis.group_aps_manager"/>
    <menuitem id="menu_apex_ai_call_logs" name="Logs" parent="menu_apex_ai_heading" action="aps_ai.action_aps_ai_call_logs" sequence="30" groups="aps_sis.group_aps_manager"/>
    <menuitem id="menu_apex_ai_runs" name="Runs" parent="menu_apex_ai_heading" action="action_aps_ai_runs" sequence="35" groups="aps_sis.group_aps_manager"/>
</odoo>
