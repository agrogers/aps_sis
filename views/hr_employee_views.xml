<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hr_employee_form_access_token" model="ir.ui.view">
        <field name="name">hr.employee.form.access.token</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='hr_settings']" position="inside">
                <group string="Portal Access Token" groups="hr.group_hr_user">
                    <field name="access_token" readonly="1" password="True"/>
                    <button name="action_reset_access_token"
                            string="Reset Token"
                            type="object"
                            class="btn-secondary"
                            confirm="This will invalidate the existing access link. Continue?"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
