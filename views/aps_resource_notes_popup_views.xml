<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Popup form view to display resource notes -->
    <record id="view_aps_resource_notes_popup" model="ir.ui.view">
        <field name="name">aps.resource.notes.popup</field>
        <field name="model">aps.resources</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <form create="false" delete="false" edit="false">
                <sheet>
                    <field name="notes" nolabel="1" readonly="1"/>
                </sheet>
                <footer>
                    <button special="cancel" string="Close" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
