<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Popup form view to display resource notes -->
    <record id="view_aps_resource_notes_popup" model="ir.ui.view">
        <field name="name">aps.resource.notes.popup</field>
        <field name="model">aps.resources</field>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <form create="false" delete="false" edit="false">
                <sheet>
                    <field name="notes" nolabel="1" readonly="1"/>
                </sheet>
                <footer>
                    <button special="cancel" string="Close" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open notes popup -->
    <record id="action_aps_resource_notes_popup" model="ir.actions.act_window">
        <field name="name">Resource Notes</field>
        <field name="res_model">aps.resources</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="action_aps_resource_notes_popup_view" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_aps_resource_notes_popup"/>
        <field name="act_window_id" ref="action_aps_resource_notes_popup"/>
    </record>

</odoo>
