<?xml version="1.0" encoding="UTF-8"?>
<odoo>
<template id="awards_voting_dashboard" name="Voting Dashboard">
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Voting Dashboard</title>
    <link rel="stylesheet" href="/aps_sis/static/src/css/awards/voting.css"/>
</head>
<body class="av-body">

    <!-- Header -->
    <header class="av-header">
        <div class="av-header-inner">
            <div class="av-header-left">
                <img src="/aps_sis/static/img/award.svg" alt="Award" class="av-trophy"/>
                <div>
                    <div class="av-header-title">Voting Dashboard</div>
                    <div class="av-header-sub"><t t-esc="employee.name"/></div>
                </div>
            </div>
            <div class="av-header-right">
                <img src="/web/image/res.company/1/logo" alt="Logo" class="av-header-logo"/>
            </div>
        </div>
    </header>

    <!-- Stats Bar -->
    <section class="av-stats">
        <div class="av-stat-card">
            <div class="av-stat-num"><t t-esc="my_votes_count"/></div>
            <div class="av-stat-label">My votes<br/><span>last 12 months</span></div>
        </div>
        <div class="av-stat-card">
            <div class="av-stat-num"><t t-esc="avg_votes"/></div>
            <div class="av-stat-label">Average votes<br/><span>per teacher</span></div>
        </div>
        <div class="av-stat-card av-stat-open">
            <div class="av-stat-num"><t t-esc="open_votes_count"/></div>
            <div class="av-stat-label">Open<br/><span>votes</span></div>
        </div>
        <div class="av-stat-card av-stat-expired">
            <div class="av-stat-num"><t t-esc="expired_count"/></div>
            <div class="av-stat-label">Missed<br/><span>without voting</span></div>
        </div>
    </section>

    <!-- Open Votes -->
    <t t-if="voter_open_votes">
        <section class="av-section">
            <div class="av-section-header">
                <h2 class="av-section-title">Open for Voting</h2>
                <t t-if="len(open_vsets) >= 1">
                    <select id="av-vset-filter" class="av-vset-select" onchange="AwardsVoting.filterByVotingSet(this.value)">
                        <option value="">All</option>
                        <t t-foreach="open_vsets.items()" t-as="vset_entry">
                            <option t-att-value="vset_entry[0]"><t t-esc="vset_entry[1]"/></option>
                        </t>
                    </select>
                </t>
            </div>
            <div class="av-cards">
                <t t-foreach="voter_open_votes" t-as="vote">
                    <button class="av-cat-card"
                            t-att-data-vote-id="vote.id"
                            t-attf-data-category-id="#{vote.award_category_id.id or 0}"
                            t-att-data-category-name="vote.vote_round_id.name or vote.award_category_id.name"
                            t-att-data-short-description="vote.short_description or ''"
                            t-att-data-description="vote.description or ''"
                            t-att-data-token="token"
                            t-attf-data-category-img="#{'/awards/vote/' + token + '/model_image/vote/' + str(vote.id) if vote.image else ''}"
                            t-attf-data-vset-ids="#{' '.join(str(s.id) for s in vote.vote_round_id.voting_set_ids) if vote.vote_round_id else ''}"
                            t-attf-style="#{('--av-primary: ' + vote.vote_round_id.color + '; --av-accent: ' + vote.vote_round_id.color + '; border-color: ' + vote.vote_round_id.color + ';') if vote.vote_round_id and vote.vote_round_id.color else ''}"
                            onclick="AwardsVoting.openModal(this)">
                        <t t-set="vset_card" t-value="vote.vote_round_id.voting_set_ids[0] if (vote.vote_round_id and vote.vote_round_id.voting_set_ids) else False"/>
                        <t t-if="vset_card and vset_card.icon">
                            <img t-attf-src="/awards/vote/#{token}/model_image/voteset/#{vset_card.id}"
                                 class="av-cat-set-icon" alt=""/>
                        </t>
                        <div class="av-cat-top">
                        <div class="av-cat-img-wrap">
                            <t t-if="vote.image">
                                <img t-attf-src="/awards/vote/#{token}/model_image/vote/#{vote.id}"
                                     class="av-cat-img" alt=""/>
                            </t>
                            <t t-else="">
                                <div class="av-cat-img-placeholder">&#127885;</div>
                            </t>
                        </div>
                        <div class="av-cat-name"><t t-esc="vote.vote_round_id.name or vote.award_category_id.name"/></div>
                        <t t-if="vote.short_description">
                            <div class="av-cat-desc"><t t-esc="vote.short_description"/></div>
                        </t>
                        <t t-if="vote.due_date">
                            <div class="av-cat-meta">
                                <span class="av-cat-due">due <t t-esc="vote.due_date.strftime('%#d %b %Y')"/></span>
                            </div>
                        </t>
                        </div>
                        <div class="av-cat-badge">Vote Now &#8594;</div>
                    </button>
                </t>
            </div>
        </section>
    </t>

    <t t-if="not voter_open_votes">
        <section class="av-section av-empty">
            <div class="av-empty-icon">&#127881;</div>
            <div class="av-empty-text">No votes are currently open for you.</div>
        </section>
    </t>

    <!-- Voting Modal -->
    <div id="av-modal" class="av-modal-overlay" style="display:none"
         onclick="AwardsVoting.overlayClick(event)">
        <div class="av-modal">
            <button class="av-modal-close" onclick="AwardsVoting.closeModal()">&#10005;</button>

            <div class="av-modal-header">
                    <div class="av-modal-header-top">
                        <img id="av-modal-cat-img" class="av-modal-cat-img" src="" alt=""/>
                        <div class="av-modal-header-titles">
                            <div id="av-modal-cat-name" class="av-modal-cat-name"/>
                            <div id="av-modal-cat-short-desc" class="av-modal-cat-short-desc"/>
                        </div>
                    </div>
                    <div id="av-modal-cat-desc" class="av-modal-cat-desc"/>
                    <div class="av-modal-header-right">
                        <button id="av-submit-btn" class="av-submit-btn" style="display:none"
                                onclick="AwardsVoting.submitVote()">Submit Vote</button>
                        <div id="av-modal-selection-summary" class="av-modal-selection-summary"
                             style="display:none"/>
                        <div id="av-submit-error" class="av-submit-error" style="display:none"/>
                    </div>
                </div>
            <div class="av-filters-bar" id="av-filters-bar">
                <button class="av-filter-toggle" id="av-filter-toggle"
                        onclick="AwardsVoting.toggleFilters()" aria-label="Toggle filters">
                    &#9776; Filters
                </button>
                <input id="av-search" class="av-filter-input av-search-inline" type="text"
                       placeholder="Search by name..." oninput="AwardsVoting.filterSearch()"/>
            </div>
            <div class="av-filters" id="av-filters">
                <input id="av-search-desktop" class="av-filter-input" type="text"
                       placeholder="Search by name..." oninput="AwardsVoting.filterSearch()"/>
                <select id="av-filter-level" class="av-filter-select"
                        onchange="AwardsVoting.filterSearch()">
                    <option value="">All Year Levels</option>
                </select>
                <select id="av-filter-subject-cat" class="av-filter-select"
                        onchange="AwardsVoting.filterSearch()">
                    <option value="">All Subject Categories</option>
                </select>
            </div>

            <div class="av-table-wrap">
                <table class="av-table" id="av-candidate-table">
                    <thead>
                        <tr>
                            <th class="av-th-photo"/>
                            <th class="av-th-name av-sortable"
                                onclick="AwardsVoting.sortBy('name')">
                                Name <span class="av-sort-icon">&#8597;</span>
                            </th>
                            <th class="av-th-level av-sortable"
                                onclick="AwardsVoting.sortBy('level')">
                                Level <span class="av-sort-icon">&#8597;</span>
                            </th>
                            <th class="av-th-times av-sortable"
                                onclick="AwardsVoting.sortBy('times_awarded')">
                                Times Awarded <span class="av-sort-icon">&#8597;</span>
                            </th>
                            <th class="av-th-last av-sortable"
                                onclick="AwardsVoting.sortBy('last_awarded')">
                                Last Awarded <span class="av-sort-icon">&#8597;</span>
                            </th>
                            <th class="av-th-select">Select</th>
                        </tr>
                    </thead>
                    <tbody id="av-candidate-list">
                        <tr><td colspan="6" class="av-loading">Loading...</td></tr>
                    </tbody>
                </table>
            </div>

        </div>
    </div>

    <script src="/aps_sis/static/src/js/awards/voting.js"/>

    <!-- My Votes History -->
    <t t-if="my_vote_groups">
        <section class="av-section av-history-section">
            <h2 class="av-section-title">My Votes</h2>
            <div class="av-history-list">
                <t t-foreach="my_vote_groups" t-as="grp">
                    <t t-set="v" t-value="grp['rep']"/>
                    <t t-set="rnd" t-value="v.vote_round_id"/>
                    <t t-set="cat" t-value="v.award_category_id"/>
                    <t t-set="vset" t-value="rnd.voting_set_ids[0] if (rnd and rnd.voting_set_ids) else False"/>
                    <div t-attf-class="av-history-row av-history-state--#{grp['state']}"
                         t-attf-style="#{('--av-primary: ' + rnd.color + '; border-left-color: ' + rnd.color + ';') if (rnd and rnd.color) else ''}"
                         t-attf-data-vset-ids="#{' '.join(str(s.id) for s in rnd.voting_set_ids) if rnd else ''}">
                        <div class="av-history-icon">
                            <t t-if="rnd and rnd.image">
                                <img t-attf-src="/awards/vote/#{token}/model_image/round/#{rnd.id}"
                                     class="av-history-cat-img" alt=""/>
                            </t>
                            <t t-elif="cat and cat.image">
                                <img t-attf-src="/awards/vote/#{token}/model_image/category/#{cat.id}"
                                     class="av-history-cat-img" alt=""/>
                            </t>
                            <t t-else="">
                                <span class="av-history-cat-placeholder">&#127885;</span>
                            </t>
                            <t t-if="vset and vset.icon">
                                <img t-attf-src="/awards/vote/#{token}/model_image/voteset/#{vset.id}"
                                     class="av-history-set-icon" alt=""/>
                            </t>
                        </div>
                        <div class="av-history-info">
                            <div class="av-history-cat-name">
                                <t t-esc="(rnd and rnd.name) or (cat and cat.name) or (rnd and rnd.short_description) or  ''"/>
                            </div>
                            <t t-if="rnd and rnd.short_description">
                                <div class="av-history-desc"><t t-esc="rnd.short_description"/></div>
                            </t>
                            <!-- List every recipient in the group -->
                            <t t-foreach="grp['votes']" t-as="gv">
                                <t t-if="gv.recipient_partner_id">
                                    <div class="av-history-recipient">
                                        <img t-attf-src="/web/image/res.partner/#{gv.recipient_partner_id.id}/avatar_128"
                                             class="av-history-recipient-avatar" alt=""/>
                                        <span class="av-history-recipient-name"><t t-esc="gv.recipient_partner_id.name"/></span>
                                        <t t-if="gv.award_sub_category_id">
                                            <span class="av-history-subcat"> — <t t-esc="gv.award_sub_category_id.name"/></span>
                                        </t>
                                        <t t-if="gv.comment">
                                            <span class="av-history-comment">"<t t-esc="gv.comment"/>"</span>
                                        </t>
                                    </div>
                                </t>
                                <t t-elif="gv.comment">
                                    <div class="av-history-recipient">
                                        <span class="av-history-comment">"<t t-esc="gv.comment"/>"</span>
                                    </div>
                                </t>
                            </t>
                        </div>
                        <div class="av-history-right">
                            <div class="av-history-date">
                                <t t-if="v.submitted_date">
                                    <t t-esc="v.submitted_date.strftime('%#d %b %Y')"/>
                                </t>
                                <!-- <t t-if="v.open_date">
                                    <span class="av-history-open">Open <t t-esc="v.open_date.strftime('%#d %b')"/></span>
                                </t> -->
                                <t t-if="grp['has_due'] and v.due_date">
                                    <span class="av-history-due">Due <t t-esc="v.due_date.strftime('%#d %b')"/></span>
                                </t>
                            </div>
                            <div class="av-history-badges">
                                <div t-attf-class="av-history-state-badge av-state--#{grp['state']}">
                                    <t t-esc="dict(v._fields['state'].selection).get(grp['state'], grp['state'])"/>
                                </div>
                                <t t-if="v.submitted_date and v.due_date and v.submitted_date > v.due_date">
                                    <span class="av-history-late-badge">Late</span>
                                </t>
                            </div>
                            <t t-if="grp['state'] == 'submitted'">
                                <button class="av-history-delete-btn"
                                        t-att-data-vote-ids="','.join(str(gv.id) for gv in grp['votes'])"
                                        t-att-data-token="token"
                                        t-att-data-has-due="'1' if grp['has_due'] else '0'"
                                        onclick="AwardsVoting.deleteVote(this)">
                                    <t t-if="grp['has_due']">&#8617; Undo</t>
                                    <t t-else="">&#10005; Delete</t>
                                </button>
                            </t>
                        </div>
                    </div>
                </t>
            </div>
        </section>
    </t>

</body>
</html>
</template>
</odoo>
