<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- APS Tasks list & Form Views -->
    <record id="view_aps_tasks_list" model="ir.ui.view">
        <field name="name">aps.tasks.list</field>
        <field name="model">aps.tasks</field>
        <field name="arch" type="xml">
            <list editable="top">
                <field name="name"/>
                <field name="resource_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <!-- APS Tasks Kanban View -->
    <record id="view_aps_tasks_kanban" model="ir.ui.view">
        <field name="name">aps.tasks.kanban</field>
        <field name="model">aps.tasks</field>
        <field name="arch" type="xml">
            <kanban default_group_by="resource_ids">
                <templates>
                    <t t-name="kanban-box">
                        <div class="o_kanban_record">
                            <div class="o_kanban_primary">
                                <strong><field name="name"/></strong>
                            </div>
                            <div class="o_kanban_secondary">
                                <span>Resources:</span>
                                <field name="resource_ids" widget="many2many_tags"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_aps_tasks_form" model="ir.ui.view">
        <field name="name">aps.tasks.form</field>
        <field name="model">aps.tasks</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="resource_ids" widget="many2many_tags"/>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_aps_tasks_search" model="ir.ui.view">
        <field name="name">aps.tasks.search</field>
        <field name="model">aps.tasks</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter name="has_resources" string="Has Resources" domain="[('resource_ids','!=',False)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_resource" string="Resource" context="{'group_by':'resource_ids'}"/>
                    <filter name="group_by_type" string="Resource Type" context="{'group_by':'resource_type_ids'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_aps_tasks" model="ir.actions.act_window">
        <field name="name">Tasks</field>
        <field name="res_model">aps.tasks</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="view_id" ref="view_aps_tasks_kanban"/>
    </record>

    <!-- Menu under APS SIS -->
    <menuitem id="menu_aps_tasks" name="Tasks" parent="menu_aps_root" action="action_aps_tasks" sequence="30"/>
</odoo>
