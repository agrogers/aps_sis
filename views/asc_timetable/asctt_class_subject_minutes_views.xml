<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Pivot view -->
    <record id="asctt_class_subject_minutes_view_pivot" model="ir.ui.view">
        <field name="name">asctt.class.subject.minutes.pivot</field>
        <field name="model">asctt.class.subject.minutes</field>
        <field name="arch" type="xml">
            <pivot string="Minutes per Class &amp; Subject" disable_linking="true">
                <field name="class_name" type="row"/>
                <field name="subject_name" type="row"/>
                <field name="total_weighted_minutes" type="measure"/>
                <field name="period_slots_per_week" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- List view -->
    <record id="asctt_class_subject_minutes_view_list" model="ir.ui.view">
        <field name="name">asctt.class.subject.minutes.list</field>
        <field name="model">asctt.class.subject.minutes</field>
        <field name="arch" type="xml">
            <list string="Minutes per Class &amp; Subject" create="false" edit="false" delete="false">
                <field name="class_name"/>
                <field name="aps_class_id" optional="show"/>
                <field name="subject_name"/>
                <field name="total_weighted_minutes" string="Minutes/Week"/>
                <field name="period_slots_per_week" string="Periods/Week"/>
            </list>
        </field>
    </record>

    <!-- Search view -->
    <record id="asctt_class_subject_minutes_view_search" model="ir.ui.view">
        <field name="name">asctt.class.subject.minutes.search</field>
        <field name="model">asctt.class.subject.minutes</field>
        <field name="arch" type="xml">
            <search string="Minutes per Class &amp; Subject">
                <field name="class_name"/>
                <field name="aps_class_id"/>
                <field name="subject_name"/>
                <group expand="0" string="Group By">
                    <filter name="group_class" string="Class" context="{'group_by': 'class_name'}"/>
                    <filter name="group_subject" string="Subject" context="{'group_by': 'subject_name'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="asctt_class_subject_minutes_action" model="ir.actions.act_window">
        <field name="name">Minutes by Class &amp; Subject</field>
        <field name="res_model">asctt.class.subject.minutes</field>
        <field name="view_mode">pivot,list</field>
    </record>

    <record id="asctt_class_subject_minutes_action_view_pivot" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="asctt_class_subject_minutes_view_pivot"/>
        <field name="act_window_id" ref="asctt_class_subject_minutes_action"/>
    </record>

    <record id="asctt_class_subject_minutes_action_view_list" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="asctt_class_subject_minutes_view_list"/>
        <field name="act_window_id" ref="asctt_class_subject_minutes_action"/>
    </record>

</odoo>
