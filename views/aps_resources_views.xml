<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- APS Resources list & Form Views -->
    <record id="view_aps_resources_list" model="ir.ui.view">
        <field name="name">aps.resources.list</field>
        <field name="model">aps.resources</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="type_icon" string="Icon" widget="image" options="{'size': [24, 24]}" optional="hide"/>
                <field name="subject_icons" string="Subject Icons" widget="image" options="{'size': [24, 24]}" optional="hide"/>
                <field name="thumbnail" widget="image" options="{'size': [50, 50]}" optional="hide"/>
                <field name="name" optional="hide"/>
                <field name="display_name" string="Display Name" optional="show"/>
                <field name="type_id" optional="hide"/>
                <field name="category" optional="hide"/>
                <field name="marks" optional="hide"/>
                <field name="points_scale" optional="hide"/>
                <field name="subjects" widget="many2many_tags" options="{'no_create': True}" optional="hide"/>
                <field name="parent_ids" optional="hide"/>
                <field name="child_count" string="Children" optional="hide"/>
                <field name="description" optional="hide"/>
                <field name="supporting_resources_buttons" widget="resource_links" optional="show"/>
                <field name="url" widget="url_icon"  options="{'html': true}" optional="hide"/>
                <field name="has_question" optional="hide"/>
                <field name="has_answer" optional="hide"/>
                <field name="has_child_resources" optional="hide"/>
                <field name="has_supporting_resources" optional="hide"/>
                <field name="create_date" optional="hide"/>
                <field name="write_date" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Hierarchy view: now a flat list since multiple parents don't form a tree -->
    <!-- used for searching for resources -->
    <record id="view_aps_resources_hierarchy" model="ir.ui.view">
        <field name="name">aps.resources.hierarchy</field>
        <field name="model">aps.resources</field>
        <field name="arch" type="xml">
                <list default_order="sequence,name">
                    <field name="sequence" widget="handle"/>
                    <field name="type_icon" string="Icon" widget="image" options="{'size': [24, 24]}" optional="hide"/>
                    <field name="display_name" optional="show"/>
                    <field name="name" optional="hide"/>
                    <field name="type_id" optional="hide"/>
                    <field name="category" optional="hide"/>
                    <field name="marks" optional="hide"/>
                    <field name="points_scale" optional="hide"/>
                    <field name="subjects" widget="many2many_tags" options="{'no_create': True}" optional="hide"/>
                    <field name="child_count" string="Children" optional="hide"/>
                    <field name="description" optional="hide"/>
                    <field name="url" widget="url_icon"  options="{'html': true}"/>
                    <field name="has_question" optional="hide"/>
                    <field name="has_answer" optional="hide"/>
                    <field name="has_default_answer" optional="hide"/>
                    <field name="has_child_resources" optional="hide"/>
                    <field name="has_supporting_resources" optional="hide"/>
                    <field name="create_date" optional="hide"/>
                    <field name="write_date" optional="hide"/>
                </list>
        </field>
    </record>

    <!-- Resources Form -->
    <record id="view_aps_resources_form" model="ir.ui.view">
        <field name="name">aps.resources.form</field>
        <field name="model">aps.resources</field>
        <field name="arch" type="xml">
            <form
                context="{
                    'tree_view_ref': 'view_aps_resources_form_brief',
                    'form_view_ref': 'view_aps_resources_form_brief'}">
                <header>
                    <button name="action_assign_students" string="Assign Students" type="object" class="btn-primary" groups="aps_sis.group_aps_teacher"/>
                </header>
                <sheet>
                    <div class="aps_ribbon" invisible="not type_id">
                        <field name="type_icon" widget="image" options="{'size': [40, 40]}" class="me-2" nolabel="1"/>
                        <field name="display_name" style="font-size: 1.5em; font-weight: 600;"/>
                    </div>
                    <notebook>
                        <page string="Basic Information">
                            <group>
                                <field name="name" />
                                <field name="parent_ids" widget="clickable_many2many_tags" options="{'no_create': True}"/>
                                <field name="has_multiple_parents" invisible="1"/>
                                <div class="o_row" invisible="not has_multiple_parents" style="margin-left: 15px;">
                                    <label for="primary_parent_id" string="Display Parent:" style="font-size: 0.8em !important;"/>
                                    <field name="primary_parent_id" options="{'no_create': True, 'no_open': True}" style="font-size: 0.9em;" nolabel="1"/>
                                </div>
                            </group>
                            <field name="thumbnail" widget="image" class="oe_avatar" options="{'size': [128, 128]}"/>
                            <group>
                                <group string="Details">
                                    <label for="type_id"/>
                                    <div class="d-flex align-items-center">
                                        <field name="type_icon" widget="image" options="{'size': [24, 24]}" class="me-2 flex-shrink-0" style="width: 24px;" nolabel="1"/>
                                        <field name="type_id" nolabel="1" class="flex-grow-1"/>
                                    </div>
                                    <field name="category"/>
                                    <field name="marks" widget="float_sentinel"/>
                                    <field name="subjects" widget="many2many_tags" options="{'no_create': True}"/>
                                    <field name="tag_ids" widget="many2many_tags" options="{'no_create': False}"/>
                                    <field name="url" widget="url_icon"/>
                                     <field name="description"/>
                                    
                                </group>
                                <group string="Technical">
                                    <field name="has_question"/>
                                    <field name="has_answer"/>
                                    <field name="has_default_answer" invisible="has_answer=='no'"/>
                                    <field name="has_child_resources"/>
                                    <field name="has_supporting_resources"/>
                                    <field name="points_scale"/>
                                    <field name="allow_subject_editing" widget="boolean_toggle"  />
                                    <field name="supporting_resources_buttons" widget="resource_links" options="{'size': '32px'}" />
                                    <field name="child_count"/>
                            </group>
                            </group>
                        </page>
                        <page string="Question" invisible="has_question=='no'">
                            <group invisible="not has_question=='use_parent'" >
                                <div class="alert alert-info" role="alert">Using <b>Parent Question</b> (read only).</div>
                                <field name="parent_question" nolabel="1" placeholder="Parent question will appear here."/>
                            </group>
                            <field name="question"  invisible="not has_question=='yes'" nolabel="1" placeholder="Enter the question for this resource."/>
                        </page>
                        <page string="Default Answer" invisible="has_default_answer==False">
                            <field name="default_answer"  invisible="has_default_answer==False" nolabel="1" placeholder="Enter the the default answer for this resource. This is helpful when students are expected to fill in a template."/>
                        </page>
                        <page string="Model Answer" invisible="has_answer=='no'">
                            <group invisible="not has_answer=='use_parent'" >
                                <div class="alert alert-info" role="alert">Using <b>Parent Answer</b> (read only).</div>
                                <field name="parent_answer" nolabel="1" placeholder="Parent answer will appear here."/>
                            </group>
                            <field name="answer" invisible="not has_answer=='yes'" placeholder="Enter the answer or solution for this resource."/>
                        </page>
                        <page string="Linked Resources" invisible="not has_child_resources=='yes'">
                            <group>
                                <div><i>Linked resources contribute to the parent total marks. To add resources such as videos or related quizzes that do not contribute to the total marks, use the 'Supporting Resources' tab.</i></div>
                            </group>
                            <field name="child_ids" widget="many2many" context="{'default_parent_ids': [(6, 0, [id])], 'default_primary_parent_id': id, 'default_subjects': subjects, 'current_parent_id': id}">
                                <list default_order="sequence,name" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="type_icon" widget="image" options="{'size': [20, 20]}" class="me-1" nolabel="1" optional="hide"/>
                                    <field name="name" optional="show"/>
                                    <field name="display_name" optional="hide"/>
                                    <field name="type_id" optional="show"/>
                                    <field name="category" optional="hide"/>
                                    <field name="marks" optional="hide"/>
                                    <field name="subjects" widget="many2many_tags" options="{'no_create': True}" optional="hide"/>
                                    <field name="description" optional="show"/>
                                    <field name="has_question" optional="hide"/>
                                    <field name="has_answer" optional="hide"/>
                                    <field name="child_count" optional="hide"/>
                                    <field name="child_count" optional="hide"/>
                                    <field name="url" widget="url_icon" options='{"html": true}' optional="hide"/>
                                    <field name="allow_subject_editing" widget="boolean_toggle" optional="hide"/>
                                    <field name="points_scale" optional="hide"/>
                                    <field name="supporting_resources_buttons" widget="resource_links" optional="hide"/>
                                    <!-- Parent-child custom name pill: shows custom name or Create... -->
                                    <field name="parent_custom_name_data" string="Custom Name" widget="parent_child_name_pill" context="{'current_parent_id': parent.id}"/>
                                    <!-- Quick access to full custom name list -->
                                    <button name="get_formview_action" type="object" string="Open..." title="Open Submission" class="btn-secondary btn-sm"/>
                                </list>
                            </field>
                        </page>
                        <page string="Supporting Resources" invisible="not has_supporting_resources=='yes'">
                            <group>
                                <div><i>Supporting resources usually include videos or related quizzes that do not contribute to the total marks.</i></div>
                            </group>
                            <field name="supporting_resource_ids" widget="many2many" context="{'default_subjects': subjects}">
                                <list default_order="sequence,name">
                                    <field name="sequence" widget="handle"/>
                                    <field name="type_icon" widget="image" options="{'size': [20, 20]}" class="me-1" nolabel="1" optional="hide"/>
                                    <field name="name" optional="show"/>
                                    <field name="display_name" optional="hide"/>
                                    <field name="type_id" optional="show"/>
                                    <field name="category" optional="hide"/>
                                    <field name="subjects" widget="many2many_tags" options="{'no_create': True}" optional="hide"/>
                                    <field name="description" optional="show"/>
                                    <field name="child_count" optional="hide"/>
                                    <field name="url" widget="url_icon" options='{"html": true}' optional="show"/>
                                    <button name="get_formview_action" type="object" string="Open..." title="Open Submission" class="btn-secondary btn-sm"/>
                                </list>
                            </field>
                        </page>
                        <page string="Students Assigned">
                            <field name="task_ids" mode="list" context="{'form_view_ref': 'aps_sis.view_aps_resource_task_form'}">
                                <list edit="false" create="true" delete="true" default_order="student_id">
                                    <field name="student_id" readonly="id" optional="show"/>
                                    <field name="state" widget="badge" 
                                        decoration-muted="state in ['created','assigned', 'reassigned']" 
                                        decoration-info="state in ['submitted']" 
                                        decoration-warning="state in ['due']" 
                                        decoration-danger="state in ['overdue', 'late']" 
                                        decoration-success="state == 'complete'" 
                                        optional="show"/>
                                    <field name="date_assigned" widget="datetime" options="{'format': 'D/MMM/YY HH:mm'}" optional="hide"/>
                                    <field name="date_due" string="Next Due Date" widget="datetime" options="{'format': 'D/MMM/YY HH:mm'}" optional="show"/>
                                    <field name="submission_count" optional="show"/>
                                    <field name="last_result" widget="percentpie_ranged" optional="show"/>
                                    <field name="avg_result" widget="percentpie_ranged" optional="hide"/>
                                    <field name="weighted_result" widget="percentpie_ranged" optional="hide"/>
                                    <field name="best_result" widget="percentpie_ranged" optional="hide"/>
                                    <field name="latest_submission_text" widget="recent_submissions" options='{"html": true}' optional="show"/>
                                    <button name="get_formview_action" type="object" string="Open..." title="Open Submission" class="btn-secondary btn-sm"/>                                  
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter groups="aps_sis.group_aps_teacher"/>
            </form>
        </field>
    </record>

    <!-- Popup form for adding child resources -->
    <record id="view_aps_resources_form_popup_detailed" model="ir.ui.view">
        <field name="name">aps.resources.tree.popup</field>
        <field name="model">aps.resources</field>
        <field name="arch" type="xml">
            <form>
                <field name="name"/>
                <field name="type_id"/>
                <field name="category"/>
                <field name="subjects"/>
                <field name="url" widget="url" optional="hide"/>
            </form>
        </field>
    </record>

    <!-- Popup form for adding child resources -->
    <record id="view_aps_resources_form_brief" model="ir.ui.view">
        <field name="name">aps.resources.form.brief</field>
        <field name="model">aps.resources</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="name"/>
                    <field name="display_name" optional="show" />
                    <field name="type_icon" widget="image" options="{'size': [24, 24]}" string=""/>
                    <field name="type_id" optional="hide"/>
                    <field name="category"/>
                    <field name="subjects"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_aps_resources_search" model="ir.ui.view">
        <field name="name">aps.resources.search</field>
        <field name="model">aps.resources</field>
        <field name="arch" type="xml">
            <search>
                <searchpanel>
                    <field name="type_id" icon="fa-tag" enable_counters="1" select="multi"/>
                    <field name="subjects" icon="fa-book" enable_counters="1" select="multi"/>
                    <field name="category" icon="fa-star" enable_counters="1"/>
                </searchpanel>
                <field name="name" string="All" filter_domain="['|','|','|','|',('display_name','ilike',self),('name','ilike',self),('url','ilike',self),('description','ilike',self),('category','ilike',self)]"/>
                <field name="display_name"/>
                <field name="name"/>
                <field name="url"/>
                <field name="description"/>
                <field name="category"/>
                <field name="marks"/>
                <field name="subjects"/>
                <filter name="has_parent" string="Has Parent" domain="[('parent_ids','!=',False)]"/>
                <filter name="no_parent" string="Root Resources" domain="[('parent_ids','=',False)]"/>
                <filter name="has_url" string="Has URL" domain="[('url','!=',False)]"/>
                <filter name="has_marks" string="Has Marks" domain="[('marks','>',0)]"/>
                <separator/>
                <filter name="has_question_yes" string="Has Question" domain="[('has_question','=','yes')]"/>
                <filter name="has_question_use_parent" string="Uses Parent Question" domain="[('has_question','=','use_parent')]"/>
                <filter name="has_answer_yes" string="Has Answer" domain="[('has_answer','=','yes')]"/>
                <filter name="has_answer_use_parent" string="Uses Parent Answer" domain="[('has_answer','=','use_parent')]"/>
                <filter name="has_child_resources" string="Has Linked Resources" domain="[('has_child_resources','=','yes')]"/>
                <filter name="has_supporting_resources" string="Has Supporting Resources" domain="[('has_supporting_resources','=','yes')]"/>
                <separator/>
                <filter name="category_mandatory" string="Mandatory" domain="[('category','=','mandatory')]"/>
                <filter name="category_optional" string="Optional" domain="[('category','=','optional')]"/>
                <filter name="category_information" string="Information" domain="[('category','=','information')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_type" string="Type" context="{'group_by':'type_id'}"/>
                    <filter name="group_by_category" string="Category" context="{'group_by':'category'}"/>
                    <filter name="group_by_subjects" string="Subjects" context="{'group_by':'subjects'}"/>
                    <filter name="group_by_has_question" string="Has Question" context="{'group_by':'has_question'}"/>
                    <filter name="group_by_has_answer" string="Has Answer" context="{'group_by':'has_answer'}"/>
                    <filter name="group_by_has_child_resources" string="Has Linked Resources" context="{'group_by':'has_child_resources'}"/>
                    <filter name="group_by_has_supporting_resources" string="Has Supporting Resources" context="{'group_by':'has_supporting_resources'}"/>
                    

                </group>
            </search>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_aps_resources" model="ir.actions.act_window">
        <field name="name">Resources</field>
        <field name="res_model">aps.resources</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_aps_resources_list"/>
        <field name="search_view_id" ref="view_aps_resources_search"/>
        <field name="context">{'default_order': 'name'}</field>
    </record>


    <record id="action_aps_resources_hierarchy" model="ir.actions.act_window">
        <field name="name">Resources (Hierarchy)</field>
        <field name="res_model">aps.resources</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_aps_resources_hierarchy"/>
        <field name="search_view_id" ref="view_aps_resources_search"/>
        <field name="domain">[('parent_ids','=',False)]</field>
        <field name="context">{'default_order': 'name'}</field>
    </record>

    <!-- Server action to force update all display names -->
    <record id="action_force_update_aps_resource_display_names" model="ir.actions.server">
        <field name="name">Update Resource Names</field>
        <field name="model_id" ref="model_aps_resources"/>
        <field name="binding_model_id" ref="model_aps_resources"/>
        <field name="binding_type">action</field>
        <field name="state">code</field>
        <field name="code">env['aps.resources'].action_force_update_display_names()
        </field>
    </record>
</odoo>
