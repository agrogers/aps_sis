<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- APS Resources list & Form Views -->
    <record id="view_aps_resources_list" model="ir.ui.view">
        <field name="name">aps.resources.list</field>
        <field name="model">aps.resources</field>
        <field name="arch" type="xml">
            <list default_order="sequence,name">
                <field name="sequence" widget="handle"/>
                <field name="thumbnail" widget="image" options="{'size': [50, 50]}" optional="hide"/>
                <field name="name" optional="hide"/>
                <field name="display_name" string="Display Name" optional="show"/>
                <field name="type_icon" string="Icon" widget="image" options="{'size': [24, 24]}" optional="hide"/>
                <field name="type_id" optional="hide"/>
                <field name="category" optional="hide"/>
                <field name="marks" optional="hide"/>
                <field name="subjects" widget="many2many_tags" options="{'no_create': True}" optional="hide"/>
                <field name="parent_ids" optional="hide"/>
                <field name="child_count" string="Children" optional="hide"/>
                <field name="description" optional="hide"/>
                <field name="url" widget="url_icon"  options="{'html': true}" optional="hide"/>
                <field name="create_date" optional="hide"/>
                <field name="write_date" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Hierarchy view: now a flat list since multiple parents don't form a tree -->
    <!-- used for searching for resources -->
    <record id="view_aps_resources_hierarchy" model="ir.ui.view">
        <field name="name">aps.resources.hierarchy</field>
        <field name="model">aps.resources</field>
        <field name="arch" type="xml">
            <list default_order="sequence,name">
                <field name="sequence" widget="handle"/>
                <field name="display_name" optional="show"/>
                <field name="name" optional="hide"/>
                <field name="type_id" optional="hide"/>
                <field name="category" optional="hide"/>
                <field name="marks" optional="hide"/>
                <field name="subjects" widget="many2many_tags" options="{'no_create': True}" optional="hide"/>
                <field name="child_count" string="Children" optional="hide"/>
                <field name="description" optional="hide"/>
                <field name="url" widget="url_icon"  options="{'html': true}"/>
                <field name="create_date" optional="hide"/>
                <field name="write_date" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_aps_resources_form" model="ir.ui.view">
        <field name="name">aps.resources.form</field>
        <field name="model">aps.resources</field>
        <field name="arch" type="xml">
            <form
                context="{
                    'tree_view_ref': 'view_aps_resources_form_brief',
                    'form_view_ref': 'view_aps_resources_form_brief'}">
                <header>
                    <button name="action_assign_students" string="Assign Students" type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="aps_ribbon" invisible="not type_id">
                        <field name="type_icon" widget="image" options="{'size': [20, 20]}" class="me-1" nolabel="1"/>
                        <field name="display_name"/>
                    </div>
                    <notebook>
                        <page string="Basic Information">
                            <field name="thumbnail" widget="image" class="oe_avatar" options="{'size': [128, 128]}"/>
                            <group>
                                <group string="Details">
                                    <field name="name"/>
                                    <label for="type_id"/>
                                    <div class="d-flex align-items-center">
                                        <field name="type_icon" widget="image" options="{'size': [24, 24]}" class="me-2 flex-shrink-0" style="width: 24px;" nolabel="1"/>
                                        <field name="type_id" nolabel="1" class="flex-grow-1"/>
                                    </div>
                                    <field name="category"/>
                                    <field name="marks" widget="float_sentinel"/>
                                    <field name="subjects" widget="many2many_tags" options="{'no_create': True}"/>
                                </group>
                                <group string="Technical">
                                    <field name="url" widget="url_icon"/>
                                    <field name="description" nolabel="0"/>
                                    <field name="parent_ids" widget="many2many_tags" options="{'no_create': True}"/>
                                    <field name="has_multiple_parents" invisible="1"/>
                                    <div class="o_row" invisible="not has_multiple_parents" style="margin-left: 15px;">
                                        <label for="primary_parent_id" string="Display Parent:" class="text-muted" style="font-size: 0.8em !important;"/>
                                        <field name="primary_parent_id" options="{'no_create': True, 'no_open': True}" class="text-muted" style="font-size: 0.9em;" nolabel="1"/>
                                    </div>
                                    <field name="child_count"/>
                            </group>
                            </group>
                        </page>
                        <page string="Question">
                            <field name="question" nolabel="1" placeholder="Enter the question for this resource."/>
                        </page>
                        <page string="Model Answer">
                            <field name="answer" nolabel="1" placeholder="Enter the answer or solution for this resource."/>
                        </page>
                        <page string="Child Resources">
                            <field name="child_ids" widget="many2many" context="{'default_parent_ids': [(6, 0, [id])], 'default_primary_parent_id': id, 'default_subjects': subjects}">
                                <list default_order="sequence,name">
                                    <field name="sequence" widget="handle"/>
                                    <field name="type_icon" widget="image" options="{'size': [20, 20]}" class="me-1" nolabel="1" optional="hide"/>
                                    <field name="name" optional="show"/>
                                    <field name="display_name" optional="hide"/>
                                    <field name="type_id" optional="show"/>
                                    <field name="category" optional="hide"/>
                                    <field name="subjects" widget="many2many_tags" options="{'no_create': True}" optional="hide"/>
                                    <field name="description" optional="show"/>
                                    <field name="child_count" optional="hide"/>
                                    <field name="url" widget="url_icon" options='{"html": true}' optional="show"/>
                                </list>
                            </field>
                        </page>
                        <page string="Students Assigned">
                            <field name="task_ids" mode="list" context="{'form_view_ref': 'aps_sis.view_aps_resource_task_form'}">
                                <list edit="false" create="true" delete="true" default_order="student_id">
                                    <field name="student_id" readonly="id" optional="show"/>
                                    <field name="state" widget="badge" 
                                        decoration-muted="state in ['created','assigned', 'reassigned']" 
                                        decoration-info="state in ['submitted']" 
                                        decoration-warning="state in ['due']" 
                                        decoration-danger="state in ['overdue', 'late']" 
                                        decoration-success="state == 'complete'" 
                                        optional="show"/>
                                    <field name="date_assigned" widget="datetime" options="{'format': 'D/MMM/YY HH:mm'}" optional="hide"/>
                                    <field name="date_due" string="Next Due Date" widget="datetime" options="{'format': 'D/MMM/YY HH:mm'}" optional="show"/>
                                    <field name="submission_count" optional="show"/>
                                    <field name="last_result" widget="float_sentinel" optional="show"/>
                                    <field name="avg_result" widget="float_sentinel" optional="hide"/>
                                    <field name="weighted_result" widget="float_sentinel" optional="hide"/>
                                    <field name="max_result" widget="float_sentinel" optional="hide"/>
                                    <field name="latest_submission_text" widget="recent_submissions" options='{"html": true}' optional="show"/>

                                    <!-- This button opens the full form view in the main area -->
                                    <button string="Open" 
                                            type="object" 
                                            name="get_formview_action" 
                                            icon="fa-external-link" 
                                            title="Open in full view"/>                                    
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter groups="aps_sis.group_aps_teacher"/>
            </form>
        </field>
    </record>

    <!-- Popup form for adding child resources -->
    <record id="view_aps_resources_form_popup_detailed" model="ir.ui.view">
        <field name="name">aps.resources.tree.popup</field>
        <field name="model">aps.resources</field>
        <field name="arch" type="xml">
            <form>
                <field name="name"/>
                <field name="type_id"/>
                <field name="category"/>
                <field name="subjects"/>
                <field name="url" widget="url" optional="hide"/>
            </form>
        </field>
    </record>

    <!-- Popup form for adding child resources -->
    <record id="view_aps_resources_form_brief" model="ir.ui.view">
        <field name="name">aps.resources.form.brief</field>
        <field name="model">aps.resources</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="name"/>
                    <field name="display_name" optional="show" />
                    <field name="type_icon" widget="image" options="{'size': [24, 24]}" string=""/>
                    <field name="type_id" optional="hide"/>
                    <field name="category"/>
                    <field name="subjects"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_aps_resources_search" model="ir.ui.view">
        <field name="name">aps.resources.search</field>
        <field name="model">aps.resources</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="All" filter_domain="['|','|','|','|',('display_name','ilike',self),('name','ilike',self),('url','ilike',self),('description','ilike',self),('category','ilike',self)]"/>
                <field name="display_name"/>
                <field name="name"/>
                <field name="url"/>
                <field name="description"/>
                <field name="category"/>
                <field name="marks"/>
                <field name="subjects"/>
                <filter name="has_parent" string="Has Parent" domain="[('parent_ids','!=',False)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_type" string="Type" context="{'group_by':'type_id'}"/>
                    <filter name="group_by_category" string="Category" context="{'group_by':'category'}"/>
                    <filter name="group_by_subjects" string="Subjects" context="{'group_by':'subjects'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_aps_resources" model="ir.actions.act_window">
        <field name="name">Resources</field>
        <field name="res_model">aps.resources</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_aps_resources_list"/>
        <field name="search_view_id" ref="view_aps_resources_search"/>
        <field name="context">{'default_order': 'name'}</field>
    </record>

    <record id="action_aps_resources_hierarchy" model="ir.actions.act_window">
        <field name="name">Resources (Hierarchy)</field>
        <field name="res_model">aps.resources</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_aps_resources_hierarchy"/>
        <field name="search_view_id" ref="view_aps_resources_search"/>
        <field name="domain">[('parent_ids','=',False)]</field>
        <field name="context">{'default_order': 'name'}</field>
    </record>
</odoo>
