<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Search view for student submissions -->
    <record id="view_aps_resource_submission_search_for_students" model="ir.ui.view">
        <field name="name">aps.resource.submission.search.for.students</field>
        <field name="model">aps.resource.submission</field>      
        <field name="arch" type="xml">
            <search string="Search Submissions">
                <searchpanel>
                    <field name="state" string="State" icon="fa-clock" enable_counters="1" select="multi"/>
                    <field name="due_status" string="Due Status" icon="fa-clock" enable_counters="1" select="multi"/>
                    <field name="subjects" string="Subjects" icon="fa-book" enable_counters="1" select="multi"/>                    
                    <field name="student_id" string="Student" icon="fa-user" enable_counters="1" select="multi"/>
                </searchpanel>
                <field name="display_name" string="Submission"/>
                <field name="resource_id" string="Resource"/>
                <field name="subjects"/>
                <field name="state"/>
                <field name="due_status"/>
                <field name="submission_label"/>
                <field name="assigned_by"/>
                <field name="date_assigned"/>
                <field name="date_due"/>
                <field name="date_submitted"/>
                <field name="date_completed"/>
                
                <filter string="Due Today" name="due_today" domain="[('date_due', '&gt;=', time.strftime('%Y-%m-%d')), ('date_due', '&lt;=', (datetime.datetime.now() + datetime.timedelta(days=1)).to_utc().strftime('%Y-%m-%d'))]"/>
                <filter string="Due Tomorrow" name="due_tomorrow" domain="[('date_due', '=', (datetime.datetime.now() + datetime.timedelta(days=1)).to_utc().strftime('%Y-%m-%d'))]"/>
                <filter string="Due in Next 7 Days" name="due_next_7_days" domain="[('date_due', '&gt;=', time.strftime('%Y-%m-%d')), ('date_due', '&lt;=', (datetime.datetime.now() + datetime.timedelta(days=7)).to_utc().strftime('%Y-%m-%d'))]"/>
                <filter string="Overdue" name="overdue" domain="[('state', '=', 'assigned'), ('date_due', '&lt;', time.strftime('%Y-%m-%d %H:%M:%S'))]"/>
                <separator/>
                <filter string="Has Answer" name="has_answer" domain="[('has_answer', '=', True)]"/>
                <filter string="Has Feedback" name="has_feedback" domain="[('has_feedback', '=', True)]"/>
                <filter string="Review Requested" name="review_requested" domain="[('review_requested_by', '!=', False)]"/>
                <filter string="Review not Requested" name="review_requested" domain="[('review_requested_by', '=', False)]"/>
                <separator/>
                <filter string="Active Submissions" name="submission_active" domain="[('submission_active', '=', True)]"/>
                <filter string="Assigned" name="assigned" domain="[('state', '=', 'assigned')]"/>
                <filter string="Submitted" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Finalised" name="completed" domain="[('state', '=', 'complete')]"/>
                <filter string="Late" name="late" domain="[('due_status', '=', 'late')]"/>
                <filter string="On Time" name="on_time" domain="[('due_status', '=', 'on-time')]"/>
                <filter string="Early" name="early" domain="[('due_status', '=', 'early')]"/>
                <filter string="Root Resource" name="root_resource" domain="[('resource_id.parent_ids', '=', False)]"/>
                <separator/>
                <filter string="Edited in Last 5 Minutes" name="edited_last_5_minutes" domain="[('write_date', '>=', (datetime.datetime.now() - datetime.timedelta(minutes=5)).to_utc().strftime('%Y-%m-%d %H:%M:%S'))]"/>
                <filter string="Edited Today" name="edited_today" domain="[('write_date', '>=', time.strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Label" name="groupby_label" context="{'group_by': 'submission_label'}"/>
                    <filter string="Resource" name="groupby_resource" context="{'group_by': 'resource_id'}"/>
                    <filter string="Submission Name" name="groupby_submission_name" context="{'group_by': 'submission_name'}"/>
                    <filter string="Subject" name="groupby_subject" context="{'group_by': 'subjects'}"/>
                    <filter string="Status" name="groupby_state" context="{'group_by': 'state'}"/>
                    <filter string="Student" name="groupby_student" context="{'group_by': 'student_id'}"/>
                    <filter string="Due Status" name="groupby_due_status" context="{'group_by': 'due_status'}"/>
                    <filter string="Assigned By" name="groupby_assigned_by" context="{'group_by': 'assigned_by'}"/>
                    <filter string="Month" name="groupby_month" context="{'group_by': 'date_assigned'}" help="Group by month of assignment"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Resource Submissions list  -->
    <record id="view_aps_resource_submission_list" model="ir.ui.view">
        <field name="name">aps.resource.submission.list</field>
        <field name="model">aps.resource.submission</field>
        <field name="priority">10</field>
        <field name="arch" type="xml">
            <list default_order="create_date desc,student_id,submission_label,submission_order">
                <field name="task_id"  optional="hide"/>
                <field name="subject_icons" widget="image" options="{'size': [20, 20]}" class="me-1" optional="show" string="Icon"/>
                <field name="subjects" widget="many2many_tags" optional="show"/>
                <field name="type_icon" widget="image" options="{'size': [20, 20]}" class="me-1" optional="show" string="Type"/>
                <field name="display_name" optional="show"/>
                <field name="submission_name" optional="show"/>
                <field name="resource_id" optional="hide"/>
                <field name="student_id" optional="show"/>  
                <field name="assigned_by" optional="hide"/>
                <field name="date_assigned" widget="datetime" options="{'format': 'D/MMM/YY HH:mm'}" optional="hide"/>
                <field name="date_submitted" widget="datetime" options="{'format': 'D/MMM/YY HH:mm'}" optional="hide"/>
                <field name="state" widget="badge" decoration-muted="state == 'complete'" decoration-info="state == 'submitted'" decoration-warning="state == 'assigned'" optional="show"/>
                <field name="score" widget="float_sentinel" optional="hide"/>
                <field name="points" optional="hide"/>
                <field name="points_scale" optional="hide"/>
                <field name="due_status" widget="badge" decoration-danger="due_status == 'late'" decoration-info="due_status == 'complete'" decoration-success="due_status == 'early'" optional="hide"/>
                <field name="supporting_resources_buttons" widget="resource_links" optional="hide"/>
                <field name="result_percent"  placeholder="-" widget="percentpie_ranged" optional="hide"/>
                <field name="date_completed" widget="datetime" options="{'format': 'D/MMM/YY HH:mm'}" optional="hide"/>
                <field name="date_due" 
                    widget="badge_decorator"
                    options="{'date_format': 'D-MMM-YY',
                        'default_classes': 'rounded-pill',
                        'expression_classes': {
                            'red-pulsing': 'days_till_due &lt; 0',
                            'red1': 'days_till_due == 0',
                            'red2': 'days_till_due == 1',
                            'red4': 'days_till_due == 2',
                            'red6': 'days_till_due == 3',
                            'grey': 'days_till_due &gt; 3'
                    }}"/>                    
                <field name="has_question" string="Question" readonly="1" optional="hide"/>
                <field name="has_answer" string="Answer" readonly="1" optional="hide"/>
                <field name="has_feedback" widget="boolean" string="Feedback" readonly="1" optional="hide"/>
                <field name="submission_label" optional="hide"/>
                <field name="submission_order" optional="hide"/>
                <field name="review_requested_by" widget="many2many_tags" options="{'no_create': True}" optional="hide"/>
                <field name="reviewed_by" widget="many2many_tags" options="{'no_create': True}" optional="hide"/>
                <field name="notification_state" optional="hide"/>
                <field name="create_date" optional="hide"/>
                <field name="write_date" optional="hide"/>
                <field name="days_till_due" optional="hide"/>
                <button name="action_open_submission" type="object" string="Details..." title="Open Submission" class="btn-secondary btn-sm"/>
            </list>
        </field>
    </record>

    <!-- Resource Submissions list for score entry -->
    <record id="view_aps_resource_submission_score_entry_list" model="ir.ui.view">
        <field name="name">aps.resource.submission.score.list</field>
        <field name="model">aps.resource.submission</field>
        <field name="priority">10</field>
        <field name="arch" type="xml">
            <list editable="top" default_order="create_date,student_id,submission_label,submission_order">
                <field name="task_id"  optional="hide" readonly="1"/>
                <field name="subject_icons" widget="image" options="{'size': [20, 20]}" class="me-1" optional="show" string="Subject"/>
                <field name="type_icon" widget="image" options="{'size': [20, 20]}" class="me-1" optional="show" string="Type"/>
                <field name="subjects" widget="many2many_tags" optional="show" readonly="1"/>
                <field name="display_name" optional="hide" readonly="1"/>
                <field name="submission_name" optional="show" readonly="1"/>
                <field name="resource_id" optional="hide"/>
                <field name="student_id" optional="show" readonly="1"/>
                <field name="assigned_by" readonly="1" optional="hide"/>
                <field name="date_assigned" widget="datetime" options="{'format': 'D/MMM/YY HH:mm'}" optional="hide" readonly="1"/>
                <field name="date_submitted" widget="datetime" options="{'format': 'D/MMM/YY HH:mm'}" optional="hide"/>
                <field name="score" widget="float_sentinel" optional="hide"/>
                <field name="out_of_marks" widget="float_sentinel" optional="hide"/>
                <field name="result_percent"  placeholder="-" widget="percentpie_ranged" optional="hide" readonly="1"/>
                <field name="points" optional="hide"/>
                <field name="state" decoration-muted="state == 'complete'" decoration-info="state == 'submitted'" decoration-warning="state == 'assigned'" optional="hide" />
                <field name="due_status" widget="badge" decoration-danger="due_status == 'late'" decoration-info="due_status == 'complete'" decoration-success="due_status == 'early'" optional="hide" readonly="1" />
                <field name="supporting_resources_buttons" widget="resource_links" optional="hide"/>
                <field name="date_completed" widget="datetime" options="{'format': 'D/MMM/YY HH:mm'}" optional="hide"/>
                <field name="date_due" widget="datetime" options="{'format': 'D/MMM/YY HH:mm'}" optional="hide"/>
                <field name="submission_label" optional="hide" readonly="1"/>
                <field name="submission_order" optional="hide" readonly="1"/>
                <field name="review_requested_by" widget="many2many_tags" options="{'no_create': True}" optional="hide"/>
                <field name="reviewed_by" widget="many2many_tags" options="{'no_create': True}" optional="hide"/>
                <field name="create_date" optional="hide"/>
                <button name="action_open_submission" type="object" string="Details..." title="Open Submission" class="btn-secondary btn-sm"/>
            </list>
        </field>
    </record>

    <!-- Resource Submissions Kanban View -->
    <record id="view_aps_resource_submission_kanban" model="ir.ui.view">
        <field name="name">aps.resource.submission.kanban</field>
        <field name="model">aps.resource.submission</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="id"/>
                <field name="display_name"/>
                <field name="state"/>
                <field name="student_id"/>
                <field name="resource_id"/>
                <field name="date_due"/>
                <field name="due_status"/>
                <field name="score"/>
                <field name="points"/>
                <field name="result_percent"/>
                <field name="subject_icons"/>
                <field name="subjects"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click" style="min-height: 50px;">
                            <div class="row">
                                <div class="col-2">
                                    <img t-if="record.subject_icons.raw_value" 
                                         t-att-src="kanban_image('aps.resource.submission', 'subject_icons', record.id.raw_value, 'image_small')" 
                                         class="oe_kanban_image" style="max-width: 32px; max-height: 32px;" alt="Subject Icon"/>
                                    <div t-else="" class="oe_kanban_no_image">
                                        <i class="fa fa-book" title="Book"></i>
                                    </div>
                                </div>
                                <div class="col-10">
                                    <div class="oe_kanban_content">
                                        <div class="o_kanban_record_title">
                                            <strong><field name="submission_name"/></strong>
                                        </div>
                                        <div class="o_kanban_record_body">
                                            <div class="row">
                                                <div class="col-12">
                                                    <div t-if="record.subjects and record.subjects.raw_value">
                                                        <field name="subjects" widget="many2many_tags"/>
                                                    </div>
                                                    <div>
                                                        <field name="state" widget="badge" 
                                                            decoration-muted="state == 'complete'" 
                                                            decoration-info="state == 'submitted'" 
                                                            decoration-warning="state == 'assigned'"/>
                                                        <span t-if="record.due_status and record.due_status.raw_value" t-attf-class="badge bg-{{ record.due_status.raw_value == 'late' ? 'danger' : record.due_status.raw_value == 'early' ? 'success' : 'info' }}">
                                                            <field name="due_status"/>
                                                        </span>
                                                        <span t-else="" class="badge bg-secondary">Unknown</span>
                                                    </div>
                                                    <div groups="aps_sis.group_aps_teacher"><strong>Student:</strong> <field name="student_id"/></div>
                                                    <div>
                                                            <strong>Due:</strong> <field name="date_due" widget="date"/>
                                                    </div>

                                                    <div t-if="record.score.raw_value and record.score.raw_value !== -0.01">
                                                        <strong>Score:</strong> <field name="score"/> / <field name="out_of_marks"/>
                                                    </div>
                                                    <div t-if="record.result_percent and record.result_percent.raw_value">
                                                        <strong>Result:</strong> <field name="result_percent" widget="percentpie_ranged"/>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="o_kanban_record_bottom">
                                                <div class="oe_kanban_bottom_left">
                                                    <field name="supporting_resources_buttons" widget="resource_links" optional="hide"/>
                                                </div>
                                            <div class="oe_kanban_bottom_right">
                                                <button name="action_open_submission" type="object" class="btn btn-sm btn-secondary">
                                                    <i class="fa fa-external-link" title="Open Submission"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Resource Submissions Form View -->
    <record id="view_aps_resource_submission_form" model="ir.ui.view">
        <field name="name">aps.resource.submission.form</field>
        <field name="model">aps.resource.submission</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="assigned,submitted,complete" statusbar_colors="assigned:warning;submitted:info;complete:success"/>
                    <field name="is_current_user_faculty" invisible="1"/>
                    <button name="action_open_submission_student_view" string="Student View" type="object" class="btn-secondary" />
                    <separator/>
                    <separator/>
                    <button name="action_mark_reviewed" string="Reviewed"  invisible="not is_current_user_faculty" type="object" class="btn-secondary"/>
                    <button name="action_mark_submitted" string="Submit" type="object" class="btn-secondary" invisible="state != 'assigned'"/>
                    <button name="action_resubmit" string="Resubmit" type="object" class="btn-secondary" invisible="state in ['assigned']"/>
                    <button name="action_mark_complete" string="Mark Complete" type="object" class="btn-primary" invisible="state not in ['assigned', 'submitted'] or not is_current_user_faculty"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Late" bg_color="bg-danger"
                            invisible="due_status != 'late'"/> 
                    <widget name="web_ribbon" title="On-Time" bg_color="bg-info" 
                            invisible="due_status != 'on-time'"/> 
                    <widget name="web_ribbon" title="Early" bg_color="bg-success" 
                            invisible="due_status != 'early'"/> 
                    <group>
                        <div class="d-flex align-items-left gap-1">
                            <field name="type_icon" widget="image" options="{'size': [32, 32]}" nolabel="1" style="width:32px"/>
                            <field name="submission_name" nolabel="1" class="fs-3 fw-bold" />
                        </div>
                    </group>

                    <field name="model_answer_is_notes" invisible="1"/>
                    <notebook>
                        <page string="ⓘ Details">
                            <group>
                                <group string="Submission Details">
                                    <field name="task_id" invisible="1"/>
                                    <field name="student_id"/>
                                    <field name="resource_id" readonly="1"/>
                                    <field name="subjects" widget="many2many_tags" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="allow_subject_editing"  widget="boolean_toggle" />
                                    <field name="assigned_by"/>
                                    <div class="o_row" colspan="2">  <!-- colspan=2 makes it span both columns of the parent group -->
                                        <label for="date_assigned" string="Assigned Date and Time" class="fw-bold"/>
                                        <field name="date_assigned" widget="datetime" options="{'format': 'D/MMM/YY HH:mm'}"/>
                                        <field name="time_assigned" widget="float_time" nolabel="1"/>
                                    </div>
                                    <field name="date_due" widget="datetime" options="{'format': 'D/MMM/YY HH:mm'}"/>
                                    <field name="submission_label"/>
                                    <field name="supporting_resources_buttons" widget="resource_links"/>
                                    <field name="submission_active" widget="boolean_toggle" />
                                </group>
                                <group string="Results">
                                    <field name="state" readonly="not is_current_user_faculty"/>
                                    <label for="score" string="Score"/>
                                    <div class="o_row">
                                        <field name="score" widget="float_sentinel" options="{'sentinel': -0.01}" class="oe_inline" nolabel="1"/>
                                        <span class="oe_inline"> / </span>
                                        <field name="out_of_marks" widget="float_sentinel" options="{'sentinel': -0.01}" class="oe_inline" nolabel="1"/>
                                    </div>
                                    <field name="result_percent" widget="percentpie_ranged" />
                                    
                                    <field class="col" name="points"/>
                                    <field class="col" name="points_scale" readonly="0"/>
                                    
                                    <field name="date_submitted" widget="datetime" options="{'format': 'D/MMM/YY HH:mm'}"/>
                                    <field name="date_completed" widget="datetime" options="{'format': 'D/MMM/YY HH:mm'}"/>
                                    <field name="due_status" readonly="not is_current_user_faculty"/>
                                    <field name="reviewed_by" widget="many2many_tags" options="{'no_create': True}"/>
                                    <field name="review_requested_by" widget="many2many_tags" options="{'no_create': True}"/>
                                </group>
                            </group>
                            <group>
                                <group string="Other Details">
                                    <field name="active_datetime" readonly="1"/>
                                    <field name="notification_state"  />
                                    <field name="days_till_due" readonly="1"/>
                                    
                                    <field name="create_date" readonly="1"/>
                                    <field name="write_date" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Student Answer">
                            <field name="answer" nolabel="1" placeholder="Enter your answer here."/>
                        </page>
                        <page string="🗪 Teacher Feedback">
                            <field name="feedback" nolabel="1" placeholder="Feedback on this submission."/>
                        </page>
                        <page string="🗹 Model Answer" invisible="not model_answer or model_answer_is_notes">
                            <field name="model_answer" nolabel="1" placeholder="Model answer for this submission." readonly="1"/>
                        </page>
                        <page string="🗹 Notes" invisible="not model_answer or not model_answer_is_notes">
                            <field name="model_answer" nolabel="1" placeholder="Notes for this submission." readonly="1"/>
                        </page>
                        <page string="ℚuestion" invisible="has_question=='no'">
                            <field name="question" nolabel="1" readonly=""/>
                        </page>
                    </notebook>
                </sheet>
                <chatter groups="aps_sis.group_aps_teacher"/>
            </form>
        </field>
    </record>

    <record id="action_aps_resource_submissions" model="ir.actions.act_window">
        <field name="name">Submissions</field>
        <field name="res_model">aps.resource.submission</field>
        <field name="view_mode">list,form,pivot,kanban,graph,calendar</field>
        <!-- <field name="view_id" ref="view_aps_resource_submission_list"/> -->
        <!-- <field name="views" eval="[(ref('aps_sis.view_aps_resource_submission_list'), 'list'), 
                               (ref('aps_sis.view_aps_resource_submission_form'), 'form')]"/> -->
        <field name="context">{'search_default_submission_active':1}</field>
    </record>

    <record id="action_aps_resource_submissions_score" model="ir.actions.act_window">
        <field name="name">Enter Scores</field>
        <field name="res_model">aps.resource.submission</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_aps_resource_submission_score_entry_list"/>
    </record>

    <!-- Server actions for bulk state changes -->
    <record id="action_mark_assigned" model="ir.actions.server">
        <field name="name">Mark as Assigned</field>
        <field name="model_id" ref="aps_sis.model_aps_resource_submission"/>
        <field name="binding_model_id" ref="aps_sis.model_aps_resource_submission"/>
        <field name="binding_view_types">list,kanban</field>
        <field name="state">code</field>
        <field name="code">action = records.action_mark_assigned()</field>
    </record>

    <record id="action_mark_submitted" model="ir.actions.server">
        <field name="name">Mark as Submitted</field>
        <field name="model_id" ref="aps_sis.model_aps_resource_submission"/>
        <field name="binding_model_id" ref="aps_sis.model_aps_resource_submission"/>
        <field name="binding_view_types">list,kanban</field>
        <field name="state">code</field>
        <field name="code">action = records.action_mark_submitted()</field>
    </record>

    <record id="action_mark_complete" model="ir.actions.server">
        <field name="name">Mark as Finalised</field>
        <field name="model_id" ref="aps_sis.model_aps_resource_submission"/>
        <field name="binding_model_id" ref="aps_sis.model_aps_resource_submission"/>
        <field name="binding_view_types">list,kanban</field>
        <field name="state">code</field>
        <field name="code">action = records.action_mark_complete()</field>
    </record>

    <record id="action_set_due_status_on_time" model="ir.actions.server">
        <field name="name">Mark as On Time</field>
        <field name="model_id" ref="aps_sis.model_aps_resource_submission"/>
        <field name="binding_model_id" ref="aps_sis.model_aps_resource_submission"/>
        <field name="binding_view_types">list,kanban</field>
        <field name="state">code</field>
        <field name="code">action = records.action_set_due_status_on_time()</field>
    </record>


</odoo>