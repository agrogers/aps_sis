<?xml version="1.0" encoding="UTF-8"?>
<odoo>


    <!-- APS Resource Submissions list & Form Views -->
    <record id="view_aps_resource_submission_list_for_students" model="ir.ui.view">
        <field name="name">aps.resource.submission.list.for.students</field>
        <field name="model">aps.resource.submission</field>
        <field name="priority">5</field>
        <field name="arch" type="xml">
            <list string="My Submissions" create="false" delete="false">
                <field name="subject_icons" widget="image" options="{'size': [20, 20]}" class="me-1" optional="show" string="Subject"/>
                <field name="subjects" widget="many2many_tags" optional="hide"/>
                <field name="type_icon" widget="image" options="{'size': [20, 20]}" class="me-1" optional="show" string="Type"/>
                <field name="submission_name" optional="show"/>
                <field name="resource_id" optional="hide"/>
                <field name="display_name" optional="hide"/>
                <field name="student_id" optional="hide"/>  
                <field name="date_assigned" widget="datetime" options="{'format': 'D/MMM/YY HH:mm'}" optional="hide"/>
                <field name="time_assigned" widget="float_time" optional="hide"/>
                <field name="date_submitted" widget="datetime" options="{'format': 'D/MMM/YY HH:mm'}" optional="hide"/>
                <field name="state" widget="badge" decoration-muted="state == 'complete'" decoration-info="state == 'submitted'" decoration-warning="state == 'assigned'"/>
                <field name="due_status" widget="badge" decoration-danger="due_status == 'late'" decoration-info="due_status == 'complete'" decoration-success="due_status == 'early'" optional="show"/>
                <field name="date_due" 
                    widget="badge_decorator"
                    options="{'date_format': 'D-MMM-YY',
                        'default_classes': 'rounded-pill',
                        'expression_classes': {
                            'red-pulsing': 'days_till_due &lt; 0',
                            'red1': 'days_till_due == 0',
                            'red2': 'days_till_due == 1',
                            'red4': 'days_till_due == 2',
                            'red6': 'days_till_due == 3',
                            'grey': 'days_till_due &gt; 3'
                        }}"/>                   
                <field name="supporting_resources_buttons" widget="resource_links" optional="show"/>
                <field name="score" widget="float_sentinel" optional="show" />
                <field name="out_of_marks" widget="float_sentinel" optional="hide" />
                <field name="result_percent"  placeholder="-" widget="percentpie_ranged" optional="show"/>
                <field name="points"  optional="hide" sum="Total Points"/>
                <field name="date_completed" widget="datetime" options="{'format': 'D/MMM/YY HH:mm'}" optional="hide"/>
                <field name="has_question" string="Question" readonly="1" optional="hide"/>
                <field name="has_answer" string="Answer" readonly="1" optional="hide"/>
                <field name="has_feedback" widget="boolean" string="Feedback" readonly="1" optional="show"/>
                <field name="submission_label" optional="hide"/>
                <field name="submission_order" optional="hide"/>
                <field name="task_id"  optional="hide"/>
                <field name="assigned_by" optional="hide"/>
                <field name="review_requested_by" widget="many2many_tags" options="{'no_create': True}" optional="hide"/>
                <field name="reviewed_by" widget="many2many_tags" options="{'no_create': True}" optional="hide"/>
                <field name="create_date" optional="hide"/>
                <field name="days_till_due" optional="hide"/>
                <button name="action_open_submission" type="object" string="Details..."
                    title="Open Submission" class="btn-secondary btn-sm" invisible="not is_current_user_faculty"/>

            </list>
        </field>
    </record>

<!-- Student Submssion Form -->
    <record id="view_aps_resource_submission_form_for_students" model="ir.ui.view">
        <field name="name">aps.resource.submission.form.for.students</field>
        <field name="model">aps.resource.submission</field>
        <field name="priority">5</field>
        <field name="arch" type="xml">
            <form create="false" delete="false">
               <header>
                    <button name="action_open_submission" string="Submission Details" type="object" class="btn-secondary" invisible="not is_current_user_faculty"/>
                    <separator invisible="not is_current_user_faculty"/>
                    <separator invisible="not is_current_user_faculty"/>
                    <field name="state" widget="statusbar" statusbar_visible="assigned,submitted,complete" statusbar_colors="assigned:warning;submitted:info;complete:success"/>
                    <field name="is_current_user_faculty" invisible="1"/>
                    <field name="is_current_user_reviewed" invisible="1"/>
                    <button name="action_mark_reviewed" string="Reviewed" invisible="not is_current_user_faculty or is_current_user_reviewed" type="object" class="btn-secondary"/>
                    <button name="action_mark_unsubmitted" string="Unsubmit" type="object" class="btn-secondary" invisible="state != 'submitted'"/>
                    <button name="action_mark_submitted" string="Submit" type="object" class="btn-primary" invisible="state != 'assigned'"/>
                    <button name="action_resubmit" string="Resubmit" type="object" class="btn-secondary" invisible="state in ['assigned']"/>
                    <button name="action_mark_complete" string="Mark Complete" type="object" class="btn-primary" invisible="state not in ['assigned'] or not is_current_user_faculty"/>
                    <button name="action_mark_complete" string="Mark Complete" type="object" class="btn-primary" invisible="state != 'submitted' or not is_current_user_faculty"/>
                    <button name="action_mark_complete_next" string="Complete>" type="object" class="btn-primary" invisible="state != 'submitted' or not is_current_user_faculty" context="{'generic_form_action': True, 'move_to_next_record': True, 'preserve_form_res_ids': True, 'success_toast_title': 'Done', 'success_toast_message': 'Processed 1 submission(s).', 'success_toast_type': 'success'}"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Late" bg_color="bg-danger" invisible="due_status != 'late'"/> 
                    <widget name="web_ribbon" title="On-Time" bg_color="bg-info" invisible="due_status != 'on-time'"/> 
                    <widget name="web_ribbon" title="Early" bg_color="bg-success" invisible="due_status != 'early'"/> 
                    
                    <group col="12">
                        <group colspan="8">
                            <div class="d-flex align-items-left gap-1">
                                <field name="type_icon" widget="image_result" options="{'size': [52, 52], 'task_id': 'task_id'}" nolabel="1" style="width:60px" readonly="1"/>

                                <field name="submission_name" nolabel="1" class="fs-3 fw-bold" options="{'no_open': True}"/>
                            </div>
                        </group>
                        <group colspan="4">
                            <field name="review_requested_by" string="Review:" widget="many2many_tags" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group col="12" class="mb-4">
                        <group colspan="3">
                            <field name="student_id" readonly="1" nolabel="1" class="fw-bold"/>
                            <field name="date_due" widget="datetime" string="Due:" options="{'format': 'D/MMM/YY HH:mm'}" readonly="not is_current_user_faculty"/>
                        </group>
                        <group colspan="9">
                            <div class="d-flex justify-content-end w-100">
                                <field name="supporting_resources_buttons" widget="resource_links" nolabel="1" options="{'size': '50px', 'show_name':True, 'show_results':True}"/>
                            </div>
                        </group>
                    </group>
                    

                    <notebook >
                        <page string="Student Answer" class="tab-with-icon student-answer-tab" name="student_answer_page" >
                            <group class="container-fluid">
                                <div class="row flex-nowrap">
                                <group class="col">
                                    <div class="o_row fs-3" invisible="out_of_marks != 0">
                                        This task is not graded. Just submit it when you're done!
                                    </div>
                                    <div class="o_row fs-2 fw-bold  flex-nowrap" style="white-space:nowrap" invisible="out_of_marks == 0">
                                        <span>
                                            <label for="score" string="Score:" class="oe_inline fs-2 me-2"/>
                                            <field name="score" widget="float_sentinel" options="{'sentinel': -0.01}" class="oe_inline fixed-score-width" nolabel="1" readonly="state == 'complete' or (state == 'submitted' and not is_current_user_faculty)"/>
                                            <span class="oe_inline mx-1"> / </span>
                                            <field name="out_of_marks" widget="float_sentinel" options="{'sentinel': -0.01}" class="oe_inline fixed-score-width" nolabel="1" readonly="1"/>
                                            <span class="ps-2">⇒</span>
                                            <field name="result_percent" widget="percentpie_ranged" class="oe_inline ms-3" readonly="state == 'complete' or (state == 'submitted' and not is_current_user_faculty)"/>
                                            <span>  </span>
                                        </span> 
                                    </div>
                                </group>
                                <group style="max-width:125px" class="col d-flex justify-content-end fs-2" invisible="state == 'assigned'">
                                    <field name="points" style="max-width:40px" string="Pts"/>
                                </group>
                                </div>
                            </group>
                            <field name="subjects" widget="clickable_many2many_tags" invisible="allow_subject_editing==False" no_add="True" no_open="True" options="{'no_create': True}"/>
                            
                            <div class="text-muted" style="font-size: 1.2em;" invisible="state == 'assigned' or answer">
                                <hr/>
                                No answer has been supplied.
                            </div>

                            <div class="row g-3" invisible="not has_feedback">
                                <div class="col-12 col-lg-6" >
                                    <group string="Answer" >
                                        <field name="answer" nolabel="1" placeholder="Enter your answer here." 
                                        readonly="state == 'complete' or (state == 'submitted' and not is_current_user_faculty)" 
                                        invisible="state != 'assigned' and not answer"/>
                                    </group>
                                </div>
                                <div class="col-12 col-lg-6" >
                                    <group string="Teacher Feedback" >
                                        <field name="feedback" class="feedback" nolabel="1" placeholder="Feedback on this submission." 
                                            readonly="not is_current_user_faculty"/>
                                    </group>
                                </div>

                                <field name="answer" nolabel="1" placeholder="Enter your answer here." 
                                    readonly="state == 'complete' or (state == 'submitted' and not is_current_user_faculty)" 
                                    invisible="(state != 'assigned' and not answer) or has_feedback"/>
                                
                            </div>
                        </page>


                        <page string="Teacher Feedback" class="tab-with-icon teacher-feedback-tab" invisible="state=='assigned' or not has_feedback"  name="feedback_page" >
                            <field name="feedback" nolabel="1" readonly="True if is_current_user_faculty else True" placeholder="Feedback on this submission."/>
                        </page>
                        <page string="Model Answer" class=" tab-with-icon model-answer-tab" invisible="not model_answer or state=='assigned' or model_answer_is_notes or has_answer == 'hidden'" name="model_answer_page">
                            <field name="model_answer" nolabel="1" placeholder="Model answer for this submission."/>
                        </page>
                        <page string="Question" name="question_page" class="default-page tab-with-icon question-tab" invisible="has_question == 'no' or has_question == 'hidden'">
                            <field name="question" nolabel="1" readonly="not is_current_user_faculty"/>
                        </page>
                        <page string="Notes" name="resource_notes_page" class="tab-with-icon notes-tab" invisible="resource_has_notes == 'no' or not resource_notes">
                            <field name="resource_notes" nolabel="1" readonly="1"/>
                        </page>
                        <page string="." name="information_page"  class="tab-with-icon information-tab tab-hide-label" invisible="1">
                            <group>
                                <group>
                                    <label for="task_id"/>
                                    <div class="o_row">
                                        <button name="action_open_task" type="object" class="btn btn-link btn-sm p-0 ms-1" icon="fa-external-link" title="Open Task" invisible="not task_id"/>
                                        <field name="task_id" readonly="1" class="oe_inline"/>
                                    </div>
                                    <!-- <field name="student_id" readonly="1"/> -->
                                    <field name="resource_id" readonly="1"/>
                                    <field name="subjects" readonly="1" widget="many2many_tags" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="supporting_resources_buttons" widget="resource_links"/>
                                    <field name="assigned_by"/>
                                    <div class="o_row" colspan="2">  <!-- colspan=2 makes it span both columns of the parent group -->
                                        <label for="date_assigned" string="Assigned On" class="fw-bold"/>
                                        <field name="date_assigned" widget="datetime" options="{'format': 'D/MMM/YY HH:mm'}"/>
                                        <field name="time_assigned" widget="float_time" nolabel="1"/>
                                    </div>
                                    <field name="submission_label"/>
                                    <field name="url" widget="url" readonly="1"/>
                                </group>
                                <group>
                                    <field name="state" readonly="not is_current_user_faculty"/>
                                    <field name="date_submitted" widget="datetime" options="{'format': 'D/MMM/YY HH:mm'}"/>
                                    <field name="date_completed" widget="datetime" options="{'format': 'D/MMM/YY HH:mm'}"/>
                                    <field name="date_due" widget="datetime" string="Due:" options="{'format': 'D/MMM/YY HH:mm'}" readonly="not is_current_user_faculty"/>
                                    <field name="due_status"/>
                                    <field name="points_scale"/>
                                    <field name="reviewed_by" widget="many2many_tags" options="{'no_create': True}"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter groups="aps_sis.group_aps_teacher"/>
          </form>
        </field>
    </record>

    <record id="action_aps_resource_submissions_for_students" model="ir.actions.act_window">
        <field name="name">My Submissions</field>
        <field name="res_model">aps.resource.submission</field>
        <field name="view_mode">list,form,pivot,kanban,graph,calendar</field>
        <field name="context">{
            'searchpanel_default_state': ['assigned'],
            'default_notebook_page': 'question_page'
        }</field>           
        
    </record>

    <!-- Bind specific views to the action -->
    <record id="action_aps_resource_submissions_for_students_view_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_aps_resource_submission_list_for_students"/>
        <field name="act_window_id" ref="action_aps_resource_submissions_for_students"/>       
    </record>

    <record id="action_aps_resource_submissions_for_students_view_form" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_aps_resource_submission_form_for_students"/>
        <field name="act_window_id" ref="action_aps_resource_submissions_for_students"/>
    </record>

    <!-- Student Dashboard Graph View -->
    <record id="view_student_dashboard_graph" model="ir.ui.view">
        <field name="name">aps.resource.submission.graph.dashboard</field>
        <field name="model">aps.resource.submission</field>
        <field name="arch" type="xml">
            <graph string="Submissions by Status" type="pie" sample="1">
                <field name="state"/>
            </graph>
        </field>
    </record>

    <!-- Student Dashboard Calendar View -->
    <record id="view_student_dashboard_calendar" model="ir.ui.view">
        <field name="name">aps.resource.submission.calendar.dashboard</field>
        <field name="model">aps.resource.submission</field>
        <field name="arch" type="xml">
            <calendar date_start="date_due" color="state" mode="month">
                <field name="display_name"/>
                <field name="resource_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <!-- Student Dashboard Action -->
    <record id="action_student_dashboard" model="ir.actions.act_window">
        <field name="name">Student Dashboard</field>
        <field name="res_model">aps.resource.submission</field>
        <field name="view_mode">graph,calendar,list,kanban,pivot</field>
        <field name="target">current</field>
        <field name="context">{'search_default_submission_active':1}</field>
    </record>

    <!-- Bind specific views to the dashboard action -->
    <record id="action_student_dashboard_view_graph" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_student_dashboard_graph"/>
        <field name="act_window_id" ref="action_student_dashboard"/>
    </record>

    <record id="action_student_dashboard_view_calendar" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">calendar</field>
        <field name="view_id" ref="view_student_dashboard_calendar"/>
        <field name="act_window_id" ref="action_student_dashboard"/>
        
    </record>

    <record id="action_student_dashboard_view_list" model="ir.actions.act_window.view">
        <field name="sequence">3</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_aps_resource_submission_list_for_students"/>
        <field name="act_window_id" ref="action_student_dashboard"/>
        
    </record>

    <record id="action_student_dashboard_view_kanban" model="ir.actions.act_window.view">
        <field name="sequence">4</field>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_aps_resource_submission_kanban"/>
        <field name="act_window_id" ref="action_student_dashboard"/>
    </record>

</odoo>