<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Grant APEX Teachers access to the Prompt Templates and Prompt Tags menus -->
    <record id="aps_ai.menu_aps_ai_prompts" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('base.group_system')), (4, ref('aps_sis.group_aps_manager')), (4, ref('aps_sis.group_aps_teacher'))]"/>
    </record>
    <record id="aps_ai.menu_aps_ai_prompt_tags" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('base.group_system')), (4, ref('aps_sis.group_aps_manager')), (4, ref('aps_sis.group_aps_teacher'))]"/>
    </record>
</odoo>
