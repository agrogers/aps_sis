<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_my_submissions" name="My Submissions">
        <t t-call="web.layout">
            <div class="container o_my_submissions mt-5">
                <div class="row">
                    <div class="col-12">
                        <h1>My Submissions</h1>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-12">
                        <t t-if="not submissions">
                            <p>You have no submissions.</p>
                        </t>
                        <t t-else="">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Task</th>
                                        <th>State</th>
                                        <th>Due Date</th>
                                        <th>Score</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="submissions" t-as="submission">
                                        <td><t t-out="submission.task_id.name"/></td>
                                        <td><t t-out="submission.state"/></td>
                                        <td><t t-out="submission.date_due and submission.date_due.strftime('%d/%m/%Y') or '-'"/></td>
                                        <td><t t-out="submission.score != -0.01 and f'{submission.score}/{submission.out_of_marks}' or '-'"/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="resource_share_page" name="Resource Share Page">
        <t t-call="portal.portal_layout">
            <t t-set="additional_title" t-value="resource.name or resource.display_name"/>
            <div class="o_portal_wrap">
                <div class="container py-5">
                    <div class="row justify-content-center">
                        <div class="col-lg-9 col-xl-8">

                            <!-- Title card -->
                            <div class="card shadow-sm mb-4">
                                <div class="card-body p-4">
                                    <h1 class="h2 mb-1 fw-bold" t-esc="resource.name or resource.display_name"/>
                                    <t t-if="resource.display_name and resource.name and resource.display_name != resource.name">
                                        <p class="text-muted small mb-0" t-esc="resource.display_name"/>
                                    </t>
                                    <t t-if="resource.subjects">
                                        <div class="mt-3">
                                            <t t-foreach="resource.subjects" t-as="subject">
                                                <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 me-1 mb-1 px-3 py-2 aps-subject-badge"
                                                      t-esc="subject.name"/>
                                            </t>
                                        </div>
                                    </t>
                                </div>
                            </div>

                            <!-- Notes card -->
                            <t t-if="resource.has_notes in ('yes', 'use_parent') and resource.notes">
                                <div class="card shadow-sm mb-4">
                                    <div class="card-header bg-light py-2 px-4">
                                        <h5 class="mb-0 aps-card-header-title">Notes</h5>
                                    </div>
                                    <div class="card-body p-4">
                                        <div class="aps-notes-content" t-out="resource.notes"/>
                                    </div>
                                </div>
                            </t>

                            <!-- Empty state -->
                            <t t-if="resource.has_notes not in ('yes', 'use_parent') and not resource.subjects">
                                <div class="alert alert-light text-muted text-center py-4">
                                    No additional details are available for this resource.
                                </div>
                            </t>

                            <p class="text-center text-muted small mt-4">Shared via APEX</p>

                        </div>
                    </div>
                </div>
            </div>
            <style>
                .aps-subject-badge { font-size: 0.85rem; }
                .aps-card-header-title { font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
                                         letter-spacing: 0.08em; color: #6c757d; }
                .aps-notes-content img { max-width: 100%; height: auto; }
                .aps-notes-content table { width: 100%; border-collapse: collapse; }
                .aps-notes-content table td,
                .aps-notes-content table th { border: 1px solid #dee2e6; padding: 0.4rem 0.6rem; }
            </style>
        </t>
    </template>
</odoo>
