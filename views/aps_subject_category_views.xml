<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Subject Category Tree/List View -->
    <record id="view_aps_subject_category_tree" model="ir.ui.view">
        <field name="name">aps.subject.category.tree</field>
        <field name="model">aps.subject.category</field>
        <field name="arch" type="xml">
            <list string="Subject Categories">
                <field name="name"/>
                <field name="code"/>
                <field name="description"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Subject Category Form  View -->
    <record id="view_aps_subject_category_form" model="ir.ui.view">
        <field name="name">aps.subject.category.form</field>
        <field name="model">aps.subject.category</field>
        <field name="arch" type="xml">
            <form string="Subject Category">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="color" widget="color"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" colspan="4"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Subject Category Action -->
    <record id="action_aps_subject_categories" model="ir.actions.act_window">
        <field name="name">Subject Categories</field>
        <field name="res_model">aps.subject.category</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_aps_subject_category_tree"/>
    </record>

    <!-- Add to Menu -->
    <menuitem id="menu_aps_subject_categories" 
              name="Subject Categories" 
              parent="openeducat_core.menu_op_school_config"
              action="action_aps_subject_categories"
              sequence="20"/>
</odoo>