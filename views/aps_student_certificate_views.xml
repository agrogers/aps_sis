<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_aps_student_certificate_list" model="ir.ui.view">
        <field name="name">aps.student.certificate.list</field>
        <field name="model">aps.student.certificate</field>
        <field name="arch" type="xml">
            <list>
                <field name="partner_id" optional="show"/>
                <field name="event" optional="show"/>
                <field name="award_category_id" optional="show"/>
                <field name="award_sub_category_id" optional="show"/>
                <field name="subject_id" optional="hide"/>
                <field name="academic_week_id" optional="hide"/>
                <field name="date_awarded" optional="show"/>
                <field name="certificate_date" optional="show"/>
                <field name="certificate_template_id" optional="show"/>
                <field name="last_printed" optional="show"/>
                <button name="action_print_certificate" string="Print" type="object" class="btn-link"/>
            </list>
        </field>
    </record>

    <record id="view_aps_student_certificate_form" model="ir.ui.view">
        <field name="name">aps.student.certificate.form</field>
        <field name="model">aps.student.certificate</field>
        <field name="arch" type="xml">
            <form string="Student Certificate">
                <header>
                    <button name="action_print_certificate" string="Print Certificate" type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <group col="2">
                        <group>
                            <field name="partner_id"/>
                            <field name="event"/>
                            <field name="award_category_id"/>
                            <field name="award_sub_category_id"
                                invisible="not award_category_id"/>
                            <field name="subject_id"/>
                        </group>
                        <group>
                            <field name="certificate_template_id"/>
                            <field name="date_awarded"/>
                            <field name="certificate_date"/>
                            <field name="academic_week_id"/>
                            <field name="last_printed" readonly="1"/>
                        </group>
                    </group>
                    <group string="Related People">
                        <field name="related_partner_ids" nolabel="1"
                            widget="many2many_tags"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_aps_student_certificate" model="ir.actions.act_window">
        <field name="name">Student Certificates</field>
        <field name="res_model">aps.student.certificate</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_aps_student_certificate_list_view" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_aps_student_certificate_list"/>
        <field name="act_window_id" ref="action_aps_student_certificate"/>
    </record>

    <record id="action_aps_student_certificate_form_view" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_aps_student_certificate_form"/>
        <field name="act_window_id" ref="action_aps_student_certificate"/>
    </record>

    <record id="view_aps_certificate_template_list" model="ir.ui.view">
        <field name="name">aps.certificate.template.list</field>
        <field name="model">aps.certificate.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" optional="show"/>
                <field name="page_format" optional="show"/>
                <field name="page_orientation" optional="show"/>
                <field name="mail_template_id" optional="show"/>
                <field name="active" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_aps_certificate_template_form" model="ir.ui.view">
        <field name="name">aps.certificate.template.form</field>
        <field name="model">aps.certificate.template</field>
        <field name="arch" type="xml">
            <form string="Certificate Template">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="page_format"/>
                        <field name="page_orientation"/>
                        <field name="frame_image" widget="image" class="o_image_64_max"/>
                        <field name="mail_template_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Award Categories -->

    <record id="view_aps_award_category_list" model="ir.ui.view">
        <field name="name">aps.award.category.list</field>
        <field name="model">aps.award.category</field>
        <field name="arch" type="xml">
            <list>
                 <field name="image" widget="image" options="{'size': [24, 24]}" optional="show"/>
                 <field name="name"/>
                 <field name="voting_active" optional="show"/>
                 <field name="adhoc_vote" optional="show"/>
                 <field name="open_date" optional="show"/>
                 <field name="short_description" optional="show"/>
                 <field name="voting_restrictions" optional="show"/>
                 <field name="level_ids" widget="many2many_tags" optional="hide"/>
                 <field name="term_ids" widget="many2many_tags" optional="hide"/>
                 <field name="subject_category_ids" widget="many2many_tags" optional="hide"/>
                 <field name="certificate_template_id" optional="show"/>
                 <field name="sub_category_ids" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_aps_award_category_form" model="ir.ui.view">
        <field name="name">aps.award.category.form</field>
        <field name="model">aps.award.category</field>
        <field name="arch" type="xml">
            <form string="Award Category">
                <sheet>
                    <field name="image" widget="image" class="oe_avatar" options="{'preview_image': 'image'}"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Award Category"/>
                        </h1>
                        <field name="short_description" placeholder="Short Description…"/>
                        <field name="description" placeholder="Description…"/>
                    </div>
                    <group>
                        <group>
                            <field name="voting_active"/>
                            <field name="adhoc_vote"/>
                            <field name="open_date"/>
                            <field name="voting_restrictions"/>
                        </group>
                        <group>
                            <field name="level_ids" widget="many2many_tags"/>
                            <field name="term_ids" widget="many2many_tags"/>
                            <field name="subject_category_ids" widget="many2many_tags"/>
                            <field name="certificate_template_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Sub-Categories">
                            <field name="sub_category_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_aps_award_category" model="ir.actions.act_window">
        <field name="name">Award Categories</field>
        <field name="res_model">aps.award.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_aps_award_category_list_view" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_aps_award_category_list"/>
        <field name="act_window_id" ref="action_aps_award_category"/>
    </record>

    <record id="action_aps_award_category_form_view" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_aps_award_category_form"/>
        <field name="act_window_id" ref="action_aps_award_category"/>
    </record>

    <!-- Award Votes -->

    <record id="view_aps_award_vote_list" model="ir.ui.view">
        <field name="name">aps.award.vote.list</field>
        <field name="model">aps.award.vote</field>
        <field name="arch" type="xml">
            <list>
                <field name="state" optional="show"/>
                <field name="open_date" optional="show"/>
                <field name="due_date" optional="show"/>
                <field name="submitted_date" optional="show"/>
                <field name="award_category_id" optional="show"/>
                <field name="award_sub_category_id" optional="show"/>
                <field name="academic_week_id" optional="show"/>
                <field name="recipient_partner_id" optional="show"/>
                <field name="voter_partner_id" optional="show"/>
                <field name="comment" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_aps_award_vote_form" model="ir.ui.view">
        <field name="name">aps.award.vote.form</field>
        <field name="model">aps.award.vote</field>
        <field name="arch" type="xml">
            <form string="Award Vote">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="pending,open,submitted,closed"/>
                </header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="short_description" placeholder="Short description…"/></h1>
                    </div>
                    <group col="2">
                        <group>
                            <field name="award_category_id"/>
                            <field name="award_sub_category_id"
                                invisible="not award_category_id"/>
                            <field name="academic_week_id"/>
                            <field name="recipient_partner_id"/>
                            <field name="voter_partner_id"/>
                            <field name="vote_round_id"/>
                        </group>
                        <group>
                            <field name="state"/>
                            <field name="open_date"/>
                            <field name="due_date"/>
                            <field name="submitted_date"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                    <group string="Comment">
                        <field name="comment" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_aps_award_vote" model="ir.actions.act_window">
        <field name="name">Award Votes</field>
        <field name="res_model">aps.award.vote</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_aps_award_vote_list_view" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_aps_award_vote_list"/>
        <field name="act_window_id" ref="action_aps_award_vote"/>
    </record>

    <record id="action_aps_award_vote_form_view" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_aps_award_vote_form"/>
        <field name="act_window_id" ref="action_aps_award_vote"/>
    </record>

    <!-- Certificate Templates -->

    <record id="action_aps_certificate_template" model="ir.actions.act_window">
        <field name="name">Certificate Templates</field>
        <field name="res_model">aps.certificate.template</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_aps_certificate_template_list_view" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_aps_certificate_template_list"/>
        <field name="act_window_id" ref="action_aps_certificate_template"/>
    </record>

    <record id="action_aps_certificate_template_form_view" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_aps_certificate_template_form"/>
        <field name="act_window_id" ref="action_aps_certificate_template"/>
    </record>

    <!-- Voting Dashboard server action: redirects current user to their voting dashboard -->
    <record id="action_aps_awards_dashboard" model="ir.actions.server">
        <field name="name">Voting Dashboard</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="binding_model_id" eval="False"/>
        <field name="state">code</field>
        <field name="code">
partner = env.user.partner_id.sudo()
token = partner._get_or_create_access_token() if partner else False
if token:
    action = {'type': 'ir.actions.act_url', 'url': '/awards/vote/' + token, 'target': 'self'}
else:
    action = {'type': 'ir.actions.act_url', 'url': '/awards/vote/invalid', 'target': 'self'}
        </field>
    </record>
</odoo>
