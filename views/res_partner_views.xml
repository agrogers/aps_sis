<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Inherit partner form to show gender field under VAT -->
    <record id="view_partner_form_gender" model="ir.ui.view">
        <field name="name">res.partner.form.gender</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- Add Student button in button box if is_student -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_aps_student" type="object" class="oe_stat_button" icon="fa-user-graduate" invisible="aps_student_count == 0">
                    <field name="aps_student_count" widget="statinfo" string="APS Student"/>
                </button>
                <button name="action_open_teacher" type="object" class="oe_stat_button" icon="fa-chalkboard-teacher" invisible="teacher_count == 0">
                    <field name="teacher_count" widget="statinfo" string="Teacher"/>
                </button>
            </xpath>
            <!-- Show gender field under VAT -->
            <xpath expr="//field[@name='vat']" position="after">
                <field name="gender"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit student portal view to add is_teacher -->
    <record id="view_partner_form_teacher" model="ir.ui.view">
        <field name="name">res.partner.form.teacher</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="openeducat_core.student_portal_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='is_student']" position="before">
                    <field name="is_teacher"/>
                    <label for="is_teacher"/>
            </xpath>
        </field>
    </record>

    <!-- Make user_id (Follow-up Responsible) optional in partner tree view -->
    <record id="view_partner_tree_user_id_optional" model="ir.ui.view">
        <field name="name">res.partner.tree.user_id.optional</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
        </field>
    </record>
</odoo>