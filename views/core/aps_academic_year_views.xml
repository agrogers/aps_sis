<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="aps_academic_year_view_list" model="ir.ui.view">
        <field name="name">aps.academic.year.list</field>
        <field name="model">aps.academic.year</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="short_name" optional="show"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="is_current"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="aps_academic_year_view_form" model="ir.ui.view">
        <field name="name">aps.academic.year.form</field>
        <field name="model">aps.academic.year</field>
        <field name="arch" type="xml">
            <form string="Academic Year">
                <div class="alert alert-info" role="alert">
                    <strong>Academic Years</strong> define the school calendar period (e.g. Academic Year 2025-2026).
                    Mark one year as the <strong>Current Year</strong> so that new student enrollments automatically inherit its start and end dates.
                    Academic Terms are grouped within an Academic Year.
                </div>
                <header>
                    <button name="action_set_current" string="Set as Current Year" type="object"
                            class="btn-primary" invisible="is_current"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Current Year" bg_color="bg-success" invisible="not is_current"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Academic Year 2025-2026"/>
                        </h1>
                        <h2>
                            <field name="short_name" placeholder="Short Name (e.g. AY25-26)"/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="is_current"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="aps_academic_year_view_search" model="ir.ui.view">
        <field name="name">aps.academic.year.search</field>
        <field name="model">aps.academic.year</field>
        <field name="arch" type="xml">
            <search string="Academic Years">
                <field name="name"/>
                <field name="short_name"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="aps_academic_year_action" model="ir.actions.act_window">
        <field name="name">Academic Years</field>
        <field name="res_model">aps.academic.year</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="aps_academic_year_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first academic year (e.g. Academic Year 2025-2026).
            </p>
        </field>
    </record>

</odoo>
