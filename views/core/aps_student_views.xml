<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="aps_student_view_list" model="ir.ui.view">
        <field name="name">aps.student.list</field>
        <field name="model">aps.student</field>
        <field name="arch" type="xml">
            <list>
                <field name="partner_id"/>
                <field name="roll" optional="show"/>
                <field name="level_id" optional="show"/>
                <field name="home_class_id" optional="show"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="aps_student_view_form" model="ir.ui.view">
        <field name="name">aps.student.form</field>
        <field name="model">aps.student</field>
        <field name="arch" type="xml">
            <form string="Student">
                <div class="alert alert-info" role="alert">
                    <strong>Students</strong> link a <strong>Partner</strong> (person) to the school system.
                    Assign a <strong>Roll Number</strong>, <strong>Level</strong>, and primary <strong>Class</strong> here.
                    Use the <strong>Classes</strong> tab to manage all class enrollments for this student, including historical enrollments.
                </div>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="partner_id" placeholder="Student"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="roll"/>
                            <field name="level_id"/>
                            <field name="home_class_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Classes">
                            <field name="enrollment_ids">
                                <list>
                                    <field name="home_class_id"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="state" widget="badge"
                                        decoration-success="state == 'enrolled'"
                                        decoration-warning="state == 'withdrawn'"
                                        decoration-muted="state == 'finished'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="aps_student_view_search" model="ir.ui.view">
        <field name="name">aps.student.search</field>
        <field name="model">aps.student</field>
        <field name="arch" type="xml">
            <search string="Students">
                <field name="partner_id"/>
                <field name="roll"/>
                <field name="level_id"/>
                <field name="home_class_id"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Class" name="group_class" context="{'group_by': 'home_class_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="aps_student_action" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">aps.student</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="aps_student_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first student.
            </p>
        </field>
    </record>

    <!-- Populate server action (shows in Actions menu on list) -->
    <record id="aps_student_action_populate" model="ir.actions.server">
        <field name="name">Populate from Contacts</field>
        <field name="model_id" ref="model_aps_student"/>
        <field name="binding_model_id" ref="model_aps_student"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = model.action_populate_from_contacts()</field>
    </record>

</odoo>
