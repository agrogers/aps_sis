<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="aps_ethnicity_view_list" model="ir.ui.view">
        <field name="name">aps.ethnicity.list</field>
        <field name="model">aps.ethnicity</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="aps_ethnicity_view_form" model="ir.ui.view">
        <field name="name">aps.ethnicity.form</field>
        <field name="model">aps.ethnicity</field>
        <field name="arch" type="xml">
            <form string="Ethnicity">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Ethnicity Name"/>
                        </h1>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="aps_ethnicity_view_search" model="ir.ui.view">
        <field name="name">aps.ethnicity.search</field>
        <field name="model">aps.ethnicity</field>
        <field name="arch" type="xml">
            <search string="Ethnicities">
                <field name="name"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="aps_ethnicity_action" model="ir.actions.act_window">
        <field name="name">Ethnicities</field>
        <field name="res_model">aps.ethnicity</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="aps_ethnicity_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first ethnicity.
            </p>
        </field>
    </record>

</odoo>
