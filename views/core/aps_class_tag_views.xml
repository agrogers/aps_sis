<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_aps_class_tag_list" model="ir.ui.view">
        <field name="name">aps.class.tag.list</field>
        <field name="model">aps.class.tag</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="color" widget="color"/>
            </list>
        </field>
    </record>

    <record id="view_aps_class_tag_form" model="ir.ui.view">
        <field name="name">aps.class.tag.form</field>
        <field name="model">aps.class.tag</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_aps_class_tag" model="ir.actions.act_window">
        <field name="name">Class Tags</field>
        <field name="res_model">aps.class.tag</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>