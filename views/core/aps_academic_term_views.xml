<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="aps_academic_term_view_list" model="ir.ui.view">
        <field name="name">aps.academic.term.list</field>
        <field name="model">aps.academic.term</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="short_name" optional="show"/>
                <field name="academic_year_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="aps_academic_term_view_form" model="ir.ui.view">
        <field name="name">aps.academic.term.form</field>
        <field name="model">aps.academic.term</field>
        <field name="arch" type="xml">
            <form string="Academic Term">
                <div class="alert alert-info" role="alert">
                    <strong>Academic Terms</strong> are subdivisions of an <strong>Academic Year</strong> (e.g. Term 1, Semester 2).
                    They define the start and end dates for each reporting or teaching period within the year.
                </div>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Term 1 2025-2026"/>
                        </h1>
                        <h2>
                            <field name="short_name" placeholder="Short Name (e.g. T1-25)"/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="academic_year_id"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="aps_academic_term_view_search" model="ir.ui.view">
        <field name="name">aps.academic.term.search</field>
        <field name="model">aps.academic.term</field>
        <field name="arch" type="xml">
            <search string="Academic Terms">
                <field name="name"/>
                <field name="short_name"/>
                <field name="academic_year_id"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Academic Year" name="group_year" context="{'group_by': 'academic_year_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="aps_academic_term_action" model="ir.actions.act_window">
        <field name="name">Academic Terms</field>
        <field name="res_model">aps.academic.term</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="aps_academic_term_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first academic term (e.g. Term 1 2025-2026).
            </p>
        </field>
    </record>

</odoo>
