<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <menuitem id="menu_op_school_main"
              name="Students"
              parent="openeducat_core.menu_op_school_root"
              sequence="10"
              action="openeducat_core.act_open_op_student_view"
              groups="openeducat_core.group_op_faculty"/>

    <menuitem id="students_list_menu"
              name="Students"
              parent="menu_op_school_main"
              sequence="10"
              action="openeducat_core.act_open_op_student_view"
              groups="openeducat_core.group_op_faculty"/>


    <!-- Add Subject Registration menu under Students -->
    <menuitem id="subject_registration_student_menu"
              name="Subject Registration"
              parent="menu_op_school_main"
              sequence="30"
              action="openeducat_core.act_subject_registration_view"
              groups="openeducat_core.group_op_back_office_admin,openeducat_core.group_op_faculty"/>

    <!-- Add Student Course Detail menu under Students -->
    <menuitem id="student_course_menu"
              name="Student Course Detail"
              parent="menu_op_school_main"
              sequence="40"
              action="openeducat_core.act_open_op_student_course_view"
              groups="openeducat_core.group_op_back_office_admin,openeducat_core.group_op_faculty"/>

    <!-- Override the action to change the name -->
    <record model="ir.actions.act_window" id="openeducat_core.act_open_op_course_view">
        <field name="name">Academic Levels</field>
    </record>

    <!-- Override the menu item to move it under SIS main menu -->
    <menuitem id="openeducat_core.menu_op_course_sub"
              parent="openeducat_core.menu_op_school_root"
              name="Academic Levels"/>

    <!-- Deactivate the original Students menu from core -->
    <menuitem id="openeducat_core.menu_op_school_main" active="false"/>

    <!-- APS SIS Menu Structure -->
    <menuitem id="menu_aps_root" name="APS SIS" sequence="10" web_icon="/aps_sis/static/src/img/menu_icon.png" groups="aps_sis.group_aps_teacher,aps_sis.group_aps_student,base.group_system"/>
    <menuitem id="menu_aps_tasks" name="Academic Tasks" parent="menu_aps_root" action="action_aps_resources" sequence="10" groups="aps_sis.group_aps_teacher,aps_sis.group_aps_student,base.group_system"/>
    <menuitem id="menu_aps_task_list" name="Tasks" parent="menu_aps_tasks" action="action_aps_resource_tasks" sequence="25" groups="aps_sis.group_aps_teacher,aps_sis.group_aps_student,base.group_system"/>
    <menuitem id="menu_aps_resources" name="Resources" parent="menu_aps_tasks" action="action_aps_resources" sequence="10" groups="aps_sis.group_aps_teacher,aps_sis.group_aps_student,base.group_system"/>
    <menuitem id="menu_aps_resource_types" name="Resource Types" parent="menu_aps_tasks" action="action_aps_resource_types" sequence="15" groups="aps_sis.group_aps_teacher,base.group_system"/>
    <menuitem id="menu_aps_submissions" name="Submissions" parent="menu_aps_tasks" action="action_aps_resource_submissions" sequence="30" groups="aps_sis.group_aps_teacher,aps_sis.group_aps_student,base.group_system"/>
    <menuitem id="menu_aps_submissions_students" name="My Submissions" parent="menu_aps_tasks" action="action_aps_resource_submissions_for_students" sequence="30" groups="aps_sis.group_aps_teacher,aps_sis.group_aps_student,base.group_system"/>

</odoo>