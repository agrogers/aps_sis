<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <menuitem id="menu_op_school_main"
              name="Students"
              parent="openeducat_core.menu_op_school_root"
              sequence="10"
              action="openeducat_core.act_open_op_student_view"
              groups="openeducat_core.group_op_faculty"/>

    <menuitem id="students_list_menu"
              name="Students"
              parent="menu_op_school_main"
              sequence="10"
              action="openeducat_core.act_open_op_student_view"
              groups="openeducat_core.group_op_faculty"/>


    <!-- Add Subject Registration menu under Students -->
    <menuitem id="subject_registration_student_menu"
              name="Subject Registration"
              parent="menu_op_school_main"
              sequence="30"
              action="openeducat_core.act_subject_registration_view"
              groups="openeducat_core.group_op_back_office_admin,openeducat_core.group_op_faculty"/>

    <!-- Add Student Course Detail menu under Students -->
    <menuitem id="student_course_menu"
              name="Student Course Detail"
              parent="menu_op_school_main"
              sequence="40"
              action="openeducat_core.act_open_op_student_course_view"
              groups="openeducat_core.group_op_back_office_admin,openeducat_core.group_op_faculty"/>

    <!-- Override the action to change the name -->
    <record model="ir.actions.act_window" id="openeducat_core.act_open_op_course_view">
        <field name="name">Academic Levels</field>
    </record>

    <!-- Override the menu item to move it under SIS main menu -->
    <menuitem id="openeducat_core.menu_op_course_sub"
              parent="openeducat_core.menu_op_school_root"
              name="Academic Levels"/>

    <!-- Deactivate the original Students menu from core -->
    <menuitem id="openeducat_core.menu_op_school_main" active="false"/>

    <!-- APS SIS Menu Structure -->
    <menuitem id="menu_apex_root" name="APEX" sequence="10" web_icon="aps_sis,static/description/icon.png" groups="aps_sis.group_aps_teacher,aps_sis.group_aps_student"/>

    <menuitem id="menu_apex_submissions" name="Submissions" parent="menu_apex_root" action="action_aps_resource_submissions" sequence="10" groups="aps_sis.group_aps_teacher"/>
    <menuitem id="menu_apex_submissions2" name="Submissions" parent="menu_apex_submissions" action="action_aps_resource_submissions" sequence="30" groups="aps_sis.group_aps_teacher"/>
    <menuitem id="menu_apex_submissions_students" name="Student Submissions" parent="menu_apex_submissions" action="action_aps_resource_submissions_for_students" sequence="30" groups="aps_sis.group_aps_teacher"/>
    <menuitem id="menu_apex_submissions_score" name="Enter Scores" parent="menu_apex_submissions" action="action_aps_resource_submissions_score" sequence="40" groups="aps_sis.group_aps_teacher"/>
    <menuitem id="menu_apex_task_list" name="Tasks" parent="menu_apex_submissions" action="action_aps_resource_tasks" sequence="250" groups="aps_sis.group_aps_teacher"/>

    <menuitem id="menu_apex_configuration" name="Configuration" parent="menu_apex_root" action="action_aps_resources" sequence="10" groups="aps_sis.group_aps_teacher"/>
    <menuitem id="menu_apex_resources" name="Resources" parent="menu_apex_configuration" action="action_aps_resources" sequence="10" groups="aps_sis.group_aps_teacher"/>
    <menuitem id="menu_apex_resource_types" name="Resource Types" parent="menu_apex_configuration" action="action_aps_resource_types" sequence="15" groups="aps_sis.group_aps_teacher"/>    
    <menuitem id="menu_apex_resource_tags" name="Resource Tags" parent="menu_apex_configuration" action="action_aps_resource_tags" sequence="16" groups="aps_sis.group_aps_teacher"/>    
    
    <menuitem id="menu_apex_resource_custom_names" name="Custom Names" parent="menu_apex_configuration" action="action_aps_resource_custom_names" sequence="200" groups="aps_sis.group_aps_teacher"/>
    <!-- Student Menus -->
    <menuitem id="menu_apex_submissions_students_root_menu" name="My Submissions" parent="menu_apex_root" action="action_aps_resource_submissions_for_students" sequence="30" groups="aps_sis.group_aps_student"/>
    <menuitem id="menu_apex_task_list_student" name="Tasks" parent="menu_apex_root" action="action_aps_resource_tasks" sequence="40" groups="aps_sis.group_aps_student"/>

</odoo>