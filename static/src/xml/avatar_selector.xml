<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<!-- ─── Field Widget (30px badge) ─── -->
<t t-name="aps_sis.AvatarSelectorField">
    <div class="o_field_avatar_selector"
         t-on-click="openPicker"
         style="position:absolute;top:-4px;right:-4px;z-index:2;cursor:pointer;">
        <t t-if="imageUrl">
            <img t-att-src="imageUrl"
                 class="rounded-circle"
                 style="width:40px;height:40px;object-fit:cover;background:#fff;border:3px solid #fff;box-shadow:0 0 0 1px #dee2e6;"
                 t-att-title="avatarName"/>
        </t>
        <t t-else="">
            <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm"
                 style="width:40px;height:40px;background:#f8f9fa;border:2px dashed #adb5bd;"
                 title="Choose Avatar">
                <i class="fa fa-user-circle-o text-muted" style="font-size:14px;"/>
            </div>
        </t>
    </div>
</t>

<!-- ─── Picker Dialog ─── -->
<t t-name="aps_sis.AvatarPickerDialog">
    <Dialog title="'Choose Your Avatar'" size="'xl'">
        <div class="d-flex" style="min-height:450px;max-height:65vh;">
            <!-- Category sidebar -->
            <div class="border-end overflow-auto" style="min-width:170px;">
                <div class="list-group list-group-flush">
                    <button type="button"
                            class="list-group-item list-group-item-action"
                            t-att-class="{'active': !state.activeCat}"
                            t-on-click="showAll">
                        <i class="fa fa-th-large me-1"/>All
                    </button>
                    <t t-foreach="state.categories" t-as="cat" t-key="cat.id">
                        <button type="button"
                                class="list-group-item list-group-item-action"
                                t-att-class="{'active': state.activeCat === cat.id}"
                                t-on-click="() => this.filterCategory(cat.id)">
                            <t t-esc="cat.name"/>
                        </button>
                    </t>
                </div>
            </div>

            <!-- Avatar grid -->
            <div class="flex-grow-1 d-flex flex-column ps-3 overflow-hidden">
                <input type="text" class="form-control mb-3"
                       placeholder="Search avatars…"
                       t-on-input="onSearch"/>
                <div class="flex-grow-1 overflow-auto">
                    <div class="row g-2" t-if="state.filtered.length">
                        <t t-foreach="state.filtered" t-as="av" t-key="av.id">
                            <div class="col-4 col-sm-3 col-lg-2">
                                <div role="button"
                                     class="card h-100 text-center"
                                     t-att-class="av.id === props.currentId ? 'border-primary border-2 shadow-sm' : ''"
                                     t-on-click="() => this.pick(av)">
                                    <img t-att-src="imageUrl(av.id)"
                                         class="card-img-top p-1"
                                         style="height:90px;object-fit:contain;"
                                         loading="lazy"/>
                                    <div class="card-body p-1">
                                        <small class="text-truncate d-block"
                                               t-att-title="av.name"
                                               t-esc="av.name"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                    <div t-else="" class="text-center text-muted py-5">
                        <i class="fa fa-search fa-2x d-block mb-2" style="opacity:.3;"/>
                        <p>No avatars found.</p>
                    </div>
                </div>
            </div>
        </div>
        <t t-set-slot="footer">
            <button t-if="props.currentId" class="btn btn-outline-secondary"
                    t-on-click="clear">
                <i class="fa fa-times me-1"/>Remove Avatar
            </button>
            <button class="btn btn-secondary" t-on-click="props.close">Cancel</button>
        </t>
    </Dialog>
</t>

</templates>
