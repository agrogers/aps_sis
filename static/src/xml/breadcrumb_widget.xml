<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!--
        BreadcrumbField template.

        Renders the display_name_breadcrumb JSON field as a row of badge pills
        separated by clickable arrows.  Each arrow can open a dropdown of sibling
        resources (children of the preceding parent) allowing quick navigation.

        The arrow style changes when clicked/active.

        OWL 2 t-foreach provides: {name}, {name}_index, {name}_first, {name}_last.
        The outer font-size is driven by the widget's `size` option.
    -->
    <t t-name="aps_sis.BreadcrumbField">
        <div class="o_breadcrumb_pills d-flex flex-wrap align-items-center gap-1"
             t-att-style="props.size ? 'font-size: ' + props.size + ';' : ''"
             t-ref="widgetRoot">
            <t t-foreach="breadcrumbs" t-as="crumb" t-key="crumb.id or crumb_index">
                <!-- Arrow separator with dropdown (not before the first pill) -->
                <t t-if="!crumb_first">
                    <div class="breadcrumb-arrow-wrapper position-relative">
                        <!-- 
                            The arrow is clickable.  crumb_index gives us the position of
                            this crumb; the parent is at crumb_index - 1.
                        -->
                        <button type="button"
                                class="breadcrumb-arrow-btn btn btn-link p-0 mx-1"
                                t-att-class="(state.dropdownOpenIndex === crumb_index ? 'active' : '') + (state.arrowHasSiblings[crumb_index] ? '' : ' no-siblings')"
                                t-att-data-arrow-index="crumb_index"
                                t-att-title="state.arrowHasSiblings[crumb_index] ? 'Show sibling resources' : ''"
                                t-on-click.stop.prevent="onArrowClick"
                                aria-haspopup="listbox"
                                t-att-aria-expanded="state.dropdownOpenIndex === crumb_index ? 'true' : 'false'">
                            <!-- Use solid icon when siblings exist (clickable), outline  otherwise -->
                            <img t-if="state.arrowHasSiblings[crumb_index]"
                                 src="/aps_sis/static/src/img/play_solid.svg"
                                 class="breadcrumb-arrow-icon"
                                 t-att-class="state.dropdownOpenIndex === crumb_index ? 'breadcrumb-arrow-open' : ''"
                                 alt=""
                                 aria-hidden="true"/>
                            <img t-else=""
                                 src="/aps_sis/static/src/img/play_outline.svg"
                                 class="breadcrumb-arrow-icon breadcrumb-arrow-no-siblings"
                                 alt=""
                                 aria-hidden="true"/>
                        </button>

                        <!-- Sibling dropdown panel -->
                        <div t-if="state.dropdownOpenIndex === crumb_index"
                             class="breadcrumb-sibling-dropdown"
                             role="listbox"
                             aria-label="Sibling resources">
                            <!-- Loading state -->
                            <div t-if="state.loading"
                                 class="breadcrumb-sibling-item breadcrumb-sibling-loading">
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                Loading&#8230;
                            </div>
                            <t t-else="">
                                <!-- Empty state -->
                                <div t-if="!state.siblings.length"
                                     class="breadcrumb-sibling-item breadcrumb-sibling-empty text-muted">
                                    No sibling resources
                                </div>
                                <!-- Sibling entries -->
                                <a t-foreach="state.siblings"
                                   t-as="sibling"
                                   t-key="sibling.id"
                                   href="#"
                                   class="breadcrumb-sibling-item"
                                   role="option"
                                   t-att-title="sibling.name"
                                   t-att-data-res-id="sibling.id"
                                   t-on-click.stop.prevent="onSiblingClick">
                                    <t t-esc="sibling.name"/>
                                </a>
                            </t>
                        </div>
                    </div>
                </t>

                <!-- Ancestor pill — clickable link -->
                <t t-if="!crumb_last and crumb.id">
                    <a href="#"
                       class="breadcrumb-pill breadcrumb-pill-ancestor badge rounded-pill text-decoration-none"
                       t-att-title="'Go to: ' + crumb.label"
                       t-att-data-res-id="crumb.id"
                       t-on-click.stop.prevent="onAncestorClick">
                        <t t-esc="crumb.label"/>
                    </a>
                </t>

                <!-- Non-last pill without an id — plain text badge -->
                <t t-elif="!crumb_last">
                    <span class="breadcrumb-pill breadcrumb-pill-ancestor badge rounded-pill"
                          t-att-title="crumb.label">
                        <t t-esc="crumb.label"/>
                    </span>
                </t>

                <!-- Current (last) resource pill — clickable if has children, plain otherwise -->
                <t t-else="">
                    <!-- Has children → show clickable button with dropdown -->
                    <t t-if="state.hasChildren">
                        <div class="breadcrumb-pill-wrapper position-relative">
                            <button type="button"
                                    class="breadcrumb-pill breadcrumb-pill-current breadcrumb-pill-current-btn badge rounded-pill"
                                    t-att-class="state.childrenDropdownOpen ? 'active' : ''"
                                    t-att-title="'Show child resources'"
                                    t-on-click.stop.prevent="onCurrentClick"
                                    aria-haspopup="listbox"
                                    t-att-aria-expanded="state.childrenDropdownOpen ? 'true' : 'false'">
                                <t t-esc="crumb.label"/>
                                <span class="breadcrumb-children-caret ms-1" aria-hidden="true">▾</span>
                            </button>

                            <!-- Children dropdown panel -->
                            <div t-if="state.childrenDropdownOpen"
                                 class="breadcrumb-sibling-dropdown breadcrumb-children-dropdown"
                                 role="listbox"
                                 aria-label="Child resources">
                                <!-- Loading state -->
                                <div t-if="state.childrenLoading"
                                     class="breadcrumb-sibling-item breadcrumb-sibling-loading">
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    Loading&#8230;
                                </div>
                                <t t-else="">
                                    <!-- Child entries -->
                                    <a t-foreach="state.children"
                                       t-as="child"
                                       t-key="child.id"
                                       href="#"
                                       class="breadcrumb-sibling-item"
                                       role="option"
                                       t-att-title="child.name"
                                       t-att-data-res-id="child.id"
                                       t-on-click.stop.prevent="onChildClick">
                                        <t t-esc="child.name"/>
                                    </a>
                                </t>
                            </div>
                        </div>
                    </t>
                    <!-- No children → plain non-interactive pill -->
                    <t t-else="">
                        <span class="breadcrumb-pill breadcrumb-pill-current badge rounded-pill"
                              t-att-title="crumb.label">
                            <t t-esc="crumb.label"/>
                        </span>
                    </t>
                </t>
            </t>
        </div>
    </t>
</templates>
