<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!--
        BreadcrumbField template.

        Renders the display_name_breadcrumb JSON field as a row of badge pills
        separated by 🢒 arrows.  Ancestor pills are clickable links; the final
        pill (the current resource) shows a caret indicator and opens a sibling-
        resource dropdown when clicked (if a parent exists in the breadcrumb).

        OWL 2 t-foreach provides: {name}, {name}_index, {name}_first, {name}_last.
        We use crumb_last to identify the current resource (last segment).
        The outer font-size is driven by the widget's `size` option.
    -->
    <t t-name="aps_sis.BreadcrumbField">
        <div class="o_breadcrumb_pills d-flex flex-wrap align-items-center gap-1"
             t-att-style="props.size ? 'font-size: ' + props.size + ';' : ''">
            <t t-foreach="breadcrumbs" t-as="crumb" t-key="crumb.id or crumb.label">
                <!-- Arrow separator (not before the first pill) -->
                <t t-if="!crumb_first">
                    <span class="breadcrumb-pills-arrow mx-1 text-muted" aria-hidden="true">🢒</span>
                </t>

                <!-- Ancestor pill — clickable link -->
                <t t-if="!crumb_last and crumb.id">
                    <a href="#"
                       class="breadcrumb-pill breadcrumb-pill-ancestor badge rounded-pill text-decoration-none"
                       t-att-title="'Go to: ' + crumb.label"
                       t-on-click.stop.prevent="() => this.openResource(crumb.id)">
                        <t t-esc="crumb.label"/>
                    </a>
                </t>

                <!-- Non-last pill without an id — plain text badge -->
                <t t-elif="!crumb_last">
                    <span class="breadcrumb-pill breadcrumb-pill-ancestor badge rounded-pill"
                          t-att-title="crumb.label">
                        <t t-esc="crumb.label"/>
                    </span>
                </t>

                <!-- Current (last) resource pill — clickable sibling dropdown when a parent exists -->
                <t t-else="">
                    <div class="breadcrumb-pill-wrapper" t-ref="siblingDropdown">
                        <!-- Has a parent → show caret and enable sibling dropdown -->
                        <t t-if="parentId">
                            <button type="button"
                                    class="breadcrumb-pill breadcrumb-pill-current breadcrumb-pill-current-btn badge rounded-pill"
                                    t-att-title="'Click to see sibling resources'"
                                    t-on-click="toggleSiblingDropdown"
                                    aria-haspopup="listbox"
                                    t-att-aria-expanded="state.dropdownOpen ? 'true' : 'false'">
                                <t t-esc="crumb.label"/>
                                <span class="breadcrumb-sibling-caret" aria-hidden="true">&#x25BE;</span>
                            </button>
                        </t>
                        <!-- No parent → plain non-interactive pill -->
                        <t t-else="">
                            <span class="breadcrumb-pill breadcrumb-pill-current badge rounded-pill"
                                  t-att-title="crumb.label">
                                <t t-esc="crumb.label"/>
                            </span>
                        </t>

                        <!-- Sibling dropdown panel -->
                        <div t-if="state.dropdownOpen"
                             class="breadcrumb-sibling-dropdown"
                             role="listbox"
                             aria-label="Sibling resources">
                            <!-- Loading state -->
                            <div t-if="state.loading"
                                 class="breadcrumb-sibling-item breadcrumb-sibling-empty">
                                Loading&#8230;
                            </div>
                            <t t-else="">
                                <!-- Empty state -->
                                <div t-if="!state.siblings.length"
                                     class="breadcrumb-sibling-item breadcrumb-sibling-empty">
                                    No sibling resources
                                </div>
                                <!-- Sibling entries -->
                                <a t-foreach="state.siblings"
                                   t-as="sibling"
                                   t-key="sibling.id"
                                   href="#"
                                   class="breadcrumb-sibling-item"
                                   role="option"
                                   t-att-title="sibling.name"
                                   t-on-click.prevent.stop="(ev) => this.openSibling(sibling.id)">
                                    <t t-esc="sibling.name"/>
                                </a>
                            </t>
                        </div>
                    </div>
                </t>
            </t>
        </div>
    </t>
</templates>
