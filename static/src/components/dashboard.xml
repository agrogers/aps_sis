<templates xml:space="preserve">
    <t t-name="apex_dashboard.Dashboard" owl="1">
        <div class="vh-100 overflow-auto bg-muted p-4">
            <div class="row mb-4 align-items-center justify-content-between bg-white shadow-sm p-4 mx-0 rounded">
                <div class="col-md-3">
                    <h1 class="text-primary fw-bold mb-0">APEX Dashboard</h1>
                    <!-- <small class="text-muted" t-esc="selectedPeriodText"/> -->
                </div>
                <div class="col-md-3">
                    <select class="form-select" t-model="state.period" t-on-change="onChangePeriod">
                        <option value="0">Select Period</option>
                        <option value="7">Last 7 Days</option>
                        <option value="14">Last 14 Days</option>
                        <option value="30">Last 30 Days</option>
                        <option value="90">Last 90 Days</option>
                        <option value="180">Last 6 Months</option>
                        <option value="270">Last 9 Months</option>
                        <option value="365">Last Year</option>
                    </select>
                </div>
                <div class="col-md-3" t-if="state.isFaculty">
                    <select class="form-select" t-model="state.selectedStudent" t-on-change="onChangeStudent">
                        <option value="false" t-if="state.students.length > 1">All Students</option>
                        <t t-foreach="state.students" t-as="student" t-key="student.id">
                            <option t-att-value="student.id" t-esc="student.name"/>
                        </t>
                    </select>
                </div>
                <div class="col-md-3">
                    <select class="form-select" t-model="state.selectedSubjectCategory" t-on-change="onChangeSubjectCategory">
                        <option value="false">All Categories</option>
                        <t t-foreach="state.subjectCategories" t-as="cat" t-key="cat.id">
                            <option t-att-value="cat.id" t-esc="cat.name"/>
                        </t>
                    </select>
                </div>
            </div>

            <div class="row mb-4">
                <t t-if="state.loadingKPIs">
                    <div class="col-lg-3 col-md-6 mb-3">
                        <div class="bg-white shadow-sm p-4 rounded h-100 d-flex align-items-center justify-content-center">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6 mb-3">
                        <div class="bg-white shadow-sm p-4 rounded h-100 d-flex align-items-center justify-content-center">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6 mb-3">
                        <div class="bg-white shadow-sm p-4 rounded h-100 d-flex align-items-center justify-content-center">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6 mb-3">
                        <div class="bg-white shadow-sm p-4 rounded h-100 d-flex align-items-center justify-content-center">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                </t>
                <t t-else="">
                    <KpiGauge name="'Rank'" value="state.student_rank.value" 
                             total_students="state.student_rank.total_students" 
                             points_from_next="state.student_rank.points_from_next" icon="'fa-trophy'" 
                             period_name="state.period_name"
                             max="state.student_rank.max"
                             onClick=""/>
                    <KpiGauge name="'Points'" value="state.student_points.value" 
                             percentage="state.student_points.percentage" icon="'fa-tasks'" 
                             period_name="state.period_name"
                             max="state.student_points.max"
                             onClick="() => this.viewPointsSubmissions()"/>
                             
                    <KpiGauge name="'Overdue Items'" value="state.overdue.value" 
                             period_name="state.period_name"
                             max="state.overdue.max"
                             onClick="() => this.viewOverdueSubmissions()"/>
                    <KpiGauge name="'All Overdue Items'" value="state.alloverdue.value" 
                             percentage="state.alloverdue.percentage"  
                             period_name="'All Time'"
                             max="state.alloverdue.max"
                             onClick="() => this.viewAllOverdueSubmissions()"/>
                </t>
            </div>

            <!-- Second row of KPIs -->
            <div class="row mb-2">
                <t t-if="state.loadingKPIs">
                    <div class="col-lg-3 col-md-6 mb-3">
                        <div class="bg-white shadow-sm p-4 rounded h-100 d-flex align-items-center justify-content-center">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6 mb-3">
                        <div class="bg-white shadow-sm p-4 rounded h-100 d-flex align-items-center justify-content-center">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6 mb-3">
                        <div class="bg-white shadow-sm p-4 rounded h-100 d-flex align-items-center justify-content-center">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6 mb-3">
                        <div class="bg-white shadow-sm p-4 rounded h-100 d-flex align-items-center justify-content-center">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                </t>
                <t t-else="">
                    <KpiCard name="'Active Tasks'" value="state.submissions.value" 
                             percentage="state.submissions.percentage" icon="'fa-tasks'" 
                             period_name="state.period_name"
                             onClick="() => this.viewActiveSubmissions()"/>
                    <KpiCard name="'Coming Due'" value="state.next_7_days.value" 
                             percentage="state.next_7_days.percentage" icon="'fa-cubes'" 
                             period_name="'in the next 7 days'"
                             onClick="() => this.viewNext7DaysSubmissions()"/>
                    <KpiCard name="'Total Submitted'" value="state.total_submitted.value" 
                             percentage="state.total_submitted.percentage" icon="'fa-clock-o'" 
                             period_name="state.period_name"
                             onClick="() => this.viewTotalSubmitted()"/>
                    <KpiCard name="'Due Status'" 
                             late="state.due_status_kpi.late"
                             on_time="state.due_status_kpi.on_time"
                             early="state.due_status_kpi.early"
                             period_name="state.period_name"
                             onClickLate="() => this.viewDueStatusSubmissions('late')"
                             onClickOnTime="() => this.viewDueStatusSubmissions('on-time')"
                             onClickEarly="() => this.viewDueStatusSubmissions('early')"/>
                </t>
            </div>

            <!-- Leaderboard -->
            <div class="row mb-4">
                <div class="col-12">
                    <div class="bg-white shadow-sm p-4 rounded">
                        <h3 class="fw-bold mb-1">🏆 Top 9 Leaderboard (<t t-raw="state.period_name"/>)</h3>
                        <p class="text-muted">Points are awarded for completed work and early submissions.</p>
                        <t t-if="state.loadingLeaderboard">
                            <div class="d-flex justify-content-center align-items-center" style="height: 170px;">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading leaderboard...</span>
                                </div>
                            </div>
                        </t>
                        <t t-elif="!state.leaderboardData or state.leaderboardData.length === 0">
                            <div class="d-flex justify-content-center align-items-center" style="height: 170px;">
                                <p class="text-muted">No leaderboard data available for this period</p>
                            </div>
                        </t>
                        <t t-else="">
                            <Leaderboard entries="state.leaderboardData" isFaculty="state.isFaculty" currentUserPartnerId="user.partnerId" selectedStudentPartnerId="state.selectedStudent"/>
                        </t>
                    </div>
                </div>
            </div>

            <!-- Progress Leaderboard -->
            <div class="row mb-4">
                <div class="col-12">
                    <div class="bg-white shadow-sm p-4 rounded">
                        <h3 class="fw-bold mb-1">📈 Progress Leaderboard</h3>
                        <p class="text-muted">How much of the IGCSE course you have completed. Try to stay in the <span style="background: #dee2e6; border-radius:3px; padding: 0px 3px 3px 3px">gray zone</span>.</p>
                        <t t-if="state.loadingProgressLeaderboard">
                            <div class="d-flex justify-content-center align-items-center" style="height: 170px;">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading progress leaderboard...</span>
                                </div>
                            </div>
                        </t>
                        <t t-elif="!state.progressLeaderboardData or state.progressLeaderboardData.length === 0">
                            <div class="d-flex justify-content-center align-items-center" style="height: 170px;">
                                <p class="text-muted">No progress leaderboard data available</p>
                            </div>
                        </t>
                        <t t-else="">
                            <Leaderboard entries="state.progressLeaderboardData" displayLimit="30" valueSuffix="'%'" isFaculty="state.isFaculty" trackMode="'progress'" redlinePercent="state.redlineForToday" pacePercent="state.paceForToday" currentUserPartnerId="user.partnerId" selectedStudentPartnerId="state.selectedStudent"/>
                        </t>
                    </div>
                </div>
            </div>

            <!-- Completion Leaderboard Prediction -->
            <div class="row mb-4">
                <div class="col-12">
                    <div class="bg-white shadow-sm p-4 rounded">
                        <h3 class="fw-bold mb-1">🎯 Completion Prediction Leaderboard</h3>
                         <p class="text-muted">This is how much of the IGCSE course we predict you will complete by
                            <t t-if="state.completionDeadline"><b><t t-esc="state.completionDeadline"/></b></t>
                            <t t-else="">the end of the course</t>
                            based on your current pace. Try to stay in the <span style="background: #27a143b6; border-radius:3px; padding: 0px 3px 3px 3px">green zone</span>.</p>
                        <t t-if="state.loadingCompletionLeaderboard">
                            <div class="d-flex justify-content-center align-items-center" style="height: 170px;">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading completion leaderboard...</span>
                                </div>
                            </div>
                        </t>
                        <t t-elif="!state.completionLeaderboardData or state.completionLeaderboardData.length === 0">
                            <div class="d-flex justify-content-center align-items-center" style="height: 170px;">
                                <p class="text-muted">No completion prediction data available</p>
                            </div>
                        </t>
                        <t t-else="">
                            <Leaderboard entries="state.completionLeaderboardData" displayLimit="30" valueSuffix="'%'" isFaculty="state.isFaculty" trackMode="'completion'" currentUserPartnerId="user.partnerId" selectedStudentPartnerId="state.selectedStudent"/>
                        </t>
                    </div>
                </div>
            </div>

            <!-- Progress Tracking Row -->
            <div class="row mb-4">
                <div class="col-lg-6 mb-4">
                    <div class="bg-white shadow-sm rounded p-4">
                        <h3 class="fw-bold mb-1">Current Progress by Subject</h3>
                        <p class="text-muted">The dark coloured bar indicates the progress made in the last 4 months.</p>
                        <t t-if="state.loadingProgress">
                            <div class="d-flex justify-content-center align-items-center" style="height: 300px;">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading progress...</span>
                                </div>
                            </div>
                        </t>
                        <t t-elif="!state.selectedStudent or state.selectedStudent === 'false'">
                            <div class="d-flex justify-content-center align-items-center" style="height: 300px;">
                                <p class="text-muted">Select a student to view progress</p>
                            </div>
                        </t>
                        <t t-elif="state.progressBarData.length === 0">
                            <div class="d-flex justify-content-center align-items-center" style="height: 300px;">
                                <p class="text-muted">No progress data available</p>
                            </div>
                        </t>
                        <t t-else="">
                            <div style="height: 350px; position: relative;">
                                <canvas t-ref="progressBarChart"></canvas>
                            </div>
                        </t>
                    </div>
                </div>
                <div class="col-lg-6 mb-4">
                    <div class="bg-white shadow-sm p-4 rounded h-100">
                        <h3 class="fw-bold mb-3">Submissions by Day</h3>
                        <t t-if="state.loadingCharts">
                            <div class="d-flex justify-content-center align-items-center" style="height: 300px;">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading chart...</span>
                                </div>
                            </div>
                        </t>
                        <t t-else="">
                            <ChartRenderer type="'bar'" title="" data="state.chartData" />
                        </t>
                    </div>
                </div>

            </div>

            <div class="row">
                <div class="col-lg-6 mb-4">
                    <div class="bg-white shadow-sm p-4 rounded h-100">
                        <h3 class="fw-bold mb-3">Subject Progress Over Time</h3>
                        <t t-if="state.loadingProgress">
                            <div class="d-flex justify-content-center align-items-center" style="height: 300px;">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading progress...</span>
                                </div>
                            </div>
                        </t>
                        <t t-elif="!state.selectedStudent or state.selectedStudent === 'false'">
                            <div class="d-flex justify-content-center align-items-center" style="height: 300px;">
                                <p class="text-muted">Select a student to view progress</p>
                            </div>
                        </t>
                        <t t-elif="state.progressLineData.length === 0">
                            <div class="d-flex justify-content-center align-items-center" style="height: 300px;">
                                <p class="text-muted">No progress data available</p>
                            </div>
                        </t>
                        <t t-else="">
                            <div style="height: 350px; position: relative;">
                                <canvas t-ref="progressLineChart"></canvas>
                            </div>
                        </t>
                    </div>
                </div>
                <div class="col-lg-6 mb-4">
                    <div class="bg-white shadow-sm p-4 rounded h-100">
                        <h3 class="fw-bold mb-3">Tasks by Due Status</h3>
                        <t t-if="state.loadingDoughnuts">
                            <div class="d-flex justify-content-center align-items-center" style="height: 300px;">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading chart...</span>
                                </div>
                            </div>
                        </t>
                        <t t-else="">
                            <ChartRenderer type="'doughnut'" title="" data="state.doughnutData2" />
                        </t>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-lg-6 mb-4">
                    <div class="bg-white shadow-sm p-4 rounded h-100">
                        <h3 class="fw-bold mb-3">Submission over Time</h3>
                        <t t-if="state.loadingCharts">
                            <div class="d-flex justify-content-center align-items-center" style="height: 300px;">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading chart...</span>
                                </div>
                            </div>
                        </t>
                        <t t-else="">
                            <ChartRenderer type="'line'" title="" data="state.chartDataCummulative" />
                        </t>
                    </div>
                </div>
                <div class="col-lg-6 mb-4">
                    <div class="bg-white shadow-sm p-4 rounded h-100">
                        <h3 class="fw-bold mb-3">Tasks Assigned by Subject</h3>
                        <t t-if="state.loadingDoughnuts">
                            <div class="d-flex justify-content-center align-items-center" style="height: 300px;">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading chart...</span>
                                </div>
                            </div>
                        </t>
                        <t t-else="">
                            <ChartRenderer type="'doughnut'" title="" data="state.doughnutData" />
                        </t>
                    </div>
                </div>
            </div>

            <!-- Student Comparison Chart - Only for Teachers -->
                        <t t-if="state.isFaculty">
            <div class="row">
                <div class="col-12 mb-4">
                    <div class="bg-white shadow-sm p-4 rounded">
                            <h3 class="fw-bold mb-3">Student Progress Comparison by Subject</h3>
                            <t t-if="state.loadingStudentComparison">
                                <div class="d-flex justify-content-center align-items-center" style="height: 450px;">
                                    <div class="spinner-border text-primary" role="status">
                                        <span class="visually-hidden">Loading comparison data...</span>
                                    </div>
                                </div>
                            </t>
                            <t t-elif="!state.studentComparisonData || !state.studentComparisonData.datasets || state.studentComparisonData.datasets.length === 0">
                                <div class="d-flex justify-content-center align-items-center" style="height: 600px;">
                                    <p class="text-muted">No comparison data available</p>
                                </div>
                            </t>
                            <t t-else="">
                                <div style="height: 800px; position: relative;">
                                    <canvas t-ref="studentComparisonChart"></canvas>
                                </div>
                            </t>
                    </div>
                </div>
            </div>
                        </t>
        </div>
    </t>
</templates>