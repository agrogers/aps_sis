<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
<t t-name="aps_sis.VoteAnalysisDashboard" owl="1">
<div class="o_vote_analysis_dashboard h-100 overflow-auto p-4">

    <div class="d-flex align-items-center justify-content-between mb-3 px-2">
        <div class="d-flex align-items-center">
            <i class="fa fa-bar-chart fa-2x me-3"/>
            <div>
                <h1 class="mb-0 fw-bold ">Vote Analysis</h1>
                <small class="text-muted">Award votes per recipient, broken down by series</small>
            </div>
        </div>
        <div class="d-flex align-items-center gap-2">
            <div class="input-group input-group-sm">
                <select class="form-select form-select-sm"
                        t-on-change="onPresetSelect"
                        style="max-width: 180px;">
                    <option value="" t-att-selected="state.activePresetId === null">
                        -- New Preset --
                    </option>
                    <t t-foreach="state.presets" t-as="preset" t-key="preset.id">
                        <option t-att-value="preset.id"
                                t-esc="preset.name"
                                t-att-selected="state.activePresetId === preset.id"/>
                    </t>
                </select>
                <input t-if="state.activePresetId === null"
                       type="text"
                       class="form-control form-control-sm"
                       placeholder="Preset name..."
                       t-att-value="state.activePresetName"
                       t-on-input="onPresetNameInput"
                       style="max-width: 140px;"/>
                <button class="btn btn-primary btn-sm"
                        t-on-click="onPresetSave"
                        t-att-disabled="(state.activePresetId === null &amp;&amp; !state.activePresetName.trim()) || state.savingPreset"
                        t-att-title="state.activePresetId ? 'Update preset' : 'Save new preset'">
                    <i t-att-class="state.savingPreset ? 'fa fa-spinner fa-spin' : 'fa fa-save'"/>
                </button>
                <button class="btn btn-outline-danger btn-sm"
                        t-on-click="onPresetDelete"
                        t-att-disabled="!state.activePresetId"
                        title="Delete preset">
                    <i class="fa fa-trash"/>
                </button>
            </div>
            <button type="button"
                    class="btn btn-outline-primary btn-sm"
                    t-att-class="{'active': state.filtersOpen}"
                    t-on-click="toggleFilters"
                    style="min-width: 100px;">
                <i class="fa fa-filter me-1"/>
                Filters
                <i t-att-class="state.filtersOpen ? 'fa fa-chevron-up ms-1' : 'fa fa-chevron-down ms-1'"/>
            </button>
        </div>
    </div>

    <div t-if="state.filtersOpen" class="card mb-3 o_vote_analysis_filters_panel">
        <div class="card-body py-2">
            <div class="row align-items-end g-2">
                <div class="col-auto">
                    <label class="form-label small mb-0">Series</label>
                    <select class="form-select form-select-sm" t-on-change="onSeriesByChange"
                            t-att-value="state.seriesBy" style="max-width: 150px;">
                        <option value="round">Vote Round</option>
                        <option value="category">Category</option>
                        <option value="sub_category">Sub Category</option>
                        <option value="voting_set">Vote Set</option>
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label small mb-0">Order</label>
                    <select class="form-select form-select-sm" t-on-change="onChartOrderChange"
                            t-att-value="state.chartOrder" style="max-width: 140px;">
                        <option value="value_desc">Most Votes</option>
                        <option value="value_asc">Least Votes</option>
                        <option value="name_asc">Name A-Z</option>
                        <option value="name_desc">Name Z-A</option>
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label small mb-0">Compare</label>
                    <select class="form-select form-select-sm" t-on-change="onOverlayChange"
                            t-att-value="state.overlay" style="max-width: 130px;">
                        <option value="none">None</option>
                        <option value="certificates">Certificates</option>
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label small mb-0">From</label>
                    <input type="date" class="form-control form-control-sm"
                           t-att-value="state.dateFrom" t-on-change="onDateFromChange"/>
                </div>
                <div class="col-auto">
                    <label class="form-label small mb-0">To</label>
                    <input type="date" class="form-control form-control-sm"
                           t-att-value="state.dateTo" t-on-change="onDateToChange"/>
                </div>
                <div class="col-auto o_vote_analysis_mrs_filter">
                    <label class="form-label small mb-0">Category</label>
                    <MultiRecordSelector
                        resModel="'aps.award.category'"
                        resIds="state.selectedCategoryIds"
                        update.bind="(resIds) => this.onCategoriesUpdate(resIds)"
                        placeholder="'Search categories...'"/>
                </div>
                <div class="col-auto">
                    <button class="btn btn-outline-secondary btn-sm mt-4" t-on-click="clearAllFilters">
                        <i class="fa fa-times me-1"/>Clear
                    </button>
                </div>
            </div>
            <div class="row align-items-end g-2 mt-1">
                <div class="col-auto">
                    <label class="form-label small mb-0">Recipient Type</label>
                    <select class="form-select form-select-sm" t-on-change="onRecipientTypeChange"
                            t-att-value="state.recipientType" style="max-width: 150px;">
                        <option value="all">All</option>
                        <option value="student">Students</option>
                        <option value="staff">Staff</option>
                    </select>
                </div>
                <t t-if="state.recipientType === 'student'">
                    <div class="col-auto o_vote_analysis_mrs_filter">
                        <label class="form-label small mb-0">Levels</label>
                        <MultiRecordSelector
                            resModel="'aps.level'"
                            resIds="state.selectedLevelIds"
                            update.bind="(resIds) => this.onLevelsUpdate(resIds)"
                            placeholder="'Search levels...'"/>
                    </div>
                </t>
                <t t-if="state.recipientType === 'staff'">
                    <div class="col-auto o_vote_analysis_mrs_filter">
                        <label class="form-label small mb-0">Departments</label>
                        <MultiRecordSelector
                            resModel="'hr.department'"
                            resIds="state.selectedDepartmentIds"
                            update.bind="(resIds) => this.onDepartmentsUpdate(resIds)"
                            placeholder="'Search departments...'"/>
                    </div>
                </t>
                <div class="col-auto o_vote_analysis_mrs_filter">
                    <label class="form-label small mb-0">Recipient</label>
                    <MultiRecordSelector
                        resModel="'res.partner'"
                        resIds="state.selectedRecipientIds"
                        update.bind="(resIds) => this.onRecipientsUpdate(resIds)"
                        placeholder="'Search recipients...'"
                        domain="state.recipientDomain"/>
                </div>
            </div>
        </div>
    </div>

    <!-- Loading -->
    <div t-if="state.loading" class="text-center py-5">
        <i class="fa fa-spinner fa-spin fa-2x text-muted"/>
        <p class="text-muted mt-2">Loading data...</p>
    </div>

    <!-- No data -->
    <div t-if="state.loading === false &amp;&amp; state.recipients.length === 0" class="text-center py-5">
        <i class="fa fa-inbox fa-3x text-muted"/>
        <p class="text-muted mt-3">No vote data found. Try adjusting the filters.</p>
    </div>

    <!-- Tabbed content -->
    <t t-if="state.loading === false &amp;&amp; state.recipients.length > 0">

        <!-- Tab bar -->
        <ul class="nav nav-tabs mb-3">
            <li class="nav-item">
                <a class="nav-link" t-att-class="{'active': state.activeTab === 'chart'}"
                   t-on-click="() => this.onTabChange('chart')" href="#">
                    <i class="fa fa-bar-chart me-1"/>Chart
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" t-att-class="{'active': state.activeTab === 'data'}"
                   t-on-click="() => this.onTabChange('data')" href="#">
                    <i class="fa fa-table me-1"/>Chart Data
                </a>
            </li>
            <li class="nav-item" t-if="state.detailRecipient">
                <a class="nav-link" t-att-class="{'active': state.activeTab === 'details'}"
                   t-on-click="() => this.onTabChange('details')" href="#">
                    <i class="fa fa-list me-1"/>Vote Details
                </a>
            </li>
            <li class="nav-item" t-if="state.certDetailRecipient">
                <a class="nav-link" t-att-class="{'active': state.activeTab === 'certs'}"
                   t-on-click="() => this.onTabChange('certs')" href="#">
                    <i class="fa fa-certificate me-1"/>Certificates
                </a>
            </li>
        </ul>

        <!-- Tab 1: Chart (always in DOM so canvas ref stays valid) -->
        <div t-att-class="state.activeTab === 'chart' ? 'o_chart_tab' : 'o_chart_tab d-none'">
            <div class="card">
                <div class="card-body o_vote_analysis_chart_body">
                    <canvas t-ref="chart"/>
                </div>
            </div>
        </div>

        <!-- Tab 2: Chart Data Table -->
        <div t-if="state.activeTab === 'data'">
            <div class="card o_vote_analysis_table_card">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <div>
                        <strong>Vote Breakdown by Recipient</strong>
                        <span class="text-muted small ms-2" t-esc="state.recipients.length + ' recipients'"/>
                    </div>
                    <span class="badge text-bg-light border">
                        Click column headers to sort
                    </span>
                </div>
                <div class="table-responsive o_vote_analysis_table_wrap">
                    <table class="table table-striped table-hover align-middle mb-0 o_vote_analysis_table">
                        <thead class="table-light">
                            <tr>
                                <th class="o_vote_analysis_th o_vote_analysis_th_name"
                                    t-att-class="{'o_vote_analysis_th_active': isSortedColumn('name')}"
                                    t-on-click="() => this.onSort('name')">
                                    <span class="o_vote_analysis_th_label">
                                        Recipient
                                        <i t-att-class="getSortIconClass('name')"/>
                                    </span>
                                </th>
                                <t t-foreach="state.series" t-as="ser" t-key="ser.id">
                                    <th class="o_vote_analysis_th text-center"
                                        t-att-class="{'o_vote_analysis_th_active': isSortedColumn(ser.id)}"
                                        t-on-click="() => this.onSort(ser.id)">
                                        <span class="o_vote_analysis_th_label">
                                            <t t-esc="ser.name"/>
                                            <i t-att-class="getSortIconClass(ser.id)"/>
                                        </span>
                                    </th>
                                </t>
                                <th class="o_vote_analysis_th text-center o_vote_analysis_th_total"
                                    t-att-class="{'o_vote_analysis_th_active': isSortedColumn('total')}"
                                    t-on-click="() => this.onSort('total')">
                                    <span class="o_vote_analysis_th_label">
                                        Total
                                        <i t-att-class="getSortIconClass('total')"/>
                                    </span>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="sortedRecipients" t-as="rec" t-key="rec.id">
                                <tr>
                                    <td class="o_vote_analysis_td_name">
                                        <span class="o_vote_analysis_recipient_name" t-esc="rec.name"/>
                                    </td>
                                    <t t-foreach="state.series" t-as="ser" t-key="ser.id">
                                        <td class="text-center">
                                            <t t-set="voteCount" t-value="getRecipientVoteCount(ser.id, rec)"/>
                                            <span t-if="voteCount" class="o_vote_analysis_vote_pill o_vote_analysis_pill_clickable"
                                                  t-esc="voteCount"
                                                  t-on-click="() => this.onTableCellClick(rec, ser.id)"/>
                                            <span t-else="" class="text-muted">—</span>
                                        </td>
                                    </t>
                                    <td class="text-center">
                                        <span class="o_vote_analysis_total_badge o_vote_analysis_pill_clickable"
                                              t-esc="rec.total"
                                              t-on-click="() => this.onTotalClick(rec)"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Tab 3: Vote Details (drill-down) -->
        <div t-if="state.activeTab === 'details' &amp;&amp; state.detailRecipient">
            <div class="card o_vote_analysis_detail_card">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <div>
                        <strong><t t-esc="state.detailHeader"/></strong>
                        <span class="text-muted small ms-2" t-esc="state.detailVotes.length + ' votes'"/>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-outline-success btn-sm"
                                t-on-click="loadSelectedCerts"
                                t-att-disabled="state.selectedVoteIds.length === 0">
                            <i class="fa fa-certificate me-1"/>
                            <t t-esc="'Show Certificates (' + state.selectedVoteIds.length + ')'"/>
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" t-on-click="() => clearDetail()">
                            <i class="fa fa-times me-1"/>Close
                        </button>
                    </div>
                </div>
                <div t-if="state.detailLoading" class="text-center py-3">
                    <i class="fa fa-spinner fa-spin text-muted"/>
                    <span class="text-muted ms-2">Loading details...</span>
                </div>
                <div class="va-grid-container" t-ref="voteDetailsGrid"/>
                <!-- Selected certificates panel -->
                <div t-if="state.selectedVoteIds.length > 0 &amp;&amp; (state.selectedCerts.length > 0 || state.selectedCertsLoading)">
                    <div class="card-header">
                        <strong>Certificates for selected votes</strong>
                        <span class="text-muted small ms-2" t-esc="state.selectedCerts.length + ' certificates'"/>
                    </div>
                    <div t-if="state.selectedCertsLoading" class="text-center py-3">
                        <i class="fa fa-spinner fa-spin text-muted"/>
                        <span class="text-muted ms-2">Loading certificates...</span>
                    </div>
                    <div t-else="" class="table-responsive">
                        <table class="table table-striped table-hover table-sm align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Event</th>
                                    <th>Category</th>
                                    <th class="text-center">Date Awarded</th>
                                    <th>Template</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="state.selectedCerts" t-as="cert" t-key="cert.id">
                                    <tr>
                                        <td><strong t-esc="cert.event"/></td>
                                        <td t-esc="cert.award_category_name"/>
                                        <td class="text-center small" t-esc="cert.date_awarded"/>
                                        <td class="small text-muted" t-esc="cert.certificate_template_name"/>
                                    </tr>
                                </t>
                                <tr t-if="state.selectedCerts.length === 0">
                                    <td colspan="4" class="text-center text-muted py-3">
                                        No certificates found.
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab 4: Certificates (drill-down from certificate line) -->
        <div t-if="state.activeTab === 'certs' &amp;&amp; state.certDetailRecipient">
            <div class="card o_vote_analysis_detail_card">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <div>
                        <strong><t t-esc="state.certDetailHeader"/></strong>
                        <span class="text-muted small ms-2" t-esc="state.certDetailList.length + ' certificates'"/>
                    </div>
                    <button class="btn btn-outline-secondary btn-sm" t-on-click="() => clearCertDetail()">
                        <i class="fa fa-times me-1"/>Close
                    </button>
                </div>
                <div t-if="state.certDetailLoading" class="text-center py-3">
                    <i class="fa fa-spinner fa-spin text-muted"/>
                    <span class="text-muted ms-2">Loading certificates...</span>
                </div>
                <div t-else="" class="table-responsive o_vote_analysis_table_wrap">
                    <table class="table table-striped table-hover table-sm align-middle mb-0 o_vote_analysis_table">
                        <thead class="table-light">
                            <tr>
                                <th>Event</th>
                                <th>Category</th>
                                <th class="text-center">Date Awarded</th>
                                <th>Template</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.certDetailList" t-as="cert" t-key="cert.id">
                                <tr>
                                    <td><strong t-esc="cert.event"/></td>
                                    <td t-esc="cert.award_category_name"/>
                                    <td class="text-center small" t-esc="cert.date_awarded"/>
                                    <td class="small text-muted" t-esc="cert.certificate_template_name"/>
                                </tr>
                            </t>
                            <tr t-if="state.certDetailList.length === 0">
                                <td colspan="4" class="text-center text-muted py-3">
                                    No certificates found for this recipient.
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </t>

</div>
</t>
</templates>
