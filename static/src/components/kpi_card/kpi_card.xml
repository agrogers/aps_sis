<t t-name="apex_dashboard.KpiCard" owl="1">
    <div class="col-lg-3 col-md-6 " t-att-id="'KPI-' + props.name" t-on-click="props.onClick">
        <div class="bg-white shadow-sm p-4 rounded text-center cursor-pointer h-100" t-on-click="props.onClick">
            <div class="text-muted fw-bold h5" t-esc="props.name"/>
            <div class="display-5 fw-bold my-2" t-att-class="props.value > 0 and props.name.includes('Overdue') ? 'text-danger' : 'text-dark'" t-esc="props.value"/>
            <!-- <div t-attf-class="h6 fw-bold #{props.percentage >= 0 ? 'text-success' : 'text-danger'}"> -->
            <div class="fs-6 text-primary">
                <t t-if="props.name === 'Rank'">
                    <small>out of <t t-esc="props.total_students || 0"/></small>
                </t>
                <t t-else="">
                    <small t-esc="props.period_name"/>
                </t>
            </div>
        </div>
    </div>
</t>