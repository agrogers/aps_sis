<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="aps_sis.ResourceNotesDialog">
        <Dialog title="props.resourceName" size="'xl'" contentClass="'rht_notes_dialog_content'">
            <t t-if="state.loading">
                <div class="d-flex justify-content-center align-items-center p-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading…</span>
                    </div>
                </div>
            </t>
            <t t-elif="!state.notes">
                <div class="p-4 text-muted text-center">
                    <i class="fa fa-file-text-o fa-2x mb-2 opacity-50"/>
                    <p>No notes available for this resource.</p>
                </div>
            </t>
            <t t-else="">
                <div class="rht_notes_body aui-image-viewer-scope p-3"
                    t-ref="notesBody"
                    t-att-data-image-viewer-model="'aps.resources'"
                    t-att-data-image-viewer-id="props.resourceId"
                    t-att-data-image-viewer-field="'notes'">
                    <t t-out="notesMarkup"/>
                </div>
            </t>
        </Dialog>
    </t>

</templates>
