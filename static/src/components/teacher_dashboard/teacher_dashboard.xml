<templates xml:space="preserve">
    <t t-name="aps_sis.TeacherDashboard" owl="1">
        <div class="aps-teacher-dashboard vh-100 overflow-auto bg-light p-4">

            <!-- ==================== FILTERS ==================== -->
            <div class="row mb-3 align-items-center bg-white shadow-sm p-2 mx-0 rounded">
                <div class="col-md-6 mt-2">
                    <h1 class="text-primary fw-bold mb-0">
                        <img src="/aps_sis/static/src/img/dashboard.svg"
                             class="aps-dashboard-title-icon me-2"
                             alt="Dashboard"/>
                        <i class="fa fa-chalkboard-teacher me-2"/>Teacher Dashboard
                    </h1>
                </div>
                <div class="col-md-3 mt-2">
                    <label class="form-label fw-semibold mb-1">Subject Category</label>
                    <select class="form-select" t-on-change="onChangeCategory">
                        <option value="">All Categories</option>
                        <t t-foreach="state.categories" t-as="cat" t-key="cat.id">
                            <option t-att-value="cat.id"
                                    t-att-selected="state.categoryId === cat.id">
                                <t t-esc="cat.name"/>
                            </option>
                        </t>
                    </select>
                </div>
                <div class="col-md-3 mt-2">
                    <label class="form-label fw-semibold mb-1">Date Range</label>
                    <select class="form-select" t-on-change="onChangeDays">
                        <t t-foreach="dateRangeOptions" t-as="opt" t-key="opt.value">
                            <option t-att-value="opt.value"
                                    t-att-selected="state.days === opt.value">
                                <t t-esc="opt.label"/>
                            </option>
                        </t>
                    </select>
                </div>
            </div>

            <!-- Loading spinner -->
            <t t-if="state.loading">
                <div class="d-flex justify-content-center align-items-center" style="height:300px;">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading…</span>
                    </div>
                </div>
            </t>

            <t t-else="">

                <!-- ==================== TWO-COLUMN ROW ==================== -->
                <div class="row g-4 mb-3">

                    <!-- COLUMN 2: Assigned Resources -->
                    <div class="col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-header bg-white fw-bold">
                                <i class="fa fa-tasks me-2 text-success"/>
                                Assigned Resources
                                <span class="badge bg-secondary ms-2">
                                    <t t-esc="state.taskResources.length"/>
                                </span>
                                <span class="text-muted small fw-normal ms-2">(click row for submissions)</span>
                            </div>
                            <t t-if="state.taskResources.length === 0">
                                <div class="card-body text-muted">No assigned resources found for the selected filters.</div>
                            </t>
                            <t t-else="">
                                <div class="aps-dashboard-scroll-list">
                                    <table class="table table-sm table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th></th>
                                                <th>Name</th>
                                                <th>Oldest Assigned</th>
                                                <th>Submissions</th>
                                                <th>Overdue</th>
                                                <th>Avg Score</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="state.taskResources" t-as="tr_" t-key="tr_.id">
                                                <tr t-att-class="state.selectedResourceId === tr_.id ? 'table-primary' : ''"
                                                    class="aps-resource-row">
                                                    <td class="aps-icon-cell">
                                                        <t t-if="tr_.type_icon">
                                                            <img t-att-src="binaryIconUrl(tr_.type_icon)"
                                                                 class="aps-type-icon"
                                                                 alt=""/>
                                                        </t>
                                                        <t t-else="">
                                                            <i class="fa fa-file-o aps-type-icon-placeholder"/>
                                                        </t>
                                                    </td>
                                                    <td class="fw-semibold">
                                                        <a href="#" 
                                                           t-on-click.prevent="() => this.selectResource(tr_.id, tr_.name)"
                                                           class="aps-resource-link">
                                                            <t t-esc="tr_.name"/>
                                                        </a>
                                                    </td>
                                                    <td class="small"><t t-esc="tr_.oldest_date_assigned or '—'"/></td>
                                                    <td><t t-esc="tr_.total_submissions"/></td>
                                                    <td>
                                                        <t t-if="tr_.overdue_count > 0">
                                                            <span class="badge bg-danger"><t t-esc="tr_.overdue_count"/></span>
                                                        </t>
                                                        <t t-else="">0</t>
                                                    </td>
                                                    <td>
                                                        <t t-if="tr_.avg_score">
                                                            <span t-att-class="'aps-score-pill ' + scoreColorClass(tr_.avg_score)">
                                                                <t t-esc="tr_.avg_score"/>%
                                                            </span>
                                                        </t>
                                                        <t t-else="">—</t>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </t>
                        </div>
                    </div>

                    <!-- COLUMN 1: Subject Resources -->
                    <div class="col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-header bg-white fw-bold">
                                <i class="fa fa-book me-2 text-primary"/>
                                Subject &amp; Recently Edited Resources
                                <span class="badge bg-secondary ms-2">
                                    <t t-esc="state.subjectResources.length"/>
                                </span>
                            </div>
                            <t t-if="state.subjectResources.length === 0">
                                <div class="card-body text-muted">No resources found for the selected filters.</div>
                            </t>
                            <t t-else="">
                                <div class="aps-dashboard-scroll-list">
                                    <table class="table table-sm table-hover mb-0">
                                        <tbody>
                                            <t t-foreach="state.subjectResources" t-as="res" t-key="res.id">
                                                <tr class="aps-resource-row">
                                                    <td class="aps-icon-cell">
                                                        <t t-if="res.type_id">
                                                            <img t-att-src="typeIconUrl(res.type_id)"
                                                                 class="aps-type-icon"
                                                                 alt=""
                                                                 t-att-title="res.type_id[1] or ''"/>
                                                        </t>
                                                        <t t-else="">
                                                            <i class="fa fa-file-o aps-type-icon-placeholder"/>
                                                        </t>
                                                    </td>
                                                    <td class="fw-semibold aps-resource-name">
                                                        <a t-att-href="getResourceUrl(res.id)" 
                                                           t-on-click.prevent="() => this.openResource(res.id)"
                                                           class="aps-resource-link">
                                                            <t t-esc="res.display_name"/>
                                                        </a>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </t>
                        </div>
                    </div>

                </div><!-- end two-column row -->

                <!-- ==================== SUBMISSIONS FOR SELECTED RESOURCE ==================== -->
                <t t-if="state.selectedResourceId">
                    <div class="card shadow-sm mb-3">
                        <div class="card-header bg-white fw-bold d-flex justify-content-between align-items-center">
                            <div>
                                <i class="fa fa-list-alt me-2 text-warning"/>
                                Submissions — <t t-esc="state.selectedResourceName or 'Selected Resource'"/>
                            </div>
                            <a t-att-href="getSubmissionsUrl(state.selectedResourceId)" 
                               t-on-click.prevent="openAllSubmissions"
                               class="btn btn-sm btn-outline-primary">
                                <i class="fa fa-external-link me-1"></i>View All
                            </a>
                        </div>

                        <t t-if="state.submissionsLoading">
                            <div class="card-body d-flex justify-content-center align-items-center" style="height:150px;">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading…</span>
                                </div>
                            </div>
                        </t>
                        <t t-elif="state.submissions.length === 0">
                            <div class="card-body text-muted">No submissions found for this resource in the selected period.</div>
                        </t>
                        <t t-else="">
                            <div class="table-responsive">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th></th>
                                            <th>Student</th>
                                            <th>Status</th>
                                            <th>Date Assigned</th>
                                            <th>Date Due</th>
                                            <th>Date Submitted</th>
                                            <th>Score %</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="state.submissions" t-as="sub" t-key="sub.id">
                                            <tr>
                                                <td class="aps-icon-cell">
                                                    <t t-if="sub.type_icon">
                                                        <img t-att-src="binaryIconUrl(sub.type_icon)"
                                                             class="aps-type-icon"
                                                             alt=""/>
                                                    </t>
                                                    <t t-else="">
                                                        <i class="fa fa-file-o aps-type-icon-placeholder"/>
                                                    </t>
                                                </td>
                                                <td><t t-esc="sub.student_id ? sub.student_id[1] : '—'"/></td>
                                                <td>
                                                    <span t-att-class="'badge ' + stateBadgeClass(sub.state)">
                                                        <t t-esc="stateLabel(sub.state)"/>
                                                    </span>
                                                </td>
                                                <td class="small"><t t-esc="sub.date_assigned or '—'"/></td>
                                                <td class="small"><t t-esc="sub.date_due or '—'"/></td>
                                                <td class="small"><t t-esc="sub.date_submitted or '—'"/></td>
                                                <td>
                                                    <t t-if="sub.result_percent">
                                                        <span t-att-class="'aps-score-pill ' + scoreColorClass(sub.result_percent)">
                                                            <t t-esc="sub.result_percent"/>%
                                                        </span>
                                                    </t>
                                                    <t t-else="">—</t>
                                                </td>
                                                <td>
                                                    <a t-att-href="getSubmissionUrl(sub.id)" 
                                                       t-on-click.prevent="() => this.openSubmission(sub.id)"
                                                       class="btn btn-outline-primary btn-sm">
                                                        <i class="fa fa-eye me-1"></i>View
                                                    </a>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>
                    </div>
                </t>

            </t>
        </div>
    </t>
</templates>
