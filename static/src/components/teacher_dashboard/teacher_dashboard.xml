<templates xml:space="preserve">
    <t t-name="aps_sis.TeacherDashboard" owl="1">
        <div class="aps-teacher-dashboard vh-100 overflow-auto bg-light p-4">

            <!-- ==================== FILTERS ==================== -->
            <div class="row mb-4 align-items-center bg-white shadow-sm p-3 mx-0 rounded">
                <div class="col-12 mb-2">
                    <h1 class="text-primary fw-bold mb-0">
                        <i class="fa fa-chalkboard-teacher me-2"/>Teacher Dashboard
                    </h1>
                </div>

                <!-- Category filter -->
                <div class="col-md-4 mt-2">
                    <label class="form-label fw-semibold mb-1">Subject Category</label>
                    <select class="form-select" t-on-change="onChangeCategory">
                        <option value="">All Categories</option>
                        <t t-foreach="state.categories" t-as="cat" t-key="cat.id">
                            <option t-att-value="cat.id"
                                    t-att-selected="state.categoryId === cat.id">
                                <t t-esc="cat.name"/>
                            </option>
                        </t>
                    </select>
                </div>

                <!-- Date range filter -->
                <div class="col-md-4 mt-2">
                    <label class="form-label fw-semibold mb-1">Date Range</label>
                    <select class="form-select" t-on-change="onChangeDays">
                        <t t-foreach="dateRangeOptions" t-as="opt" t-key="opt.value">
                            <option t-att-value="opt.value"
                                    t-att-selected="state.days === opt.value">
                                <t t-esc="opt.label"/>
                            </option>
                        </t>
                    </select>
                </div>
            </div>

            <!-- Loading spinner -->
            <t t-if="state.loading">
                <div class="d-flex justify-content-center align-items-center" style="height:300px;">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading…</span>
                    </div>
                </div>
            </t>

            <t t-else="">

                <!-- ==================== SECTION 3: SUBJECT / EDIT RESOURCES ==================== -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white fw-bold">
                        <i class="fa fa-book me-2 text-primary"/>
                        Subject &amp; Recently Edited Resources
                        <span class="badge bg-secondary ms-2">
                            <t t-esc="state.subjectResources.length"/>
                        </span>
                    </div>

                    <t t-if="state.subjectResources.length === 0">
                        <div class="card-body text-muted">No resources found for the selected filters.</div>
                    </t>
                    <t t-else="">
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Name</th>
                                        <th>Type</th>
                                        <th>Subjects</th>
                                        <th>Last Modified</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.subjectResources" t-as="res" t-key="res.id">
                                        <tr>
                                            <td><t t-esc="res.name"/></td>
                                            <td>
                                                <t t-if="res.type_id">
                                                    <span class="badge bg-info text-dark">
                                                        <t t-esc="res.type_id[1]"/>
                                                    </span>
                                                </t>
                                            </td>
                                            <td>
                                                <t t-if="res.subjects and res.subjects.length">
                                                    <span class="text-muted small">
                                                        <t t-esc="res.subjects.length"/> subject(s)
                                                    </span>
                                                </t>
                                            </td>
                                            <td class="text-muted small"><t t-esc="res.write_date or ''"/></td>
                                            <td>
                                                <button class="btn btn-outline-primary btn-sm"
                                                        t-on-click="() => this.openResource(res.id)">
                                                    <i class="fa fa-eye me-1"/>View
                                                </button>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </t>
                </div>

                <!-- ==================== SECTION 4: ASSIGNED RESOURCES ==================== -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white fw-bold">
                        <i class="fa fa-tasks me-2 text-success"/>
                        Assigned Resources
                        <span class="badge bg-secondary ms-2">
                            <t t-esc="state.taskResources.length"/>
                        </span>
                        <span class="text-muted small fw-normal ms-2">(click a row to view submissions)</span>
                    </div>

                    <t t-if="state.taskResources.length === 0">
                        <div class="card-body text-muted">No assigned resources found for the selected filters.</div>
                    </t>
                    <t t-else="">
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Name</th>
                                        <th>Oldest Date Assigned</th>
                                        <th>No. Submissions</th>
                                        <th>No. Overdue</th>
                                        <th>Avg Score</th>
                                        <th>Most Recent Assignment</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.taskResources" t-as="tr_" t-key="tr_.id">
                                        <tr t-att-class="state.selectedResourceId === tr_.id ? 'table-primary' : ''"
                                            style="cursor:pointer;"
                                            t-on-click="() => this.selectResource(tr_.id, tr_.name)">
                                            <td class="fw-semibold"><t t-esc="tr_.name"/></td>
                                            <td><t t-esc="tr_.oldest_date_assigned or '—'"/></td>
                                            <td><t t-esc="tr_.total_submissions"/></td>
                                            <td>
                                                <t t-if="tr_.overdue_count > 0">
                                                    <span class="badge bg-danger"><t t-esc="tr_.overdue_count"/></span>
                                                </t>
                                                <t t-else="">0</t>
                                            </td>
                                            <td>
                                                <t t-if="tr_.avg_score">
                                                    <t t-esc="tr_.avg_score"/>%
                                                </t>
                                                <t t-else="">—</t>
                                            </td>
                                            <td class="text-muted small"><t t-esc="tr_.most_recent_date_assigned or '—'"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </t>
                </div>

                <!-- ==================== SECTION 5: SUBMISSIONS FOR SELECTED RESOURCE ==================== -->
                <t t-if="state.selectedResourceId">
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-white fw-bold">
                            <i class="fa fa-list-alt me-2 text-warning"/>
                            Submissions — <t t-esc="state.selectedResourceName"/>
                        </div>

                        <t t-if="state.submissionsLoading">
                            <div class="card-body d-flex justify-content-center align-items-center" style="height:150px;">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading…</span>
                                </div>
                            </div>
                        </t>
                        <t t-elif="state.submissions.length === 0">
                            <div class="card-body text-muted">No submissions found for this resource in the selected period.</div>
                        </t>
                        <t t-else="">
                            <div class="table-responsive">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Name</th>
                                            <th>Student</th>
                                            <th>Status</th>
                                            <th>Date Assigned</th>
                                            <th>Date Due</th>
                                            <th>Date Submitted</th>
                                            <th>Score %</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="state.submissions" t-as="sub" t-key="sub.id">
                                            <tr>
                                                <td><t t-esc="sub.display_name"/></td>
                                                <td><t t-esc="sub.student_id ? sub.student_id[1] : '—'"/></td>
                                                <td>
                                                    <span t-att-class="'badge ' + stateBadgeClass(sub.state)">
                                                        <t t-esc="stateLabel(sub.state)"/>
                                                    </span>
                                                </td>
                                                <td class="small"><t t-esc="sub.date_assigned or '—'"/></td>
                                                <td class="small"><t t-esc="sub.date_due or '—'"/></td>
                                                <td class="small"><t t-esc="sub.date_submitted or '—'"/></td>
                                                <td>
                                                    <t t-if="sub.result_percent">
                                                        <t t-esc="sub.result_percent"/>%
                                                    </t>
                                                    <t t-else="">—</t>
                                                </td>
                                                <td>
                                                    <button class="btn btn-outline-primary btn-sm"
                                                            t-on-click="() => this.openSubmission(sub.id)">
                                                        <i class="fa fa-eye me-1"/>View
                                                    </button>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>
                    </div>
                </t>

            </t>
        </div>
    </t>
</templates>
