<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
<t t-name="aps_sis.SchoolMgmtDashboard" owl="1">
<div class="smd-dashboard vh-100 overflow-auto p-4">

    <!-- Header -->
    <div class="smd-header d-flex align-items-center mb-4 px-2">
        <i class="fa fa-university fa-2x text-primary me-3"/>
        <div>
            <h1 class="mb-0 fw-bold text-primary">School Management</h1>
            <small class="text-muted">Quick access to all core school records</small>
        </div>
    </div>

    <!-- Section: Academic Calendar -->
    <div class="smd-section mb-4">
        <h5 class="smd-section-title text-uppercase text-muted fw-semibold mb-3 px-1">
            <i class="fa fa-calendar me-2"/>Academic Calendar
        </h5>
        <div class="row g-3">
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="smd-card card" t-on-click="() => this.open('aps_sis.aps_academic_year_action')">
                    <div class="smd-card-icon bg-primary-subtle text-primary">
                        <i class="fa fa-calendar-check-o"/>
                    </div>
                    <div class="smd-card-body">
                        <div class="smd-card-title">Academic Years</div>
                        <div class="smd-card-count" t-esc="this.count('aps.academic.year')"/>
                    </div>
                    <i class="fa fa-chevron-right smd-card-arrow text-muted"/>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="smd-card card" t-on-click="() => this.open('aps_sis.aps_academic_term_action')">
                    <div class="smd-card-icon bg-info-subtle text-info">
                        <i class="fa fa-bookmark"/>
                    </div>
                    <div class="smd-card-body">
                        <div class="smd-card-title">Academic Terms</div>
                        <div class="smd-card-count" t-esc="this.count('aps.academic.term')"/>
                    </div>
                    <i class="fa fa-chevron-right smd-card-arrow text-muted"/>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="smd-card card" t-on-click="() => this.open('aps_sis.aps_academic_week_action')">
                    <div class="smd-card-icon bg-success-subtle text-success">
                        <i class="fa fa-th"/>
                    </div>
                    <div class="smd-card-body">
                        <div class="smd-card-title">Academic Weeks</div>
                        <div class="smd-card-count" t-esc="this.count('aps.academic.week')"/>
                    </div>
                    <i class="fa fa-chevron-right smd-card-arrow text-muted"/>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="smd-card card" t-on-click="() => this.open('aps_sis.aps_school_calendar_action')">
                    <div class="smd-card-icon bg-warning-subtle text-warning">
                        <i class="fa fa-calendar"/>
                    </div>
                    <div class="smd-card-body">
                        <div class="smd-card-title">School Calendar</div>
                        <div class="smd-card-count" t-esc="this.count('aps.school.calendar')"/>
                    </div>
                    <i class="fa fa-chevron-right smd-card-arrow text-muted"/>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="smd-card card" t-on-click="() => this.open('aps_sis.aps_timetable_entry_action')">
                    <div class="smd-card-icon bg-primary-subtle text-primary">
                        <i class="fa fa-table"/>
                    </div>
                    <div class="smd-card-body">
                        <div class="smd-card-title">School Timetable</div>
                        <div class="smd-card-count" t-esc="this.count('aps.timetable.entry')"/>
                    </div>
                    <i class="fa fa-chevron-right smd-card-arrow text-muted"/>
                </div>
            </div>
        </div>
    </div>

    <!-- Section: People -->
    <div class="smd-section mb-4">
        <h5 class="smd-section-title text-uppercase text-muted fw-semibold mb-3 px-1">
            <i class="fa fa-users me-2"/>People
        </h5>
        <div class="row g-3">
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="smd-card card" t-on-click="() => this.open('aps_sis.aps_teacher_action')">
                    <div class="smd-card-icon bg-primary-subtle text-primary">
                        <i class="fa fa-chalkboard-teacher"/>
                    </div>
                    <div class="smd-card-body">
                        <div class="smd-card-title">Teachers</div>
                        <div class="smd-card-count" t-esc="this.count('aps.teacher')"/>
                    </div>
                    <i class="fa fa-chevron-right smd-card-arrow text-muted"/>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="smd-card card" t-on-click="() => this.open('aps_sis.aps_student_action')">
                    <div class="smd-card-icon bg-success-subtle text-success">
                        <i class="fa fa-graduation-cap"/>
                    </div>
                    <div class="smd-card-body">
                        <div class="smd-card-title">Students</div>
                        <div class="smd-card-count" t-esc="this.count('aps.student')"/>
                    </div>
                    <i class="fa fa-chevron-right smd-card-arrow text-muted"/>
                </div>
            </div>
        </div>
    </div>

    <!-- Section: Structure -->
    <div class="smd-section mb-4">
        <h5 class="smd-section-title text-uppercase text-muted fw-semibold mb-3 px-1">
            <i class="fa fa-sitemap me-2"/>Structure
        </h5>
        <div class="row g-3">
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="smd-card card" t-on-click="() => this.open('aps_sis.aps_level_action')">
                    <div class="smd-card-icon bg-secondary-subtle text-secondary">
                        <i class="fa fa-layer-group"/>
                    </div>
                    <div class="smd-card-body">
                        <div class="smd-card-title">Academic Levels</div>
                        <div class="smd-card-count" t-esc="this.count('aps.level')"/>
                    </div>
                    <i class="fa fa-chevron-right smd-card-arrow text-muted"/>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="smd-card card" t-on-click="() => this.open('aps_sis.action_aps_subject_categories')">
                    <div class="smd-card-icon bg-warning-subtle text-warning">
                        <i class="fa fa-tags"/>
                    </div>
                    <div class="smd-card-body">
                        <div class="smd-card-title">Subject Categories</div>
                        <div class="smd-card-count" t-esc="this.count('aps.subject.category')"/>
                    </div>
                    <i class="fa fa-chevron-right smd-card-arrow text-muted"/>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="smd-card card" t-on-click="() => this.open('aps_sis.aps_subject_action')">
                    <div class="smd-card-icon bg-info-subtle text-info">
                        <i class="fa fa-book"/>
                    </div>
                    <div class="smd-card-body">
                        <div class="smd-card-title">Subjects</div>
                        <div class="smd-card-count" t-esc="this.count('aps.subject')"/>
                    </div>
                    <i class="fa fa-chevron-right smd-card-arrow text-muted"/>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="smd-card card" t-on-click="() => this.open('aps_sis.aps_class_action')">
                    <div class="smd-card-icon bg-danger-subtle text-danger">
                        <i class="fa fa-door-open"/>
                    </div>
                    <div class="smd-card-body">
                        <div class="smd-card-title">Classes</div>
                        <div class="smd-card-count" t-esc="this.count('aps.class')"/>
                    </div>
                    <i class="fa fa-chevron-right smd-card-arrow text-muted"/>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="smd-card card" t-on-click="() => this.open('aps_sis.aps_student_class_action')">
                    <div class="smd-card-icon bg-primary-subtle text-primary">
                        <i class="fa fa-user-plus"/>
                    </div>
                    <div class="smd-card-body">
                        <div class="smd-card-title">Enrollments</div>
                        <div class="smd-card-count" t-esc="this.count('aps.student.class')"/>
                    </div>
                    <i class="fa fa-chevron-right smd-card-arrow text-muted"/>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="smd-card card" t-on-click="() => this.open('aps_sis.action_aps_locations')">
                    <div class="smd-card-icon bg-secondary-subtle text-secondary">
                        <i class="fa fa-map-marker"/>
                    </div>
                    <div class="smd-card-body">
                        <div class="smd-card-title">Locations</div>
                        <div class="smd-card-count" t-esc="this.count('aps.location')"/>
                    </div>
                    <i class="fa fa-chevron-right smd-card-arrow text-muted"/>
                </div>
            </div>
        </div>
    </div>

    <!-- Section: Tools -->
    <div class="smd-section mb-4">
        <h5 class="smd-section-title text-uppercase text-muted fw-semibold mb-3 px-1">
            <i class="fa fa-wrench me-2"/>Tools
        </h5>
        <div class="row g-3">
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="smd-card smd-card-tool card" t-on-click="() => this.open('aps_sis.aps_school_calendar_generate_wizard_action')">
                    <div class="smd-card-icon bg-warning-subtle text-warning">
                        <i class="fa fa-magic"/>
                    </div>
                    <div class="smd-card-body">
                        <div class="smd-card-title">Generate Calendar</div>
                        <div class="smd-card-subtitle text-muted">Auto-fill from previous year</div>
                    </div>
                    <i class="fa fa-chevron-right smd-card-arrow text-muted"/>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="smd-card smd-card-tool card" t-on-click="() => this.open('aps_sis.aps_academic_week_generate_wizard_action')">
                    <div class="smd-card-icon bg-success-subtle text-success">
                        <i class="fa fa-magic"/>
                    </div>
                    <div class="smd-card-body">
                        <div class="smd-card-title">Generate Weeks</div>
                        <div class="smd-card-subtitle text-muted">Create weeks in bulk</div>
                    </div>
                    <i class="fa fa-chevron-right smd-card-arrow text-muted"/>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="smd-card smd-card-tool card" t-on-click="() => this.open('aps_sis.action_aps_student_class_bulk_wizard')">
                    <div class="smd-card-icon bg-primary-subtle text-primary">
                        <i class="fa fa-users"/>
                    </div>
                    <div class="smd-card-body">
                        <div class="smd-card-title">Bulk Class Enrolment</div>
                        <div class="smd-card-subtitle text-muted">Enrol students in bulk</div>
                    </div>
                    <i class="fa fa-chevron-right smd-card-arrow text-muted"/>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="smd-card smd-card-tool card" t-on-click="() => this.open('aps_sis.action_aps_class_rollover_wizard')">
                    <div class="smd-card-icon bg-info-subtle text-info">
                        <i class="fa fa-arrow-right"/>
                    </div>
                    <div class="smd-card-body">
                        <div class="smd-card-title">Roll Classes to New Year</div>
                        <div class="smd-card-subtitle text-muted">Carry classes forward</div>
                    </div>
                    <i class="fa fa-chevron-right smd-card-arrow text-muted"/>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="smd-card smd-card-tool card" t-on-click="() => this.open('aps_sis.action_aps_year_level_rollover_wizard')">
                    <div class="smd-card-icon bg-secondary-subtle text-secondary">
                        <i class="fa fa-level-up"/>
                    </div>
                    <div class="smd-card-body">
                        <div class="smd-card-title">Roll Students to Next Level</div>
                        <div class="smd-card-subtitle text-muted">Promote selected students</div>
                    </div>
                    <i class="fa fa-chevron-right smd-card-arrow text-muted"/>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="smd-card smd-card-tool card" t-on-click="() => this.open('aps_sis.action_aps_class_tag_enrol_wizard')">
                    <div class="smd-card-icon bg-success-subtle text-success">
                        <i class="fa fa-magic"/>
                    </div>
                    <div class="smd-card-body">
                        <div class="smd-card-title">Auto-Enrol by Tag</div>
                        <div class="smd-card-subtitle text-muted">Enrol students matching class tags</div>
                    </div>
                    <i class="fa fa-chevron-right smd-card-arrow text-muted"/>
                </div>
            </div>
        </div>
    </div>

</div>
</t>
</templates>
