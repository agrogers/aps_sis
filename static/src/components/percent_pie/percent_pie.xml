<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="aps_sis.PercentPie">
        <div class="o_pie_info pe-1">
            <span class="o_pie_value" t-if="displayValue > 0" t-esc="formattedValue"
                  t-att-style="'color: ' + color + ';'"/>
            <span class="o_pie_text" t-esc="props.string"/>
            <figure class="o_pie mb-0 mr-5 rounded-circle"
                    t-attf-style="background: conic-gradient(
                        {{color}} 0% {{displayValue}}%,
                        rgba(0, 0, 0, 0.15) 0% 100%
                    ); --PercentPieField-color-active: {{color}};"
            />
        </div>

    </t>

</templates>
