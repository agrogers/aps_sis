<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cron_recompute_submission_active_status" model="ir.cron">
        <field name="name">Recompute Active Status for APEX Submissions</field>
        <field name="model_id" ref="model_aps_resource_submission"/>
        <field name="state">code</field>
        <field name="code">model.recompute_submission_active_status()</field>
        <field name="active">True</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="nextcall" eval="(datetime.now() + relativedelta(days=1)).replace(hour=0, minute=0, second=0, microsecond=0).strftime('%Y-%m-%d %H:%M:%S')"/>        
    </record>    
