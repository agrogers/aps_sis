        <field name="model_id" ref="model_aps_resource_submission"/>
        <field name="state">code</field>
        <field name="code">model._compute_due_status()</field>
        <field name="active">True</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="nextcall" eval="(datetime.now() + relativedelta(days=1)).replace(hour=0, minute=0, second=0, microsecond=0).strftime('%Y-%m-%d %H:%M:%S')"/>
    </record> -->

    <record id="cron_send_active_notifications" model="ir.cron">
        <field name="name">Send Active Notifications for APEX Submissions</field>
        <field name="model_id" ref="model_aps_resource_submission"/>
        <field name="state">code</field>
        <field name="code">model.send_active_notifications()</field>
        <field name="active">True</field>
        <field name="interval_number">10</field>
        <field name="interval_type">minutes</field>
        <field name="nextcall" eval="(datetime.now() + relativedelta(minutes=10)).strftime('%Y-%m-%d %H:%M:%S')"/>
    </record>

    <record id="cron_recompute_submission_due_status" model="ir.cron">
        <field name="name">Recompute Due Status for APEX Submissions</field>
        <field name="model_id" ref="model_aps_resource_submission"/>
        <field name="state">code</field>
        <field name="code">model.search([('state','in',['assigned'])])._compute_days_till_due()</field>
        <field name="active">True</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="nextcall" eval="(datetime.now() + relativedelta(days=1)).replace(hour=0, minute=0, second=0, microsecond=0).strftime('%Y-%m-%d %H:%M:%S')"/>
    </record>

</odoo>