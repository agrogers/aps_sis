<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- =====================================================================
         Views: ai_prompts
         ===================================================================== -->
    <record id="view_ai_prompts_search" model="ir.ui.view">
        <field name="name">ai.prompts.search</field>
        <field name="model">ai_prompts</field>
        <field name="arch" type="xml">
            <search>
                <field name="prompt_name"/>
                <field name="prompt"/>
                <field name="message_section"/>
                <field name="applies_to_ai_models"/>
                <field name="applies_to_db_models"/>
                <field name="tag_ids"/>
                <filter name="filter_enabled" string="Enabled" domain="[('enabled', '=', True)]"/>
                <filter name="filter_disabled" string="Disabled" domain="[('enabled', '=', False)]"/>
                <filter name="filter_always_include" string="Always Include" domain="[('always_include', '=', True)]"/>
            </search>
        </field>
    </record>

    <record id="view_ai_prompts_list" model="ir.ui.view">
        <field name="name">ai.prompts.list</field>
        <field name="model">ai_prompts</field>
        <field name="arch" type="xml">
            <list default_order="sequence, id">
                <field name="sequence" widget="handle" optional="show"/>
                <field name="enabled" widget="boolean_toggle" optional="show"/>
                <field name="always_include" widget="boolean_toggle" optional="show"/>
                <field name="prompt_name"/>
                <field name="message_section" optional="show"/>
                <field name="tag_ids" widget="many2many_tags" optional="show"/>
                <field name="applies_to_ai_models" widget="many2many_tags" optional="show"/>
                <field name="applies_to_db_models" widget="many2many_tags" optional="show"/>
                <field name="create_date" optional="hide"/>
                <field name="prompt" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_ai_prompts_form" model="ir.ui.view">
        <field name="name">ai.prompts.form</field>
        <field name="model">ai_prompts</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="prompt_name"/>
                            <field name="sequence"/>
                            <field name="enabled" widget="boolean_toggle"/>
                            <field name="always_include" widget="boolean_toggle"/>
                            <field name="message_section"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            <field name="applies_to_ai_models" widget="many2many_tags" options="{'no_create': True}"/>
                            <field name="applies_to_db_models" widget="many2many_tags" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group string="Prompt">
                        <field name="prompt" nolabel="1" placeholder="Enter reusable AI prompt text."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_prompts" model="ir.actions.act_window">
        <field name="name">Prompt Templates</field>
        <field name="res_model">ai_prompts</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_ai_prompts_search"/>
    </record>

    <!-- =====================================================================
         Views: ai.prompt.tag
         ===================================================================== -->
    <record id="view_ai_prompt_tag_list" model="ir.ui.view">
        <field name="name">ai.prompt.tag.list</field>
        <field name="model">ai.prompt.tag</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <record id="view_ai_prompt_tag_form" model="ir.ui.view">
        <field name="name">ai.prompt.tag.form</field>
        <field name="model">ai.prompt.tag</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_prompt_tags" model="ir.actions.act_window">
        <field name="name">Prompt Tags</field>
        <field name="res_model">ai.prompt.tag</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- =====================================================================
         Menus  (under the AI root menu owned by aps_ai)
         ===================================================================== -->
    <menuitem id="menu_aps_ai_prompts"
              name="Prompt Templates"
              parent="menu_aps_ai_root"
              action="action_ai_prompts"
              sequence="40"
              groups="base.group_system"/>

    <menuitem id="menu_aps_ai_prompt_tags"
              name="Prompt Tags"
              parent="menu_aps_ai_root"
              action="action_ai_prompt_tags"
              sequence="50"
              groups="base.group_system"/>
</odoo>
